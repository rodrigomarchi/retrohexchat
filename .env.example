# Required
DATABASE_URL=ecto://user:pass@host/retro_hex_chat_prod
SECRET_KEY_BASE=<run: mix phx.gen.secret>
PHX_HOST=retrohexchat.app

# Dashboard auth (required in production)
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=<strong-password>

# Optional (defaults shown)
PORT=4000
POOL_SIZE=10

# Deploy targets (required for make deploy)
# DEPLOY_USER=myuser
# SUN_IP=1.2.3.4
# MOON_IP=5.6.7.8
# SSH_PORT=2222
