#: lib/retro_hex_chat/commands/handlers/invite.ex:93
#, elixir-autogen, elixir-format
msgid "Target channel (defaults to current channel)"
msgstr "Целевой канал (недостатки текущего канала)"

#: lib/retro_hex_chat/commands/handlers/mode.ex:117
#, elixir-autogen, elixir-format
msgid "Target nickname (for +o, +v, +b)"
msgstr "Прозвище цели (для +o, +v, +b)"

#: lib/retro_hex_chat/commands/handlers/p2p.ex:67
#, elixir-autogen, elixir-format
msgid "Target user"
msgstr "Целевой пользователь"

#: lib/retro_hex_chat/commands/handlers/singleplayer.ex:17
#, elixir-autogen, elixir-format
msgid "This command is reserved for administrators. "
msgstr "Эта команда зарезервирована для администраторов."

#: lib/retro_hex_chat/commands/handlers/slow.ex:75
#, elixir-autogen, elixir-format
msgid "Throttle interval in seconds (0 to disable)"
msgstr "Интервал дросселя в секундах (0 для отключения)"

#: lib/retro_hex_chat/commands/handlers/timer.ex:100
#, elixir-autogen, elixir-format
