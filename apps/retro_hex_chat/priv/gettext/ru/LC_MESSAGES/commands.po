#: lib/retro_hex_chat/commands/handlers/admin.ex:57
#, elixir-autogen, elixir-format
msgid "Subcommands: server, user, channel, ns, cs, debug, log, turn, nuke.\n"
msgstr ""
"Подкоманды: сервер, пользователь, канал, ns, cs, отладка, журнал, поворот, "
