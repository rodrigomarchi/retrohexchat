#, elixir-autogen, elixir-format
msgid "REKKR: Sunken Land"
msgstr "Оригинальное название: Sunken Land"

#: lib/retro_hex_chat/chat/help_topics/bots.ex:91
#, elixir-autogen, elixir-format
msgid ""
"RPG dice rolling with standard notation (NdS, modifiers, keep "
