msgstr ""
"Отправлять и получать личные сообщения с другими пользователями, "
"использующими /msg и /query команды."

#: lib/retro_hex_chat/chat/help_topics/commands.ex:123
#, elixir-autogen, elixir-format
msgid "Send commands to ChanServ for channel registration and management."
msgstr "Отправляйте команды ChanServ для регистрации и управления каналом."

#: lib/retro_hex_chat/chat/help_topics/commands.ex:289
#, elixir-autogen, elixir-format
