msgstr "Недостаточные привилегии для настройки режимов канала"

#: lib/retro_hex_chat/channels/modes.ex:123
#, elixir-autogen, elixir-format
msgid "Invalid mode string: must start with + or -"
msgstr "Недействительная строка режима: должна начинаться с + или -"

#: lib/retro_hex_chat/channels/server.ex:651
#, elixir-autogen, elixir-format
