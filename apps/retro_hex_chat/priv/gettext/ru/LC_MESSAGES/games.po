msgstr "Гонка через сетку, оставляя светящийся след позади вас."

#: lib/retro_hex_chat/games/catalog.ex:334
#, elixir-autogen, elixir-format
msgid "Race the avalanche"
msgstr "Скачайте лавину"

#: lib/retro_hex_chat/games/catalog.ex:265
#, elixir-autogen, elixir-format
msgid "Race through the wasteland"
msgstr "Гонка через пустыню"

