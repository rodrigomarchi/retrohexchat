#: lib/retro_hex_chat/games/catalog.ex:160
#, elixir-autogen, elixir-format
msgid "Fast and furious"
msgstr "Быстрый и яростный"

#: lib/retro_hex_chat/games/catalog.ex:363
#, elixir-autogen, elixir-format
msgid "Fastest time down the mountain wins."
msgstr "Самое быстрое время в горах побеждает."

#: lib/retro_hex_chat/games/catalog.ex:89
#, elixir-autogen, elixir-format
msgid "Fight through a field of floating asteroids that block missiles and kill on contact. "
