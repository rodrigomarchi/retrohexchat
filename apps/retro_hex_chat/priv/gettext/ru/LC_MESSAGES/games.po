#: lib/retro_hex_chat/games/catalog.ex:248
#, elixir-autogen, elixir-format
msgid "No alien drop. Survive together or fall together."
msgstr "Никаких инопланетных капель. Выжить вместе или упасть вместе."

#: lib/retro_hex_chat/games/catalog.ex:362
#, elixir-autogen, elixir-format
msgid "No avalanche, no items — just trees, rocks, and gates. "
msgstr "Нет лавины, нет предметов — только деревья, камни и ворота."

#: lib/retro_hex_chat/games/catalog.ex:255
#, elixir-autogen, elixir-format
msgid "No mercy, no delay"
msgstr "Никакой пощады, никакой задержки."

#: lib/retro_hex_chat/games/catalog.ex:150
#, elixir-autogen, elixir-format
msgid "No mines, pure skill"
msgstr "Никаких мин, чистое мастерство"

#: lib/retro_hex_chat/games/catalog.ex:396
#, elixir-autogen, elixir-format
msgid "No stealing, pure race"
msgstr "Нет воровства, чистая раса"

#: lib/retro_hex_chat/games/catalog.ex:434
#, elixir-autogen, elixir-format
msgid "No timer — first to 5 goals wins. Puck speed increases with each goal scored. "
msgstr "Нет таймера — сначала выигрывает 5 голов. Скорость шайбы увеличивается с каждым забитым голом."

#: lib/retro_hex_chat/games/session_server.ex:155
#, elixir-autogen, elixir-format
msgid "Not a participant"
msgstr "Не участник"

#: lib/retro_hex_chat/games/catalog.ex:219
#, elixir-autogen, elixir-format
msgid "Nowhere to hide"
msgstr "Негде спрятаться"

#: lib/retro_hex_chat/games/catalog.ex:386
#, elixir-autogen, elixir-format
msgid "One epic round"
msgstr "Один эпический раунд"

#: lib/retro_hex_chat/games/catalog.ex:424
#, elixir-autogen, elixir-format
msgid "One period of 3 minutes — faster puck, higher tackle success rate. "
msgstr "Один период в 3 минуты — более быстрая шайба, более высокий показатель успеха."

#: lib/retro_hex_chat/games/catalog.ex:324
#, elixir-autogen, elixir-format
msgid "One point, one game"
msgstr "Одно очко, одна игра"

#: lib/retro_hex_chat/games/catalog.ex:73
#, elixir-autogen, elixir-format
msgid "Orbit the dying star"
msgstr "Орбита умирающей звезды"

#: lib/retro_hex_chat/games/catalog.ex:75
#, elixir-autogen, elixir-format
msgid "Orbital combat around a central gravity star. "
msgstr "Орбитальный бой вокруг центральной гравитационной звезды."

#: lib/retro_hex_chat/games/catalog.ex:350
#, elixir-autogen, elixir-format
msgid "Outrun the wasteland"
msgstr "Опередить пустошь"

#: lib/retro_hex_chat/games/catalog.ex:268
#, elixir-autogen, elixir-format
