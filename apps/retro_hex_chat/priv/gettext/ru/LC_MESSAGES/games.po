msgstr "Сначала 11 очков (выигрыш на 2). Шар ускоряется на каждом ралли."

#: lib/retro_hex_chat/games/catalog.ex:314
#, elixir-autogen, elixir-format
msgid "First to 3 games"
msgstr "Первые 3 игры"

#: lib/retro_hex_chat/games/catalog.ex:327
#, elixir-autogen, elixir-format
msgid "First to 6 games takes the set. Pure pressure."
msgstr "Первая до 6 игр занимает сет. Чистое давление."

#: lib/retro_hex_chat/games/catalog.ex:399
#, elixir-autogen, elixir-format
msgid "First to complete the igloo wins. Fair and square."
msgstr "Сначала доиграем иглу. Справедливо и честно."

#: lib/retro_hex_chat/games/catalog.ex:432
#, elixir-autogen, elixir-format
msgid "First to five"
msgstr "Первый до пяти"

#: lib/retro_hex_chat/games/catalog.ex:170
#, elixir-autogen, elixir-format
msgid "Fists of fury"
msgstr "Кулаки ярости"

#: lib/retro_hex_chat/games/catalog.ex:307
#, elixir-autogen, elixir-format
msgid "Full set with tiebreak at 6-6. Deuce, advantage, the works."
msgstr "Полный комплект с тай-брейком на 6-6. Дьюс, преимущество, работа."

#: lib/retro_hex_chat/games/policy.ex:101
#, elixir-autogen, elixir-format
msgid "Game session is no longer active"
msgstr "Сеанс игры больше не активен"

#: lib/retro_hex_chat/games/catalog.ex:279
#, elixir-autogen, elixir-format
msgid "Headlights only"
msgstr "Только фары"

#: lib/retro_hex_chat/games/catalog.ex:39
#, elixir-autogen, elixir-format
