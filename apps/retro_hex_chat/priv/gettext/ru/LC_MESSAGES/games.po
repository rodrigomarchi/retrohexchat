#: lib/retro_hex_chat/games/catalog.ex:353
#, elixir-autogen, elixir-format
msgid "Last skier standing wins. Pure survival."
msgstr "Победит последний лыжник. Чистое выживание."

#: lib/retro_hex_chat/games/catalog.ex:206
#, elixir-autogen, elixir-format
msgid "Moving cover"
msgstr "Движущаяся крышка"

#: lib/retro_hex_chat/games/catalog.ex:87
#, elixir-autogen, elixir-format
msgid "Navigate the wreckage"
msgstr "Навигация по обломкам"

#: lib/retro_hex_chat/games/catalog.ex:406
#, elixir-autogen, elixir-format
msgid "Neon ice warfare"
msgstr "Неоновая ледяная война"

#: lib/retro_hex_chat/games/catalog.ex:58
#, elixir-autogen, elixir-format
msgid "Newtonian space combat — thrust, rotate, and fire missiles in open vacuum. "
