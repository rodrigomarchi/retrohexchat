#: lib/retro_hex_chat/games/catalog.ex:25
#, elixir-autogen, elixir-format
msgid "Pong reimagined as cyberpunk arcade — neon glow, CRT scanlines, synth audio. "
msgstr "Pong переосмыслен как аркада киберпанка — неоновое свечение, CRT-сканирование, синтезаторное аудио."

#: lib/retro_hex_chat/games/catalog.ex:267
#, elixir-autogen, elixir-format
msgid "Pseudo-3D racing duel through day, snow, fog, and night. "
msgstr "Псевдо-3D гонки дуэль днем, снегом, туманом и ночью."

#: lib/retro_hex_chat/games/catalog.ex:153
#, elixir-autogen, elixir-format
msgid "Pure competition for points, fuel, and survival across 10 sections."
msgstr "Чистая конкуренция за очки, топливо и выживание в 10 секциях."

#: lib/retro_hex_chat/games/catalog.ex:398
#, elixir-autogen, elixir-format
msgid "Pure construction race — no block stealing allowed. "
msgstr "Чистая строительная гонка — не допускается кража блоков."

#: lib/retro_hex_chat/games/catalog.ex:360
#, elixir-autogen, elixir-format
msgid "Pure downhill duel"
msgstr "Чистая спусковая дуэль"

#: lib/retro_hex_chat/games/catalog.ex:425
#, elixir-autogen, elixir-format
