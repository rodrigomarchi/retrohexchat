#: lib/retro_hex_chat/games/catalog.ex:76
#, elixir-autogen, elixir-format
msgid "Use gravity slingshots, but fly too close and the star kills you. First to 7 wins."
msgstr "Используйте гравитационные рогатки, но летите слишком близко, и звезда вас убьет. Сначала 7 побед."

#: lib/retro_hex_chat/games/catalog.ex:93
#, elixir-autogen, elixir-format
msgid "Use the debris for cover — or watch it destroy you. First to 7 wins."
msgstr "Используйте мусор для укрытия или наблюдайте, как он разрушает вас. Сначала 7 побед."

#: lib/retro_hex_chat/games/policy.ex:85
#, elixir-autogen, elixir-format
msgid "User not available"
msgstr "Пользователь недоступен"

#: lib/retro_hex_chat/games/catalog.ex:119
#, elixir-autogen, elixir-format
msgid "Versus Breakout battle — each player defends a brick castle with a king inside. "
msgstr "Versus Breakout Battle — каждый игрок защищает кирпичный замок с королем внутри."

#: lib/retro_hex_chat/games/catalog.ex:221
#, elixir-autogen, elixir-format
msgid "Western duel in open field — no obstacle, full horizontal movement. "
msgstr "Западная дуэль в открытом поле — без препятствий, полное горизонтальное движение."

#: lib/retro_hex_chat/games/catalog.ex:208
#, elixir-autogen, elixir-format
msgid "Western duel with a stagecoach rolling across the arena. "
msgstr "Западный поединок с дилижансом, катящимся по арене."

#: lib/retro_hex_chat/games/catalog.ex:192
#, elixir-autogen, elixir-format
