#: lib/retro_hex_chat/games/catalog.ex:46
#, elixir-autogen, elixir-format
msgid "Blast through the maze"
msgstr "Взрыв через лабиринт"

#: lib/retro_hex_chat/games/catalog.ex:257
#, elixir-autogen, elixir-format
msgid "Blitz Space Invaders — instant alien drops, easier combos, "
msgstr "Blitz Space Invaders — мгновенные инопланетные капли, более простые комбинации"

#: lib/retro_hex_chat/games/catalog.ex:104
#, elixir-autogen, elixir-format
msgid "Break blocks together"
msgstr "Разбивать блоки вместе"

#: lib/retro_hex_chat/games/catalog.ex:370
#, elixir-autogen, elixir-format
msgid "Build or be frozen"
msgstr "Построить или заморозить"

#: lib/retro_hex_chat/games/catalog.ex:190
#, elixir-autogen, elixir-format
msgid "Bullets bounce back"
msgstr "Пули отскакивают назад"

#: lib/retro_hex_chat/games/catalog.ex:196
#, elixir-autogen, elixir-format
msgid "Bullets ricochet once off ceiling/floor. First to 10. Best of 3 rounds."
msgstr "Пули рикошетом с потолка/floorСначала до 10. Лучший из 3 раундов."

#: lib/retro_hex_chat/games/policy.ex:43
#, elixir-autogen, elixir-format
msgid "Cannot start a game with yourself"
msgstr "Невозможно начать игру с самим собой"

#: lib/retro_hex_chat/games/catalog.ex:244
#, elixir-autogen, elixir-format
msgid "Classic co-op Space Invaders — two cannons fighting the same alien waves. "
msgstr "Классический кооператив Space Invaders — две пушки, сражающиеся с одинаковыми инопланетными волнами."

#: lib/retro_hex_chat/games/catalog.ex:235
#, elixir-autogen, elixir-format
msgid "Combos send extra. 10 waves of escalating chaos."
msgstr "Комбо посылают дополнительные 10 волн нарастающего хаоса."

#: lib/retro_hex_chat/games/catalog.ex:106
#, elixir-autogen, elixir-format
msgid "Cooperative Breakout with two paddles — one at the top, one at the bottom. "
msgstr "Кооперативный прорыв с двумя веслами — один вверху, один внизу."

#: lib/retro_hex_chat/games/catalog.ex:23
#, elixir-autogen, elixir-format
msgid "Cyberpunk Pong"
msgstr "Киберпанк-понг"

#: lib/retro_hex_chat/games/catalog.ex:292
#, elixir-autogen, elixir-format
msgid "Daylight sprint — no weather changes, no fuel drain, just speed. "
msgstr "Дневной спринт — нет изменений погоды, нет слива топлива, только скорость."

#: lib/retro_hex_chat/games/catalog.ex:242
#, elixir-autogen, elixir-format
msgid "Defend Earth together"
msgstr "Защитим Землю вместе"

#: lib/retro_hex_chat/games/catalog.ex:117
#, elixir-autogen, elixir-format
msgid "Defend your castle"
msgstr "Защитите свой замок"

#: lib/retro_hex_chat/games/catalog.ex:123
#, elixir-autogen, elixir-format
msgid "Deflect or catch the fireball to smash your opponent's walls. Last king standing wins."
msgstr "Отклоняйте или ловите огненный шар, чтобы разбить стены противника. Победит последний король."

#: lib/retro_hex_chat/games/catalog.ex:183
#, elixir-autogen, elixir-format
msgid "Dodge bullets you can see coming. First to 10. Best of 3 rounds."
msgstr "Уклоняйтесь от пуль, которые вы видите. Сначала до 10. Лучший из 3 раундов."

#: lib/retro_hex_chat/games/catalog.ex:222
#, elixir-autogen, elixir-format
msgid "Dodge freely in your half. First to 10. Best of 3 rounds."
msgstr "Уклоняйтесь свободно в своей половине. Сначала до 10. Лучший из 3 раундов."

#: lib/retro_hex_chat/games/catalog.ex:56
#, elixir-autogen, elixir-format
msgid "Dogfight in the void"
msgstr "Собачий бой в пустоте"

#: lib/retro_hex_chat/games/catalog.ex:36
#, elixir-autogen, elixir-format
msgid "Don't cross the line"
msgstr "Не пересекай линию"

#: lib/retro_hex_chat/games/catalog.ex:180
#, elixir-autogen, elixir-format
