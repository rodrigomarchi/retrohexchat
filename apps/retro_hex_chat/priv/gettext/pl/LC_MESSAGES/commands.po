#: lib/retro_hex_chat/commands/handlers/umode.ex:76
#, elixir-autogen, elixir-format
msgid "Toggle personal user modes that affect what messages you receive."
msgstr ""
"Włączenie / wyłączenie trybów osobistych użytkowników, które wpływają na "
"otrzymane wiadomości."

#: lib/retro_hex_chat/commands/handlers/umode.ex:42
#, elixir-autogen, elixir-format
msgid ""
"Toggle personal user modes that affect what messages you receive.\n"
"Available modes: +w (wallops — receive operator broadcast messages), -w (stop receiving).\n"
"Must start with + or -. Currently only the w (wallops) mode is supported."
msgstr ""
"Włączenie / wyłączenie trybów osobistych użytkowników, które wpływają na otrzymane wiadomości.\n"
"Dostępne tryby: + w (wallopy - odbieraj komunikaty nadawane przez operatora), -w (przestań odbierać).\n"
"Trzeba zacząć od + lub -. Obecnie obsługiwane jest tylko tryb w (wallops)."

#: lib/retro_hex_chat/commands/handlers/mode.ex:159
#, elixir-autogen, elixir-format
