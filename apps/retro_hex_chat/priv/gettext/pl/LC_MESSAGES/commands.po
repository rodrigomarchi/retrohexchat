msgstr "Temat chroniony"

#: lib/retro_hex_chat/commands/handlers/notify.ex:104
#, elixir-autogen, elixir-format
msgid ""
"Track when specific users come online or go offline with your buddy list."
msgstr ""
"Śledź, gdy konkretni użytkownicy są online lub offline z listy znajomych."

#: lib/retro_hex_chat/commands/handlers/notify.ex:77
#, elixir-autogen, elixir-format
msgid ""
"Track when specific users come online or go offline with your buddy list.\n"
"Subcommands: add <nick> [note], remove <nick>, edit <nick> <note>, list. No args opens the dialog.\n"
"Registered users: persisted. Guests: session-only."
msgstr ""
"Śledź, gdy konkretni użytkownicy są online lub offline z listy znajomych.\n"
"Podkomendy: dodać < ph0 > < < ph4 > < / ph4 > > [uwaga], usunąć < ph1 > < < ph5 > < / ph5 > >, edytować < ph2 > < < ph6 > < / ph6 > > < ph3 > < ph7 > < / ph7 > >, lista. Nie otwierają okna dialogowego.\n"
"Zarejestrowani użytkownicy: utrzymują się. Goście: tylko sesja."

#: lib/retro_hex_chat/commands/handlers/transfer.ex:49
#, elixir-autogen, elixir-format
msgid "Transfer channel ownership to another user."
msgstr "Transfer własności kanału do innego użytkownika."

#: lib/retro_hex_chat/commands/handlers/transfer.ex:29
#, elixir-autogen, elixir-format
msgid ""
"Transfer channel ownership to another user.\n"
"The new owner gets +q (owner) and you are demoted to operator.\n"
"Requires: channel owner."
msgstr ""
"Transfer własności kanału do innego użytkownika.\n"
"Nowy właściciel dostaje + q (właściciel) i jesteś zdegradowany do operatora.\n"
"Wymaga: właściciela kanału."

#: lib/retro_hex_chat/commands/handlers/admin.ex:61
#, elixir-autogen, elixir-format
msgid "Type /admin <subcommand> for usage details."
msgstr ""
"Typ < ph1 > < / ph1 > < ph0 > < ph2 > < / ph2 > > dla szczegółów "
"użytkowania."

#: lib/retro_hex_chat/commands/handlers/ignore.ex:139
#, elixir-autogen, elixir-format
msgid "Type: all, messages, pms, actions, notices, invites"
msgstr "Typ: wszystkie, wiadomości, pms, akcje, ogłoszenia, zaproszenia"

