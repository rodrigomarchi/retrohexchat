#: lib/retro_hex_chat/arcade/catalog.ex:51
#, elixir-autogen, elixir-format
msgid "32 levels — Doom II compatible"
msgstr "32 livelli — Doom II compatibile"

#: lib/retro_hex_chat/arcade/catalog.ex:37
#, elixir-autogen, elixir-format
msgid "36 levels of open-source doom"
msgstr "36 livelli di dominio open source"

#: lib/retro_hex_chat/arcade/catalog.ex:109
#, elixir-autogen, elixir-format
msgid ""
"A Viking-themed total conversion with hand-drawn pixel art. Battle through "
"Norse-inspired levels with axes, bows, and runic magic."
msgstr ""
"Conversione totale a tema vichingo con pixel art disegnato a mano. Battaglia"
" attraverso livelli di ispirazione norrena con assi, archi e magia runica."

#: lib/retro_hex_chat/arcade/catalog.ex:53
#, elixir-autogen, elixir-format
msgid ""
"A complete free replacement for DOOM II — 32 levels with the Super Shotgun. "
"Compatible with thousands of community-made PWAD mods."
msgstr ""
"Una sostituzione gratuita completa per DOOM II — 32 livelli con il Super "
"Shotgun. Compatibile con migliaia di mod PWAD fatti dalla comunità."

#: lib/retro_hex_chat/arcade/catalog.ex:136
#, elixir-autogen, elixir-format
msgid ""
"A complete free replacement for Quake — original levels, art, and music "
"under BSD license. Community-made open-source content."
msgstr ""
"Una sostituzione gratuita completa per Quake — livelli originali, arte e "
"musica sotto licenza BSD. Contenuto di open source comunitario."

#: lib/retro_hex_chat/arcade/catalog.ex:39
#, elixir-autogen, elixir-format
msgid ""
"A complete free replacement for Ultimate DOOM — 4 episodes, 36 levels. "
"Original art, music, and levels under BSD license."
msgstr ""
"Una sostituzione gratuita completa per Ultimate DOOM — 4 episodi, 36 "
"livelli. Arte originale, musica e livelli sotto licenza BSD."

#: lib/retro_hex_chat/arcade/catalog.ex:95
#, elixir-autogen, elixir-format
msgid ""
"A cyberpunk total conversion — hack through a dystopian future with new "
"weapons, enemies, and levels. Standalone v1.2 IWAD."
msgstr ""
"Una conversione totale cyberpunk — hack attraverso un futuro distopico con "
"nuove armi, nemici e livelli. Standalone v1.2 IWAD."

#: lib/retro_hex_chat/arcade/catalog.ex:234
#, elixir-autogen, elixir-format
msgid ""
"A disturbing top-down cyberpunk adventure by Creative Reality. You are Ryan,"
" plagued by nightmares about the Dreamweb — a mystical barrier protecting "
"reality. Full CD version with voice acting."
msgstr ""
"Un'inquietante avventura cyberpunk di Creative Reality. Tu sei Ryan, "
"afflitto da incubi sul Dreamweb — una barriera mistica che protegge la "
"realtà. Versione CD completa con recitazione vocale."

#: lib/retro_hex_chat/arcade/content/halflife_uplink.ex:27
#: lib/retro_hex_chat/arcade/content/librequake.ex:27
