msgid "Strafe left"
msgstr "Strafe sinistra"

#: lib/retro_hex_chat/arcade/content/chex_quest.ex:26
#: lib/retro_hex_chat/arcade/content/doom_shareware.ex:26
#: lib/retro_hex_chat/arcade/content/freedm.ex:26
#: lib/retro_hex_chat/arcade/content/freedoom1.ex:26
#: lib/retro_hex_chat/arcade/content/freedoom2.ex:26
