#: lib/retro_hex_chat/chat/help_topics/features.ex:1355
#, elixir-autogen, elixir-format
msgid "10 sections of increasing difficulty. Destroy bridges to advance. "
msgstr "১০ নাম্বার সেকশনে সমস্যা বেড়েই চলছে। সেতু ধ্বংস করুন."

#: lib/retro_hex_chat/chat/help_topics/features.ex:1176
#, elixir-autogen, elixir-format
msgid "2-minute rounds, best of 3. Modes: Classic (open field) and Maze Battle. "
msgstr "২ মিনিটের রাউন্ড, ৩-এর মধ্যে। মোড"

#: lib/retro_hex_chat/chat/help_topics/features.ex:1289
#, elixir-autogen, elixir-format
msgid "3 shared lives, 50 neon blocks (5 rows), ball speeds up. Arrow keys or A/D to move."
msgstr "৩ জন মানুষ বেঁচে আছে, ৫০ নিউন ব্লক (৫ সারি), বলদের গতি বেড়ে গেছে। অ্যারো কী অথবা কী [<f\\-0\\-0] সরানো হয়েছে।"

#: lib/retro_hex_chat/chat/help_topics/features.ex:1695
#, elixir-autogen, elixir-format
msgid "3-minute race in permanent darkness with fog bursts. "
msgstr "৩ মিনিটের অন্ধকারে কুয়াশার ডাস্টবিনে।"

#: lib/retro_hex_chat/chat/help_topics/features.ex:2509
#, elixir-autogen, elixir-format
msgid "32 deathmatch-focused arena maps for the DOOM engine. BSD license."
msgstr "DOM ইঞ্জিনের জন্য DOM ইঞ্জিনের জন্য DOM এর মানচিত্র BSD লাইসেন্স।"

#: lib/retro_hex_chat/chat/help_topics/features.ex:1404
#, elixir-autogen, elixir-format
msgid "5 sections of intense River Raid action — river starts narrow, "
msgstr "৫ চরম নদীগুলোর মধ্যে একটা"

#: lib/retro_hex_chat/chat/help_topics/features.ex:1637
#, elixir-autogen, elixir-format
msgid "5 waves of pure chaos from the start. "
msgstr "শুরু থেকে বিশুদ্ধ বিশৃঙ্খলার ৫ তরঙ্গ।"

#: lib/retro_hex_chat/chat/help_topics/features.ex:1034
#, elixir-autogen, elixir-format
msgid "7 days"
msgstr "৭ দিন"

#: lib/retro_hex_chat/chat/help_topics/features.ex:1723
#, elixir-autogen, elixir-format
msgid "90 seconds to score maximum overtakes. "
msgstr "৯০ সেকেন্ডের সর্বাধিক গতি।"

#: lib/retro_hex_chat/chat/help_topics/features.ex:2596
#, elixir-autogen, elixir-format
msgid "A Viking-themed DOOM total conversion with hand-drawn pixel art — axes, bows, and runic magic. Cacoward 2018 winner."
msgstr "একটি ভিকিং-এর থিম-এর মালিক ডওএম-এর হাতে তুলে দেওয়া পিক্সেল আর্টের মাধ্যমে সম্পূর্ণভাবে পরিবর্তিত হচ্ছে। ক্রুওয়ার্ড ২০১৮ বিজয়ী।"

#: lib/retro_hex_chat/chat/help_topics/features.ex:2480
#, elixir-autogen, elixir-format
msgid "A complete free replacement for DOOM II — 32 levels with the Super Shotgun. Compatible with community PWAD mods."
msgstr "ডিওএম ২-এর জন্য সম্পূর্ণভাবে এক মুক্ত জায়গা — সুপার শটগানের ৩২টি স্তর । পিডাব্লিউএডির সাথে সুসংগত।"

#: lib/retro_hex_chat/chat/help_topics/features.ex:2651
#, elixir-autogen, elixir-format
msgid "A complete free replacement for Quake — original levels, art, and music under BSD license."
msgstr "কোকুন — মূল স্তর, শিল্প এবং সংগীত"

#: lib/retro_hex_chat/chat/help_topics/features.ex:2450
#, elixir-autogen, elixir-format
msgid "A complete free replacement for Ultimate DOOM — 4 episodes, 36 levels with original art and music."
msgstr "সর্বাধিক অর্থসংস্থান লাভ করা"

#: lib/retro_hex_chat/chat/help_topics/features.ex:2565
#, elixir-autogen, elixir-format
msgid "A cyberpunk DOOM total conversion with new weapons, enemies, and levels. Standalone v1.2 IWAD."
msgstr "একটি সাইবারপাঙ্ক DOM সম্পূর্ণ নতুন অস্ত্র, শত্রু এবং লেভেলে রূপান্তর। স্বতন্ত্র v1.2 IWAD."

#: lib/retro_hex_chat/chat/help_topics/user_interface.ex:121
#, elixir-autogen, elixir-format
msgid "Access all features through the toolbar buttons organized in six groups."
msgstr "টুলবার বাটন দিয়ে ৬টি দলে সংগঠিত সমস্ত বৈশিষ্ট্য ব্যবহার করা হয় ।"

#: lib/retro_hex_chat/chat/help_topics/user_interface.ex:91
#, elixir-autogen, elixir-format
msgid "Access user actions and channel operations through right-click context menus."
msgstr "ব্যবহারকারী এবং চ্যানেল দ্বারা ডান-থেকে-ডান মেনুর মধ্যে কর্ম ব্যবহার করুন।"

#: lib/retro_hex_chat/chat/help_topics/commands.ex:152
#, elixir-autogen, elixir-format
msgid "Add a user to your ignore list to hide their messages and actions."
msgstr "উপেক্ষা করার জন্য চিহ্নিত বার্তাগুলিকে উপেক্ষা করার জন্য চিহ্নিত করুন।"

#: lib/retro_hex_chat/chat/help_topics/features.ex:332
#, elixir-autogen, elixir-format
msgid "Add custom items to right-click context menus for quick access to commands."
msgstr "কমান্ডের সাহায্যে মেনুর মধ্যে কিছু কনটেক্সট মেনুর জন্য ডান বাটন ক্লিক করা যাবে।"

#: lib/retro_hex_chat/chat/help_topics/commands.ex:277
#, elixir-autogen, elixir-format
