#: lib/retro_hex_chat/commands/handlers/mode.ex:37
#: lib/retro_hex_chat/commands/handlers/mode.ex:99
#, elixir-autogen, elixir-format
msgid "Change channel settings and user privileges using mode flags.\n"
"Flags: +o (operator), +v (voice), +b (ban), +h (half-op), +m (moderated), +i (invite-only), +t (topic protected), +k (key/password), +l (user limit), +n (no external messages), +j (join throttle), +K (no knock).\n"
"Requires: channel operator. Half-operators can only set +v/-v. Must be in a channel."
msgstr "Ändern Sie die Kanaleinstellungen und Benutzerrechte mithilfe von Mode-Flags.\n"
"Flaggen: +o (Operator), +v (Sprache), +b (ban), +h (half-op), +m (modifiziert), +i (nur eingeladen), +t (topisch geschützt), +k (key/password), +l (Benutzergrenze), +n (keine externe Nachrichten), +j (Joindrossel), +K (kein Klopf).\n"
"Anforderungen: Kanalbetreiber. Halbbediener können nur +v/-v einstellen. Muss in einem Kanal sein."

#: lib/retro_hex_chat/commands/handlers/nick.ex:82
