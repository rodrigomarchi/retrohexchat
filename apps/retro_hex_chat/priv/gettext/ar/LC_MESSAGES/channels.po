#: lib/retro_hex_chat/channels/modes.ex:216
#, elixir-autogen, elixir-format
msgid "+s and +p are mutually exclusive"
msgstr "+s and +p are mutually exclusive"

#: lib/retro_hex_chat/channels/server.ex:1030
#, elixir-autogen, elixir-format
msgid "Already in channel"
msgstr "بالفعل في القناة"

#: lib/retro_hex_chat/channels/policy.ex:47
#, elixir-autogen, elixir-format
msgid "Bad channel key (+k)"
msgstr "مفتاح القناة السيئة (+ك)"

#: lib/retro_hex_chat/channels/server.ex:440
#: lib/retro_hex_chat/channels/server.ex:852
#, elixir-autogen, elixir-format
msgid "Banned"
msgstr "تم حظرها"

#: lib/retro_hex_chat/channels/policy.ex:153
#, elixir-autogen, elixir-format
msgid "Cannot ban a user with equal or higher rank"
msgstr "لا يمكن أن تحظر على المستخدم ذي رتب متساوية أو أعلى"

#: lib/retro_hex_chat/channels/policy.ex:126
#, elixir-autogen, elixir-format
msgid "Cannot kick a higher-ranked user"
msgstr "لا يمكن ركلة مستعمل أعلى مرتبة"

#: lib/retro_hex_chat/channels/policy.ex:63
#, elixir-autogen, elixir-format
msgid "Cannot send to channel (no external messages)"
msgstr "لا يمكن إرسالها إلى القناة (لا رسائل خارجية)"

#: lib/retro_hex_chat/channels/policy.ex:35
#, elixir-autogen, elixir-format
msgid "Channel is full (+l)"
msgstr "القناة كاملة (+ل)"

#: lib/retro_hex_chat/channels/policy.ex:41
#, elixir-autogen, elixir-format
msgid "Channel is invite-only (+i)"
msgstr "القناة مدعوة فقط (+i)"

#: lib/retro_hex_chat/channels/policy.ex:72
#, elixir-autogen, elixir-format
msgid "Channel is moderated (+m). You need voice (+v) to speak."
msgstr "وتدار القناة (+م). تحتاج إلى صوت لتتحدث"

#: lib/retro_hex_chat/channels/server.ex:648
#, elixir-autogen, elixir-format
msgid "Channel is not invite-only"
msgstr "القناة ليست دعوة فقط"

#: lib/retro_hex_chat/channels/server.ex:1055
#, elixir-autogen, elixir-format
msgid "Channel join throttle active, please try again shortly"
msgstr "القناة تندمج بنشاط من فضلك حاول مرة أخرى قريبا"

#: lib/retro_hex_chat/channels/server.ex:68
#: lib/retro_hex_chat/channels/server.ex:71
#: lib/retro_hex_chat/channels/server.ex:222
#: lib/retro_hex_chat/channels/server.ex:225
#, elixir-autogen, elixir-format
msgid "Channel not found"
msgstr "لم يعثر على القناة"

#: lib/retro_hex_chat/channels/policy.ex:116
#: lib/retro_hex_chat/channels/policy.ex:117
#: lib/retro_hex_chat/channels/policy.ex:142
#: lib/retro_hex_chat/channels/policy.ex:143
#: lib/retro_hex_chat/channels/server.ex:691
#: lib/retro_hex_chat/channels/server.ex:705
#: lib/retro_hex_chat/channels/server.ex:708
#, elixir-autogen, elixir-format
msgid "Insufficient privileges"
msgstr "عدم كفاية الامتيازات"

#: lib/retro_hex_chat/channels/policy.ex:169
#: lib/retro_hex_chat/channels/policy.ex:173
#, elixir-autogen, elixir-format
msgid "Insufficient privileges to set channel modes"
msgstr "عدم كفاية الامتيازات لوضع أساليب القنوات"

#: lib/retro_hex_chat/channels/modes.ex:123
#, elixir-autogen, elixir-format
msgid "Invalid mode string: must start with + or -"
msgstr "سلاسل نمطية غير سليمة: يجب أن تبدأ بـ + أو"

#: lib/retro_hex_chat/channels/server.ex:651
#, elixir-autogen, elixir-format
msgid "Knocking is disabled for this channel"
msgstr "الدق معاق لهذه القناة"

#: lib/retro_hex_chat/channels/server.ex:317
#, elixir-autogen, elixir-format
msgid "Not in channel"
msgstr "ليس في القناة"

#: lib/retro_hex_chat/channels/server.ex:758
#, elixir-autogen, elixir-format
msgid "Only the channel owner can transfer ownership"
msgstr "فقط مالك القناة يمكنه نقل الملكية"

#: lib/retro_hex_chat/channels/server.ex:923
#, elixir-autogen, elixir-format
msgid "User %{target} is not in channel"
msgstr "مستخدم %{target} ليس في القناة"

#: lib/retro_hex_chat/channels/server.ex:688
#: lib/retro_hex_chat/channels/server.ex:762
#, elixir-autogen, elixir-format
msgid "User is not in channel"
msgstr "المستخدم ليس في القناة"

#: lib/retro_hex_chat/channels/server.ex:658
#, elixir-autogen, elixir-format
msgid "You are already in that channel"
msgstr "أنت بالفعل في تلك القناة"

#: lib/retro_hex_chat/channels/server.ex:655
#, elixir-autogen, elixir-format
msgid "You are banned from that channel"
msgstr "أنت ممنوع من تلك القناة"

#: lib/retro_hex_chat/channels/server.ex:966
#, elixir-autogen, elixir-format
msgid "You are muted in this channel"
msgstr "أنت مطحون في هذه القناة"

#: lib/retro_hex_chat/channels/policy.ex:75
#: lib/retro_hex_chat/channels/policy.ex:82
#: lib/retro_hex_chat/channels/policy.ex:97
#, elixir-autogen, elixir-format
msgid "You are not in this channel"
msgstr "أنت لست في هذه القناة"

#: lib/retro_hex_chat/channels/policy.ex:136
#, elixir-autogen, elixir-format
msgid "You cannot ban yourself"
msgstr "لا يمكنك أن تحظر نفسك"

#: lib/retro_hex_chat/channels/server.ex:501
#: lib/retro_hex_chat/channels/server.ex:527
#: lib/retro_hex_chat/channels/server.ex:553
#: lib/retro_hex_chat/channels/server.ex:579
#, elixir-autogen, elixir-format
msgid "You must be a channel operator"
msgstr "يجب أن تكون مشغل القناة"

#: lib/retro_hex_chat/channels/policy.ex:91
#, elixir-autogen, elixir-format
msgid "You must be a channel operator to change the topic"
msgstr "يجب أن تكون مشغل القناة لتغيير الموضوع"

#: lib/retro_hex_chat/channels/server.ex:597
#: lib/retro_hex_chat/channels/server.ex:868
#, elixir-autogen, elixir-format
msgid "You must be a channel operator to unban users"
msgstr "يجب أن تكون مشغل قناة للمستعملين"

#: lib/retro_hex_chat/channels/policy.ex:53
#, elixir-autogen, elixir-format
msgid "You must be registered to join this channel"
msgstr "يجب أن تكون مسجلاً للإنضمام إلى هذه القناة"
