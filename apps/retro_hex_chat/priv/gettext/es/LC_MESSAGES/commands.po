msgstr "Información y configuración del servidor"

#: lib/retro_hex_chat/commands/handlers/set_welcome.ex:72
#, elixir-autogen, elixir-format
msgid ""
"Set a message shown once to each user when they join the current channel."
msgstr ""
"Establecer un mensaje mostrado una vez a cada usuario cuando se unen al "
"canal actual."

#: lib/retro_hex_chat/commands/handlers/set_welcome.ex:47
#, elixir-autogen, elixir-format
msgid ""
"Set a message shown once to each user when they join the current channel.\n"
"Requires: channel operator. Must be in a channel.\n"
"With no args: clears the welcome message (same as /clearwelcome)."
msgstr ""
"Establecer un mensaje mostrado una vez a cada usuario cuando se unen al canal actual.\n"
"Requiere: operador de canal. Debe estar en un canal.\n"
"Sin args: aclara el mensaje de bienvenida (igual que /clearwelcome)."

#: lib/retro_hex_chat/commands/handlers/bio.ex:73
#, elixir-autogen, elixir-format
msgid ""
"Set a short 'about me' text visible when others look you up with /whois."
msgstr ""
"Establece un texto corto 'sobre mí' visible cuando otros te miran con "
"/whois."

#: lib/retro_hex_chat/commands/handlers/bio.ex:48
#, elixir-autogen, elixir-format
msgid ""
"Set a short 'about me' text visible when others look you up with /whois.\n"
"Max 200 characters (text beyond this limit is silently truncated). Use /bio to view, /bio clear to remove."
msgstr ""
"Establece un texto corto 'sobre mí' visible cuando otros te miran con /whois.\n"
"Max 200 caracteres (texto más allá de este límite es silenciosamente truncado). Use /bio para ver, /bio para eliminar."

#: lib/retro_hex_chat/commands/handlers/mode.ex:166
#, elixir-autogen, elixir-format
msgid "Set channel password"
msgstr "Establecer contraseña del canal"

#: lib/retro_hex_chat/commands/handlers/autojoin.ex:117
#, elixir-autogen, elixir-format
msgid "Set channels to join automatically every time you connect."
msgstr ""
"Establecer canales para unirse automáticamente cada vez que se conecta."

#: lib/retro_hex_chat/commands/handlers/autojoin.ex:80
#, elixir-autogen, elixir-format
msgid ""
"Set channels to join automatically every time you connect.\n"
"Subcommands: list, add <#channel> [key], remove <#channel>, clear. No args opens the Perform dialog.\n"
"Channel names must start with #. Registered users only."
msgstr ""
"Establecer canales para unirse automáticamente cada vez que se conecta.\n"
"Subcomandos: lista, añadir <#channel> [key], eliminar <#channel>, claro. Ningún args abre el diálogo Perform.\n"
"Los nombres de los canales deben empezar con #. Sólo usuarios registrados."

#: lib/retro_hex_chat/commands/handlers/slow.ex:47
#, elixir-autogen, elixir-format
msgid ""
