msgstr "Eliminar el estado de voz de un usuario."

#: lib/retro_hex_chat/commands/handlers/devoice.ex:29
#, elixir-autogen, elixir-format
msgid ""
"Remove voice status from a user. Shortcut for /mode -v <nickname>.\n"
"Requires: half-operator, operator, or owner."
msgstr ""
"Eliminar el estado de voz de un usuario. Atajo para /mode -v <nickname>.\n"
