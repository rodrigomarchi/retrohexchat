#: lib/retro_hex_chat/commands/handlers/mode.ex:37
#: lib/retro_hex_chat/commands/handlers/mode.ex:99
#, elixir-autogen, elixir-format
msgid ""
"Change channel settings and user privileges using mode flags.\n"
"Flags: +o (operator), +v (voice), +b (ban), +h (half-op), +m (moderated), +i (invite-only), +t (topic protected), +k (key/password), +l (user limit), +n (no external messages), +j (join throttle), +K (no knock).\n"
"Requires: channel operator. Half-operators can only set +v/-v. Must be in a channel."
msgstr ""
"Kanaalinstellingen en gebruikersrechten wijzigen met behulp van modusvlaggen.\n"
"Vlaggen: +o (operator), +v (voice), +b (ban), +h (half-op), +m (gematigd), +i (invite-only), +t (topic protected), +k (key/password), +l (user limit), +n (geen externe berichten), +j (join thrattle), +K (no klop).\n"
"Vereist: kanaaloperator. Halfoperators kunnen alleen +v/-v instellen. Moet in een kanaal zitten."

