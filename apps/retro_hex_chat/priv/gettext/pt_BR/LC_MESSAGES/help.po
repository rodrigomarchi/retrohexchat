#, elixir-autogen, elixir-format
msgid "1 long epic round — igloo needs 20 pieces, all enemies from the start, "
msgstr "1 longa rodada épica — iglu precisa de 20 peças, todos os inimigos desde o início, "

#: lib/retro_hex_chat/chat/help_topics/features.ex:1355
#, elixir-autogen, elixir-format
msgid "10 sections of increasing difficulty. Destroy bridges to advance. "
msgstr "10 secções de dificuldade crescente. Destruir pontes para avançar. "

#: lib/retro_hex_chat/chat/help_topics/features.ex:1176
#, elixir-autogen, elixir-format
