#: lib/retro_hex_chat/commands/handlers/autojoin.ex:115
#, elixir-autogen, elixir-format
msgid "Set channels to join automatically every time you connect."
msgstr ""
"Defina os canais para entrar automaticamente cada vez que você conectar."

#: lib/retro_hex_chat/commands/handlers/autojoin.ex:80
#, elixir-autogen, elixir-format
msgid ""
"Set channels to join automatically every time you connect.\n"
"Subcommands: list, add <#channel> [key], remove <#channel>, clear. No args opens the Perform dialog.\n"
"Channel names must start with #. Registered users only."
msgstr ""
"Defina os canais para entrar automaticamente cada vez que você conectar.\n"
"Subcomandos: lista, adicionar <#channel> [chave], remover <#channel>, limpar. Nenhum args abre o diálogo Executar.\n"
"Os nomes dos canais devem começar com #. Apenas usuários registrados."

#: lib/retro_hex_chat/commands/handlers/slow.ex:42
#, elixir-autogen, elixir-format
msgid ""
"Set join throttle on the channel (5 joins per N seconds). Use /slow 0 to disable.\n"
"Requires: channel operator or owner."
msgstr ""
"Ajuste o acelerador de junção no canal (5 juntas por N segundos). Usar o /slow 0 to disable.\n"
"Requires: channel operator or owner."

#: lib/retro_hex_chat/commands/handlers/slow.ex:61
#, elixir-autogen, elixir-format
msgid "Set join throttle. 0 to disable."
msgstr "Preparem o acelerador. 0 para desativar."

#: lib/retro_hex_chat/chat/help_topics/commands.ex:62
#, elixir-autogen, elixir-format
msgid ""
"Set or clear your away status to let others know you are not available."
msgstr ""
"Definir ou limpar o seu status de distância para deixar outros saber que "
"você não está disponível."

#: lib/retro_hex_chat/chat/help_topics/special_messages.ex:24
#, elixir-autogen, elixir-format
msgid ""
"Set or update the server's Message of the Day. Requires admin privileges."
msgstr ""
"Definir ou atualizar a Mensagem do Dia do Servidor. Requer privilégios de "
"administração."

#: lib/retro_hex_chat/chat/help_topics/commands.ex:79
