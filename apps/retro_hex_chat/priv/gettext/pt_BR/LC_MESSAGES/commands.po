#: lib/retro_hex_chat/commands/handlers/timer.ex:63
#, elixir-autogen, elixir-format
msgid "Schedule a command to run after a delay or on a repeating interval.\n"
"Create: /timer <name> <seconds> <command>. Repeat: /timer <name> repeat <seconds> <command>.\n"
"Timers run in the window that was active when they were created and do not switch your current window when they fire.\n"
"Manage: /timer list, /timer stop <name>.\n"
"Max 5 timers. One-shot: 1-86400s. Repeat minimum: 10s. Session-only (lost on disconnect)."
msgstr "Agende um comando para executar após um atraso ou em um intervalo repetido.\n"
"Criar: /timer <name> <seconds> <command>. Repetir: /timer <name> repeat <seconds> <command>.\n"
"Os timers são executados na janela que estava ativa quando foram criados e não mudam sua janela atual quando disparam.\n"
"Gerir: /timer list, /timer stop <name>.\n"
"Max 5 timers. Um tiro: 1-86400s. Repetir o mínimo: 10s. Apenas sessão (perdido ao desconectar)."

#: lib/retro_hex_chat/commands/handlers/timer.ex:89
#, elixir-autogen, elixir-format
msgid "Schedule a command to run after a delay or on a repeating interval. The command runs in the window that was active when the timer was created."
msgstr "Agende um comando para executar após um atraso ou em um intervalo repetido. O comando é executado na janela que estava ativa quando o timer foi criado."

#: lib/retro_hex_chat/commands/handlers/invite.ex:44
#: lib/retro_hex_chat/commands/handlers/invite.ex:75
#, elixir-autogen, elixir-format
msgid "Send a channel invitation to another user. Required for invite-only (+i) channels.\n"
"Defaults to current channel if no #channel specified. Must be in a channel when no channel arg given.\n"
"/invite auto — toggles whether you automatically join channels when invited."
msgstr "Envie um convite de canal para outro usuário. Necessário para canais apenas para convidados (+i).\n"
"O padrão é o canal atual se não for especificado o #channel. Deve estar num canal quando não for indicado nenhum arg de canal.\n"
"/invite auto — comuta se você entra automaticamente em canais quando convidado."

#: lib/retro_hex_chat/commands/handlers/send_file.ex:55
#, elixir-autogen, elixir-format
msgid "Send a file to another user through a direct peer-to-peer connection.\n"
"Requires: both users must be registered and identified (/ns identify)."
msgstr "Envie um arquivo para outro usuário através de uma conexão direta peer-to-peer.\n"
"Requer: ambos os usuários devem ser registrados e identificados (/ns identify)."

#: lib/retro_hex_chat/commands/handlers/send_file.ex:34
#, elixir-autogen, elixir-format
msgid "Send a file to another user through a direct peer-to-peer connection.\n"
"Requires: both you and the target must be registered and identified (/ns identify).\n"
"You cannot send files to yourself. Creates a P2P session — the peer must accept."
msgstr "Envie um arquivo para outro usuário através de uma conexão direta peer-to-peer.\n"
"Requer: você e o alvo devem ser registrados e identificados (/ns identify).\n"
"Você não pode enviar arquivos para si mesmo. Cria uma sessão P2P — o par deve aceitar."

