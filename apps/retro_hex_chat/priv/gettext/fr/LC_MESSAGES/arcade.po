#: lib/retro_hex_chat/arcade/content/wolfenstein_3d.ex:50
#, elixir-autogen, elixir-format
msgid "Treasure counts toward your score — try for 100% on each level for maximum points."
msgstr "Le trésor compte pour votre score — essayez de 100% sur chaque niveau pour des points maximums."

#: lib/retro_hex_chat/arcade/content/scummvm_drascula.ex:31
#, elixir-autogen, elixir-format
msgid "Try everything with everything — the game's puzzle logic follows cartoon comedy rules."
msgstr "Essayez tout avec tout — la logique du jeu de puzzle suit les règles de la comédie de dessin animé."

#: lib/retro_hex_chat/arcade/content/wolfenstein_3d.ex:25
#, elixir-autogen, elixir-format
msgid "Turn left / right"
msgstr "Tournez à gauche / à droite"

