msgstr "Chọn và chuyển đổi giữa microphone, máy ảnh và loa trong cuộc gọi."

#: lib/retro_hex_chat/chat/help_topics/special_messages.ex:69
#, elixir-autogen, elixir-format
msgid "Send a broadcast message to all users who have wallops mode enabled."
msgstr ""
"Gửi một thông điệp phát thanh cho mọi người dùng có chế độ Bức tường bật."

#: lib/retro_hex_chat/chat/help_topics/commands.ex:367
#, elixir-autogen, elixir-format
msgid "Send a file to another user through a peer-to-peer connection."
msgstr "Gửi tập tin tới người dùng khác qua kết nối ngang hàng."

#: lib/retro_hex_chat/chat/help_topics/special_messages.ex:78
#, elixir-autogen, elixir-format
msgid ""
"Send a global announcement to all connected users. Requires admin "
"privileges."
msgstr ""
"Gửi thông báo toàn cục cho tất cả người dùng đã kết nối. Cần có quyền quản "
"trị."

#: lib/retro_hex_chat/chat/help_topics/commands.ex:253
#, elixir-autogen, elixir-format
msgid ""
"Send a notice message to a user or channel. Notices do not open query "
"windows."
msgstr ""
"Gửi thông điệp cho người dùng hay kênh. Thông báo không mở cửa sổ truy vấn."

#: lib/retro_hex_chat/chat/help_topics/commands.ex:233
#, elixir-autogen, elixir-format
msgid ""
"Send a private message to another user without opening a conversation tab."
msgstr "Gửi thông điệp riêng cho người dùng khác mà không mở thẻ đối thoại."

#: lib/retro_hex_chat/chat/help_topics/commands.ex:211
#, elixir-autogen, elixir-format
msgid "Send an action message that describes what you are doing."
msgstr "Gửi một thông điệp hành động miêu tả những gì bạn đang làm."

#: lib/retro_hex_chat/chat/help_topics/getting_started.ex:64
#, elixir-autogen, elixir-format
msgid ""
"Send and receive private messages with other users using the /msg and /query"
