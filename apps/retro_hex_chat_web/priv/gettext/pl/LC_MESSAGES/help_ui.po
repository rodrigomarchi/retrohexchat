#: lib/retro_hex_chat_web/controllers/help_content/keyboard_shortcuts.html.heex:10
#, elixir-autogen, elixir-format
msgid ""
"Enter — Send message / select autocomplete item Shift+Enter — Insert newline"
" in input Up — Edit last message (when input is empty) / command history Up "
"/ Down — Command history / navigate autocomplete dropdown Ctrl+Up — Browse "
"history (saves draft) Ctrl+Down — Browse history forward (restores draft) "
"Ctrl+R — Reverse search history Tab — Select autocomplete item / cycle nick "
"completion Escape — Cancel edit mode / dismiss autocomplete / tooltip / — "
"Open command autocomplete (at start of input) @ — Open nick autocomplete (at"
" word boundary) # — Open channel autocomplete (at word boundary)"
msgstr ""
"Wpisz - Wyślij wiadomość / wybierz autokompletną pozycję Shift + Enter - "
"Wstaw nową linię we wejściu W górę - Edytuj ostatnią wiadomość (gdy wejście "
"jest puste) / historia poleceń W górę / w dół - Historia poleceń / nawigacja"
" autocomplete dropdown Ctrl + Up - Przeglądaj historię (zapisuje szkic) Ctrl"
" + w dół - Przeglądaj historię do przodu (przywraca szkic) Ctrl + R - "
"Odwrócenie historii wyszukiwania Tab - Wybierz autocomplete element / cykl "
"nick completion Escape - Anuluj tryb edycji / zwolnij autocomplete / tooltip"
" / - Otwórz polecenie autocomplete (na początku wejścia) @ - Otwórz nick "
"autocomplete (na granicy słowa) # - Otwórz kanał autocomplete (na granicy "
"słowa)"

