#: lib/retro_hex_chat_web/controllers/help_content/ui_context_menu.html.heex:1
#, elixir-autogen, elixir-format
msgid "Click a nickname in the user list to open the context menu."
msgstr "Kliknij nick na liście użytkowników, aby otworzyć menu kontekstowe."

#: lib/retro_hex_chat_web/controllers/help_content/ui_nicklist.html.heex:40
#, elixir-autogen, elixir-format
msgid ""
"Click a nickname to access Query, Whois, Kick, Ban, Mode, Add to Contacts, "
"and Set Nick Color options. Double-click to open a private message."
msgstr ""
"Kliknij nick, aby uzyskać dostęp do Query, Whois, Kick, Zakaz, Tryb, Dodaj "
"do kontaktów i Ustaw Nick kolor opcji. Kliknij dwukrotnie, aby otworzyć "
"prywatną wiadomość."

#: lib/retro_hex_chat_web/controllers/help_content/ui_tab_bar.html.heex:9
#, elixir-autogen, elixir-format
msgid ""
"Click a tab to switch. The active tab is highlighted. Tabs show close "
"buttons (×) for channels and PMs. Unread tabs appear bold, and highlighted "
"tabs flash."
msgstr ""
"Kliknij kartę, aby zmienić. Podświetlona jest aktywna karta. Table pokazują "
"przyciski zamykane (×) dla kanałów i PM. Nieprzeczytane karty pojawiają się "
"pogrubione, a podświetlone karty flash."

#: lib/retro_hex_chat_web/controllers/help_content/ui_conversations.html.heex:63
#, elixir-autogen, elixir-format
msgid ""
"Click a username to open the context menu. Double-click to open a private "
"message. Right-click a channel for options (Mark as Read, Mute, Copy Name, "
"Leave, Settings)."
msgstr ""
"Kliknij nazwę użytkownika, aby otworzyć menu kontekstowe. Kliknij "
"dwukrotnie, aby otworzyć prywatną wiadomość. Kliknij prawym przyciskiem "
"myszy kanał dla opcji (Zaznacz jako Read, Mute, Kopiuj nazwę, Leave, "
"Ustawienia)."

