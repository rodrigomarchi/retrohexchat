msgid "The placeholder text changes based on your current context:"
msgstr "Tekst posiadacza miejsca zmienia się na podstawie bieżącego kontekstu:"

#: lib/retro_hex_chat_web/controllers/help_content/feature_nick_expiry.html.heex:50
#, elixir-autogen, elixir-format
msgid "The purge runs automatically every 6 hours"
msgstr "Oczyszczanie działa automatycznie co 6 godzin"

#: lib/retro_hex_chat_web/controllers/help_content/feature_nick_expiry.html.heex:28
#, elixir-autogen, elixir-format
msgid "The registration is permanently deleted"
msgstr "Rejestracja jest trwale usuwana"

#: lib/retro_hex_chat_web/controllers/help_content/feature_search.html.heex:54
#, elixir-autogen, elixir-format
msgid "The search bar remembers your last search term. When you reopen it, the previous query is restored and matches are re-highlighted."
msgstr "Pasek wyszukiwania pamięta twój ostatni termin wyszukiwania. Po ponownym otwarciu, poprzednie zapytanie zostaje przywrócone, a dopasowania są ponownie zaznaczone."

#: lib/retro_hex_chat_web/controllers/help_content/feature_status_bar.html.heex:2
#, elixir-autogen, elixir-format
msgid "The status bar at the bottom of the screen provides real-time information about your connection and current channel."
msgstr "Pasek stanu na dole ekranu zawiera informacje na temat Twojego połączenia i aktualnego kanału."

#: lib/retro_hex_chat_web/controllers/help_content/feature_connection_states.html.heex:2
#, elixir-autogen, elixir-format
