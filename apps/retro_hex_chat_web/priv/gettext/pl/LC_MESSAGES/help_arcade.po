#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_doom.html.heex:106
#, elixir-autogen, elixir-format
msgid ""
"— The shotgun is your workhorse weapon. Use the pistol for weak enemies to "
"conserve shells."
msgstr ""
"- Strzelba to twoja broń. Użyj pistoletu dla słabych wrogów do ochrony "
"muszli."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_soltys.html.heex:70
#, elixir-autogen, elixir-format
msgid "— The streamlined point-and-click interface keeps things accessible."
msgstr "- Uproszczony interfejs point-and-click utrzymuje wszystko dostępne."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_dreamweb.html.heex:67
#, elixir-autogen, elixir-format
msgid ""
"— The top-down perspective makes small items harder to spot. Click "
"everywhere."
msgstr ""
"- Perspektywa top- down sprawia, że małe przedmioty trudniej dostrzec. "
"Kliknij wszędzie."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_hacx.html.heex:83
#, elixir-autogen, elixir-format
msgid "— The v1.2 release runs standalone — no DOOM II required."
msgstr "- Wydanie v1.2 działa samodzielnie - DOOM II nie jest wymagane."

