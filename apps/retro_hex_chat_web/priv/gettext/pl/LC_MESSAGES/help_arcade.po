#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_soltys.html.heex:56
#, elixir-autogen, elixir-format
msgid "— Small hotspots are easy to miss. Methodically explore each screen."
msgstr "- Małe hotspoty łatwo przeoczyć. Metodycznie zbadać każdy ekran."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_bass.html.heex:92
#, elixir-autogen, elixir-format
msgid "— Some puzzle sequences are complex and easy to get stuck in."
msgstr "- Niektóre sekwencje puzzle są skomplikowane i łatwe do utknięcia w."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_lure.html.heex:74
#, elixir-autogen, elixir-format
msgid "— Some puzzles depend on NPC positions. Save often and be patient."
msgstr ""
"- Niektóre zagadki zależą od pozycji NPC. Oszczędzaj często i bądź "
"cierpliwy."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_fotaq.html.heex:74
#, elixir-autogen, elixir-format
msgid "— Some puzzles have more than one solution. Experiment freely."
msgstr ""
"- Niektóre zagadki mają więcej niż jedno rozwiązanie. Eksperymentuj "
"swobodnie."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_chex_quest.html.heex:32
