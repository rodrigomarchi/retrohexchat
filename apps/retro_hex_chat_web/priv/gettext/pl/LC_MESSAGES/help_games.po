#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost.html.heex:104
#, elixir-autogen, elixir-format
msgid "— 1 epic round, 20-piece igloo, all enemies from the start"
msgstr "- 1 epicka runda, 20-częściowy igloo, wszyscy wrogowie od początku"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey.html.heex:111
#, elixir-autogen, elixir-format
msgid "— 1 period of 3 minutes, faster puck, 80% tackle success"
msgstr "- 1 okres 3 minut, szybszy krążek, 80% pokonać sukces"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_blitz.html.heex:38
#, elixir-autogen, elixir-format
msgid "— 25% speed increase on all shots"
msgstr "- 25% wzrost prędkości na wszystkich ujęciach"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro.html.heex:73
#, elixir-autogen, elixir-format
msgid "— 3-minute race in permanent darkness with fog bursts"
msgstr "- 3-minutowy wyścig w stałej ciemności z wybuchem mgły"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid.html.heex:65
#, elixir-autogen, elixir-format
msgid "— 5 sections, narrow river, faster mine recharge"
msgstr "- 5 sekcji, wąska rzeka, szybsze ładowanie kopalni"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_showdown.html.heex:44
#, elixir-autogen, elixir-format
msgid "— 60% success rate (same as Classic)"
msgstr "- 60% wskaźnik sukcesu (taki sam jak Classic)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro.html.heex:79
#, elixir-autogen, elixir-format
msgid "— 90-second daylight sprint, no weather, no fuel drain"
msgstr "- 90- sekundowy sprint, bez pogody, bez odprowadzania paliwa"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw.html.heex:63
#, elixir-autogen, elixir-format
msgid "— A moving stagecoach blocks shots with unpredictable timing"
msgstr "- Poruszający się dyliżans blokuje ujęcia z nieprzewidywalnym czasem"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing_escape.html.heex:57
#, elixir-autogen, elixir-format
msgid "— A stun at high speeds means the avalanche catches up instantly. One collision can end your run."
msgstr "- Ostudzenie przy dużych prędkościach oznacza, że lawina łapie natychmiast. Jedno zderzenie może zakończyć bieg."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_night.html.heex:55
#, elixir-autogen, elixir-format
msgid "— AI cars appear as colored dots at the edge of your vision. React to dot colors to predict their lane."
msgstr "Samochody AI pojawiają się jako kolorowe kropki na krawędzi wizji. Reakcja na kropki kolorów, aby przewidzieć ich pas."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro.html.heex:23
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_night.html.heex:23
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_sprint.html.heex:23
