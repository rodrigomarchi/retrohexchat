msgstr "ग्रेविटी वेल"

#: lib/retro_hex_chat_web/controllers/help_content/feature_gravity_well.html.heex:44
#, elixir-autogen, elixir-format
msgid ""
"Gravity curves missile trajectories — use the star to bend shots around "
