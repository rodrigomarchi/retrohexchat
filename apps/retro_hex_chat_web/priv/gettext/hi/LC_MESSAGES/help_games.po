msgstr "प्रत्येक सेल आप पार स्थायी रूप से अपने निशान का हिस्सा बन जाता है"

#: lib/retro_hex_chat_web/controllers/help_content/feature_light_trails.html.heex:45
#, elixir-autogen, elixir-format
msgid "First to 3 round wins takes the match"
msgstr "पहले से 3 राउंड जीत मैच लेता है"

#: lib/retro_hex_chat_web/controllers/help_content/feature_star_duel.html.heex:70
#, elixir-autogen, elixir-format
