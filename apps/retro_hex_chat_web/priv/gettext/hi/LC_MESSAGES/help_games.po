msgstr "गेम चयन की आवश्यकता है"

#: lib/retro_hex_chat_web/controllers/help_content/feature_debris_field.html.heex:98
#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_games.html.heex:59
#: lib/retro_hex_chat_web/controllers/help_content/feature_star_duel.html.heex:75
#: lib/retro_hex_chat_web/controllers/help_content/feature_star_duel.html.heex:89
