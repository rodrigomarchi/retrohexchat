msgid "Requires half-operator (%) status or higher"
msgstr "आधे ऑपरेटर की आवश्यकता (%) स्थिति या उच्चतर"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_slow.html.heex:34
#, elixir-autogen, elixir-format
msgid "Requires operator (@) or owner (~) status"
msgstr "ऑपरेटर की आवश्यकता (@) या मालिक (~) स्थिति"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_deop.html.heex:18
#: lib/retro_hex_chat_web/controllers/help_content/cmd_op.html.heex:18
#, elixir-autogen, elixir-format
msgid "Requires operator (@) or owner (~) status in the channel"
msgstr "चैनल में ऑपरेटर (@) या मालिक (~) स्थिति की आवश्यकता है"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_admin.html.heex:52
#, elixir-autogen, elixir-format
msgid "Requires server administrator or server operator role"
msgstr "सर्वर व्यवस्थापक या सर्वर ऑपरेटर भूमिका की आवश्यकता है"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_admin.html.heex:55
#, elixir-autogen, elixir-format
msgid "Root admins (configured via environment) cannot be demoted"
msgstr ""
"रूट व्यवस्थापक (पर्यावरण के माध्यम से कॉन्फ़िगर) को ध्वस्त नहीं किया जा सकता"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_admin_user.html.heex:56
#, elixir-autogen, elixir-format
msgid "Root admins cannot be demoted via commands"
msgstr "रूट व्यवस्थापक को कमांड के माध्यम से ध्वस्त नहीं किया जा सकता है"

