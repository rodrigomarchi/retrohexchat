#: lib/retro_hex_chat_web/controllers/help_content/feature_contextual_tips.html.heex:14
#, elixir-autogen, elixir-format
msgid "\"Channels you join appear in the left panel\""
msgstr "\"आप में शामिल होने वाले चैनल बाएं पैनल में दिखाई देते हैं\""

#: lib/retro_hex_chat_web/controllers/help_content/feature_contextual_tips.html.heex:18
#, elixir-autogen, elixir-format
msgid "\"PMs appear as separate windows in the conversations sidebar\""
msgstr "\"पीएम बातचीत साइडबार में अलग-अलग खिड़कियों के रूप में दिखाई देते हैं\""

#: lib/retro_hex_chat_web/controllers/help_content/feature_contextual_tips.html.heex:26
#, elixir-autogen, elixir-format
msgid "\"Type /help to see all commands\""
msgstr "टाइप /help सभी कमांड देखने के लिए"

#: lib/retro_hex_chat_web/controllers/help_content/feature_contextual_tips.html.heex:10
#, elixir-autogen, elixir-format
msgid "\"Use ↑ to edit your last message\""
msgstr "\"अपने अंतिम संदेश को संपादित करने के लिए उपयोग करें\""

#: lib/retro_hex_chat_web/controllers/help_content/feature_contextual_tips.html.heex:22
#, elixir-autogen, elixir-format
msgid "\"Your nick was mentioned! Configure alerts in Settings\""
msgstr "\"Your nick का उल्लेख किया गया था! सेटिंग्स में अलर्ट कॉन्फ़िगर करें\""

#: lib/retro_hex_chat_web/controllers/help_content/feature_admin_console.html.heex:27
#, elixir-autogen, elixir-format
msgid "# Configure main channels /chanserv register #general /chanserv set #general guard on /chanserv set #general topiclock on # Create a bot /bot create HelperBot"
msgstr "# मुख्य चैनल को कॉन्फ़िगर करें /chanserv रजिस्टर #general /chanserv सेट #general गार्ड पर /chanserv सेट #general विषय पर क्लिक करें /bot HelperBot"

