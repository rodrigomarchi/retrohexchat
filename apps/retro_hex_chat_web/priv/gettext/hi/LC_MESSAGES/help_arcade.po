#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_quake.html.heex:94
#, elixir-autogen, elixir-format
msgid ""
"QuakeWorld (1996) was the first game to implement client-side prediction for"
" smoother online play over dial-up connections."
msgstr ""
"क्वाकवर्ल्ड (1996) डायल-अप कनेक्शन पर ऑनलाइन खेलने के लिए क्लाइंट-साइड "
"भविष्यवाणी को लागू करने वाला पहला गेम था।"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_doom_shareware.html.heex:66
#, elixir-autogen, elixir-format
msgid "Quicksave often"
msgstr "Quicksave अक्सर"

