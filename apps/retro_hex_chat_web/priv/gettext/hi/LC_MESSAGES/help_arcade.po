msgstr "- उपयोग / बातचीत"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_chex_quest.html.heex:43
#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_doom_shareware.html.heex:43
#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_freedm.html.heex:43
#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_freedoom1.html.heex:43
#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_freedoom2.html.heex:43
#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_hacx.html.heex:43
#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_rekkr.html.heex:43
