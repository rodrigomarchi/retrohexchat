msgstr "Orbit, jangan melawan"

#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_games.html.heex:2
#, elixir-autogen, elixir-format
msgid "P2P Games lets you play retro arcade games directly with another user. Games run in real-time over WebRTC DataChannel — no server relay, minimal latency. 15 base games with 20 additional mode variants across action, sports, racing, and co-op genres."
msgstr "P2P Games memungkinkan Anda bermain game arcade retro langsung dengan pengguna lain. Permainan dijalankan secara real-time melalui WebRTC DagaChannel - tidak ada relay server, minimal latensi. 15 game basa dengan 20 mode variasi tambahan di seluruh tindakan, olahraga, balap, dan co-op genres."

#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_games.html.heex:244
#, elixir-autogen, elixir-format
msgid "P2P Sessions"
msgstr "Sesi P2P"

#: lib/retro_hex_chat_web/controllers/help_content/feature_block_breakers.html.heex:38
#, elixir-autogen, elixir-format
msgid "Paddle hit angle affects ball direction — edges create steeper bounces (up to 60 degrees)"
msgstr "Sudut memukul kayuh mempengaruhi arah bola - tepi membuat bounce steeper (hingga 60 derajat)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_games.html.heex:236
#, elixir-autogen, elixir-format
msgid "Pending sessions expire in 5 minutes. The lobby expires after 15 minutes of inactivity (with a warning at 10 minutes)."
msgstr "Sesi tertunda berakhir dalam 5 menit. Lobby berakhir setelah 15 menit ketidakaktifan (dengan peringatan di 10 menit)."

#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_games.html.heex:50
#, elixir-autogen, elixir-format
