msgid "and select the file."
msgstr "dan memilih berkas."

#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_sessions.html.heex:38
#, elixir-autogen, elixir-format
msgid "bilateral consent"
msgstr "persetujuan bilateral"

#: lib/retro_hex_chat_web/controllers/help_content/feature_audio_call.html.heex:14
#, elixir-autogen, elixir-format
msgid "button to mute your microphone. The other user will see an indication that you are muted."
msgstr "Tombol untuk mematikan mikrofon Anda. Pengguna lain akan melihat indikasi bahwa Anda bermutasi."

#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_sessions.html.heex:78
#, elixir-autogen, elixir-format
msgid "or close the tab. The other user will be notified."
msgstr "atau menutup tab. Pengguna lain akan diberitahu."

#: lib/retro_hex_chat_web/controllers/help_content/feature_audio_call.html.heex:22
#, elixir-autogen, elixir-format
msgid "to finish. Both users return to the lobby."
msgstr "untuk menyelesaikan. Kedua pengguna kembali ke lobi."

#: lib/retro_hex_chat_web/controllers/help_content/feature_video_call.html.heex:24
#, elixir-autogen, elixir-format
msgid "to pause the video. The peer will see a placeholder."
msgstr "untuk jeda video. Peer akan melihat placeholder."

#: lib/retro_hex_chat_web/controllers/help_content/feature_video_call.html.heex:32
#, elixir-autogen, elixir-format
msgid "to pop the remote video into a floating window that stays visible while navigating other tabs."
msgstr "untuk pop video remote ke jendela mengambang yang tetap terlihat ketika menavigasi tab lain."

#: lib/retro_hex_chat_web/controllers/help_content/feature_media_devices.html.heex:5
#, elixir-autogen, elixir-format
msgid "to see available devices. Choose a microphone, camera, or audio output from the menus."
msgstr "untuk melihat perangkat yang tersedia. Pilih mikrofon, kamera, atau keluaran audio dari menu."

#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_sessions.html.heex:56
