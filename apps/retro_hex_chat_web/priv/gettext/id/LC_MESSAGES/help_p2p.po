#: lib/retro_hex_chat_web/controllers/help_content/feature_file_transfer.html.heex:18
#, elixir-autogen, elixir-format
msgid "When you receive an offer, you see the file name and size. Click"
msgstr "Ketika Anda menerima tawaran, Anda melihat nama berkas dan ukuran. Klik"

#: lib/retro_hex_chat_web/controllers/help_content/feature_file_transfer.html.heex:11
