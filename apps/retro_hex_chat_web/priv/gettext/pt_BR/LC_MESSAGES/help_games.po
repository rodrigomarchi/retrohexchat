msgid "— At 0.5°/second, you have about 2 minutes. Don't panic but don't dawdle either."
msgstr "— A 0,5°/second, você tem cerca de 2 minutos. Não entres em pânico, mas não demores."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_blitz.html.heex:58
#, elixir-autogen, elixir-format
msgid "— At combo 4+, armored drops appear. These take 2 hits and can clog your opponent's screen."
msgstr "— Na combinação 4+, aparecem gotas blindadas. Estes levam 2 hits e podem entupir a tela do seu oponente."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost.html.heex:92
#, elixir-autogen, elixir-format
msgid "— Bonus collectible between rows (200 points)"
msgstr "— Bónus colecionável entre linhas (200 pontos)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro.html.heex:29
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_night.html.heex:29
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_sprint.html.heex:29
#, elixir-autogen, elixir-format
msgid "— Brake"
msgstr "— Travão"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_pacifist.html.heex:41
#, elixir-autogen, elixir-format
msgid "— Bridges give the highest point rewards. Never miss a bridge kill."
msgstr "— As pontes dão as mais altas recompensas. Nunca percas a morte de uma ponte."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_ricochet.html.heex:51
#, elixir-autogen, elixir-format
msgid "— Bullets always bounce at matching angles. Position yourself so the ricochet lands where your opponent tends to stand."
msgstr "— As balas saltam sempre nos ângulos correspondentes. Posicione-se para que o ricochete caia onde seu oponente tende a ficar."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw.html.heex:54
#, elixir-autogen, elixir-format
msgid "— Bullets fire at 30-degree angles and bounce once off ceiling/floor"
msgstr "— Balas disparam em ângulos de 30 graus e batem uma vez no tecto/plano"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_warlords.html.heex:19
#, elixir-autogen, elixir-format
msgid "— Catch fireball on shield contact"
msgstr "— Apanhar bola de fogo em contacto com o escudo"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_night.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_sprint.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Change lane left"
msgstr "— Mudar de faixa à esquerda"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro.html.heex:17
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_night.html.heex:17
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_sprint.html.heex:17
#, elixir-autogen, elixir-format
msgid "— Change lane right"
msgstr "— Mudar de faixa à direita"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis.html.heex:64
#, elixir-autogen, elixir-format
msgid "— Classic: full set with tiebreak at 6-6"
msgstr "— Clássico: conjunto completo com tiebreak em 6-6"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_coop.html.heex:54
#, elixir-autogen, elixir-format
msgid "— Clearing aliens from the sides slows horizontal movement for the entire wave."
msgstr "— A remoção dos estrangeiros dos lados retarda o movimento horizontal para toda a onda."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing_clean.html.heex:45
#, elixir-autogen, elixir-format
msgid "— Courses repeat. In best-of-3, the third round favors the player who learned the layout."
msgstr "— Cursos repetidos. No melhor de 3, a terceira rodada favorece o jogador que aprendeu o layout."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid.html.heex:20
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_blitz.html.heex:20
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_pacifist.html.heex:20
#, elixir-autogen, elixir-format
msgid "— Decelerate"
msgstr "— Acelerar"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_blitz.html.heex:57
#, elixir-autogen, elixir-format
msgid "— Decelerate in narrow sections. One wrong move at high speed means instant death on the banks."
msgstr "— Acelerar em secções estreitas. Um movimento errado em alta velocidade significa morte instantânea nas margens."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing.html.heex:66
#, elixir-autogen, elixir-format
msgid "— Dense ice patches, fast avalanche, narrow gates"
msgstr "— Manchas de gelo densas, avalanche rápida, portões estreitos"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_sprint.html.heex:72
#, elixir-autogen, elixir-format
msgid "— Don't waste time recovering from crashes. Stay focused from second one."
msgstr "- Não perca tempo a recuperar de acidentes. Concentra-te na segunda."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid.html.heex:29
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_blitz.html.heex:29
#, elixir-autogen, elixir-format
msgid "— Drop mine"
msgstr "— Largar a mina"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing_clean.html.heex:31
#, elixir-autogen, elixir-format
msgid "— Each gate saves 2 seconds. Over a full run, gates make the difference between winning and losing."
msgstr "— Cada portão economiza 2 segundos. Ao longo de uma corrida completa, portões fazem a diferença entre ganhar e perder."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_coop.html.heex:47
#, elixir-autogen, elixir-format
msgid "— Each player takes a side. Overlapping coverage wastes shots and leaves gaps."
msgstr "— Cada jogador toma um lado. Sobreposição cobertura desperdiça tiros e deixa lacunas."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis.html.heex:76
#, elixir-autogen, elixir-format
msgid "— Each point wins a game, first to 6"
msgstr "— Cada ponto ganha um jogo, primeiro a 6"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_coop.html.heex:68
#, elixir-autogen, elixir-format
msgid "— Earlier waves are easier. Play conservatively to have lives for waves 8-10."
msgstr "— As ondas anteriores são mais fáceis. Jogue conservadoramente para ter vidas para as ondas 8-10."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_peaceful.html.heex:62
#, elixir-autogen, elixir-format
msgid "— Enemies still escalate. In later rounds, focus on survival over speed."
msgstr "- Os inimigos ainda aumentam. Nas rondas posteriores, concentre-se na sobrevivência sobre a velocidade."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_peaceful.html.heex:48
#, elixir-autogen, elixir-format
msgid "— Even though stealing is off, being on the same row as your opponent means fewer blocks for you."
msgstr "— Mesmo que o roubo esteja desconectado, estar na mesma fileira que seu oponente significa menos blocos para você."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis_quick.html.heex:53
#, elixir-autogen, elixir-format
msgid "— Even when behind in a game, fighting to deuce gives you a chance. Never give up a game easily."
msgstr "— Mesmo quando para trás em um jogo, lutar para dar-lhe uma chance. Nunca desistas de um jogo facilmente."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis_sudden.html.heex:40
#, elixir-autogen, elixir-format
msgid "— Every single rally decides a game. Stay focused for every point."
msgstr "— Cada rali decide um jogo. Concentra-te para cada ponto."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_showdown.html.heex:76
#, elixir-autogen, elixir-format
msgid "— Fast pucks that hit the corners of the goal are nearly impossible to save."
msgstr "— Os discos rápidos que atingem os cantos do gol são quase impossíveis de salvar."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw.html.heex:17
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_nml.html.heex:15
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_ricochet.html.heex:19
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_stagecoach.html.heex:17
#, elixir-autogen, elixir-format
msgid "— Fire (one bullet at a time)"
msgstr "— Fogo (uma bala de cada vez)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_debris_field.html.heex:29
#: lib/retro_hex_chat_web/controllers/help_content/feature_gravity_well.html.heex:29
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders.html.heex:23
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_blitz.html.heex:23
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_coop.html.heex:23
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid.html.heex:26
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_blitz.html.heex:26
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_pacifist.html.heex:26
#: lib/retro_hex_chat_web/controllers/help_content/feature_pixel_tanks.html.heex:20
#: lib/retro_hex_chat_web/controllers/help_content/feature_star_duel.html.heex:29
#, elixir-autogen, elixir-format
msgid "— Fire missile"
msgstr "— Mísseis de fogo"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis.html.heex:70
#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_games.html.heex:127
#, elixir-autogen, elixir-format
msgid "— First to 3 games wins"
msgstr "— Primeiro a 3 jogos ganha"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost.html.heex:80
#, elixir-autogen, elixir-format
msgid "— Fly between rows, danger during jumps (from round 3)"
msgstr "— Voar entre fileiras, perigo durante saltos (da carreira 3)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing_escape.html.heex:64
#, elixir-autogen, elixir-format
msgid "— Focus on the obstacles ahead, not the death wall behind you. Trust your speed and dodge forward."
msgstr "— Concentre - se nos obstáculos à frente, não no muro da morte atrás de você. Confia na tua velocidade e foge para a frente."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_night.html.heex:62
#, elixir-autogen, elixir-format
msgid "— Fog bursts reduce visibility to nearly zero. Slow down when fog hits and stay centered."
msgstr "— As explosões de nevoeiro reduzem a visibilidade para quase zero. Devagar quando o nevoeiro atingir e ficar centrado."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey.html.heex:50
#, elixir-autogen, elixir-format
msgid "— Free puck gradually slows down on the ice"
msgstr "— O disco livre diminui gradualmente no gelo"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro.html.heex:67
#, elixir-autogen, elixir-format
msgid "— Full Classic Duel: 3 days with weather cycle"
msgstr "— Duelo Clássico completo: 3 dias com ciclo meteorológico"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders.html.heex:62
#, elixir-autogen, elixir-format
msgid "— Full rules: alien drops, combos, 10 waves"
msgstr "— Regras completas: gotas, combos, 10 ondas"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid.html.heex:53
#, elixir-autogen, elixir-format
msgid "— Full rules: mines, fuel competition, 10 sections"
msgstr "— Regras completas: minas, concorrência de combustível, 10 secções"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_nml.html.heex:64
#, elixir-autogen, elixir-format
msgid "— Half-measures get you killed. Either push hard or stay back and react."
msgstr "- As meias medidas matam-te. Empurra forte ou afasta-te e reage."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_coop.html.heex:61
#, elixir-autogen, elixir-format
msgid "— If one cannon goes down, the other faces the full wave alone. Keep each other alive."
msgstr "— Se um canhão cair, o outro enfrenta a onda completa sozinho. Mantenham-se uns aos outros vivos."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey.html.heex:56
#, elixir-autogen, elixir-format
msgid "— If the puck stops for 5 seconds, a face-off is called"
msgstr "— Se o disco parar durante 5 segundos, chama-se \"face-off\""

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_blitz.html.heex:76
#, elixir-autogen, elixir-format
msgid "— If tied at the end, the next goal wins. Stay composed under pressure."
msgstr "— Se empatado no final, o próximo gol vence. Mantenham-se sob pressão."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_blitz.html.heex:65
#, elixir-autogen, elixir-format
msgid "— In Blitz, volume of kills matters more than perfect accuracy. Keep firing."
msgstr "— Em Blitz, o volume de mortes é mais do que a precisão perfeita. Continuem a disparar."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis_quick.html.heex:46
#, elixir-autogen, elixir-format
msgid "— In a short match, holding serve is critical. Aim for the corners on your service games."
msgstr "— Num combate curto, o serviço de retenção é crítico. Aponte para os cantos em seus jogos de serviço."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing.html.heex:39
#, elixir-autogen, elixir-format
msgid "— Infinite descent, ever-accelerating avalanche, last skier standing wins"
msgstr "— Descendente infinita, avalanche cada vez mais acelerada, último esquiador em pé ganha"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders.html.heex:74
#, elixir-autogen, elixir-format
msgid "— Instant drops, easier combos, 5 waves"
msgstr "— Gotas instantâneas, combinações mais fáceis, 5 ondas"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_blizzard.html.heex:17
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_peaceful.html.heex:17
#, elixir-autogen, elixir-format
msgid "— Jump to row above"
msgstr "— Saltar para a linha acima"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_blizzard.html.heex:23
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_peaceful.html.heex:23
#, elixir-autogen, elixir-format
msgid "— Jump to row below"
msgstr "— Saltar para a linha abaixo"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost.html.heex:17
#, elixir-autogen, elixir-format
msgid "— Jump to the row above (toward shore)"
msgstr "— Saltar para a linha acima (para a costa)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost.html.heex:23
#, elixir-autogen, elixir-format
msgid "— Jump to the row below (toward water)"
msgstr "— Saltar para a linha abaixo (para a água)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_night.html.heex:76
#, elixir-autogen, elixir-format
msgid "— Keep a mental tally. If you're ahead, play safe. If behind, take risks in the final minute."
msgstr "- Mantenha uma contagem mental. Se estiveres à frente, joga com cuidado. Se ficar para trás, corre riscos no último minuto."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_warlords.html.heex:25
#, elixir-autogen, elixir-format
msgid "— Launch fireball toward opponent"
msgstr "— Lançar bola de fogo para o oponente"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey.html.heex:38
#, elixir-autogen, elixir-format
msgid "— Launches puck at 2× your movement speed in your facing direction"
msgstr "— Lança o disco a 2× sua velocidade de movimento na direção de frente"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_stagecoach.html.heex:59
#, elixir-autogen, elixir-format
msgid "— Match your vertical position to stay in the gap the stagecoach leaves behind as it moves."
msgstr "— Coincidir com a sua posição vertical para ficar na lacuna que a diligência deixa para trás enquanto se move."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing.html.heex:60
#, elixir-autogen, elixir-format
msgid "— More rocks, faster avalanche, medium gates"
msgstr "— Mais rochas, avalanche mais rápida, portões médios"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_boxing.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Move boxer (8 directions)"
msgstr "— Mover boxeador (8 direcções)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_blitz.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_coop.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Move cannon left"
msgstr "— Mover o canhão para a esquerda"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders.html.heex:17
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_blitz.html.heex:17
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_coop.html.heex:17
#, elixir-autogen, elixir-format
msgid "— Move cannon right"
msgstr "— Mover o canhão para a direita"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_nml.html.heex:50
#, elixir-autogen, elixir-format
msgid "— Move forward to draw a shot, then dodge it while your opponent reloads."
msgstr "— Mova-se para a frente para desenhar um tiro, em seguida, esquive-se dele enquanto seu oponente recarrega."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Move gunslinger (vertical; horizontal in No Man's Land)"
msgstr "— Deslocar o pistoleiro (vertical; horizontal na terra de ninguém)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_stagecoach.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Move gunslinger vertically"
msgstr "— Mover o pistoleiro verticalmente"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_nml.html.heex:12
#, elixir-autogen, elixir-format
msgid "— Move gunslinger vertically and horizontally within your half"
msgstr "— Mova o pistoleiro vertical e horizontalmente na sua metade"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_blitz.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_showdown.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Move in 8 directions"
msgstr "— Circular em 8 direcções"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_blizzard.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_peaceful.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Move left/right"
msgstr "— Mover para a esquerda/direita"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Move left/right on blocks or shore"
msgstr "— Mover para a esquerda/direita em blocos ou em terra"

#: lib/retro_hex_chat_web/controllers/help_content/feature_block_breakers.html.heex:13
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_pong.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Move paddle"
msgstr "— Deslocar a pá"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis_quick.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis_sudden.html.heex:11
#, elixir-autogen, elixir-format
