#: lib/retro_hex_chat_web/controllers/help_content/feature_notices.html.heex:13
#, elixir-autogen, elixir-format
msgid "- Do NOT create PM windows or conversations sidebar entries"
msgstr "- NÃO criar janelas PM ou conversas entradas da barra lateral"

#: lib/retro_hex_chat_web/controllers/help_content/feature_notices.html.heex:16
#, elixir-autogen, elixir-format
msgid "- Do NOT trigger notification sounds or highlights"
msgstr "- NÃO acionar sons de notificação ou destaques"

#: lib/retro_hex_chat_web/controllers/help_content/feature_typing_indicator.html.heex:18
#, elixir-autogen, elixir-format
msgid "- Ignored users' typing indicators are not shown"
msgstr "- Os indicadores de digitação dos usuários ignorados não são mostrados"

#: lib/retro_hex_chat_web/controllers/help_content/feature_timers.html.heex:43
#, elixir-autogen, elixir-format
msgid "- Maximum 5 concurrent timers per session."
msgstr "- Máximo de 5 timers simultâneos por sessão."

#: lib/retro_hex_chat_web/controllers/help_content/feature_mute.html.heex:11
#, elixir-autogen, elixir-format
msgid "- Mute state persists across page reloads (stored in browser)"
msgstr "- Estado mudo persiste através de reloads de página (armazenado no navegador)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_mute.html.heex:14
#, elixir-autogen, elixir-format
msgid "- Muting does not affect the typing indicator"
msgstr "- Muting não afeta o indicador de digitação"

#: lib/retro_hex_chat_web/controllers/help_content/feature_mute.html.heex:11
#, elixir-autogen, elixir-format
msgid "- Muting does not affect visual notifications (conversations sidebar flash, title flash)"
msgstr "- Muting não afeta notificações visuais (conversas sidebar flash, título flash)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_timers.html.heex:43
#, elixir-autogen, elixir-format
msgid "- One-shot: minimum 1 second, maximum 86,400 seconds (24 hours)."
msgstr "- Um tiro: no mínimo 1 segundo, no máximo 86.400 segundos (24 horas)."

#: lib/retro_hex_chat_web/controllers/help_content/feature_typing_indicator.html.heex:9
#, elixir-autogen, elixir-format
msgid "- Only appears in private message conversations (not channels)"
msgstr "- Apenas aparece em conversas de mensagens privadas (não em canais)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_timers.html.heex:46
#, elixir-autogen, elixir-format
msgid "- Repeat: minimum 10 seconds, maximum 86,400 seconds."
msgstr "- Repito: no mínimo 10 segundos, no máximo 86.400 segundos."

#: lib/retro_hex_chat_web/controllers/help_content/feature_notices.html.heex:10
#, elixir-autogen, elixir-format
msgid "- Shown in a distinct color for easy identification"
