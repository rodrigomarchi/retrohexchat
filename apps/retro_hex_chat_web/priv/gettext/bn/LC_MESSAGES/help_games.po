msgstr "— ডিসেম্বর"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_blitz.html.heex:57
#, elixir-autogen, elixir-format
msgid "— Decelerate in narrow sections. One wrong move at high speed means instant death on the banks."
msgstr "— সংকীর্ণ অংশে প্রবেশ করুন । উচ্চ গতিতে একটা ভুল পদক্ষেপ মানে ব্যাংকের মৃত্যুর সাথে সাথেই মারা যায়।"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing.html.heex:66
#, elixir-autogen, elixir-format
