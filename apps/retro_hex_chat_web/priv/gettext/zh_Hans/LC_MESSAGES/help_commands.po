msgstr "注册用户:在会话中保存别名. 来宾:只开会"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_bio.html.heex:31
#, elixir-autogen, elixir-format
msgid "Registered users: bio is saved across sessions"
msgstr "注册用户:在会话中保存生物"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_popups.html.heex:23
#, elixir-autogen, elixir-format
