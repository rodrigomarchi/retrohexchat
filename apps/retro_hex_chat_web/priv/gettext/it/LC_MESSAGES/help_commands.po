#: lib/retro_hex_chat_web/controllers/help_content/cmd_invite.html.heex:2
#, elixir-autogen, elixir-format
msgid "Send a channel invitation to another user. This is required for invite-only (+i) channels where users cannot join on their own."
msgstr "Invia un invito di canale ad un altro utente. Questo è necessario per i canali di invito solo (+i) dove gli utenti non possono unirsi da soli."

#: lib/retro_hex_chat_web/controllers/help_content/cmd_sendfile.html.heex:2
#, elixir-autogen, elixir-format
msgid "Send a file to another user through a direct peer-to-peer connection. The file transfers directly between your browsers without going through the server."
msgstr "Inviare un file a un altro utente tramite una connessione peer-to-peer diretta. Il file si trasferisce direttamente tra i browser senza passare attraverso il server."

#: lib/retro_hex_chat_web/controllers/help_content/cmd_notice.html.heex:2
#, elixir-autogen, elixir-format
msgid "Send a lightweight notice to a user or channel. Unlike"
msgstr "Invia un avviso leggero a un utente o canale. Diversamente"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_wallops.html.heex:2
#, elixir-autogen, elixir-format
msgid "Send a message to all users who have opted in to receive operator announcements by enabling +w user mode."
msgstr "Invia un messaggio a tutti gli utenti che hanno optato per ricevere annunci operatore abilitando la modalità utente +w."

#: lib/retro_hex_chat_web/controllers/help_content/cmd_msg.html.heex:2
#, elixir-autogen, elixir-format
msgid "Send a private message to another user. This opens a PM conversation tab for both of you."
msgstr "Invia un messaggio privato a un altro utente. Questo apre una scheda di conversazione PM per entrambi."

#: lib/retro_hex_chat_web/controllers/help_content/cmd_me.html.heex:2
#, elixir-autogen, elixir-format
msgid "Send an action message that describes what you're doing. It appears to everyone in the channel as"
msgstr "Invia un messaggio d'azione che descrive quello che stai facendo. Sembra a tutti nel canale come"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_announce.html.heex:2
#, elixir-autogen, elixir-format
msgid "Send an urgent broadcast message to every connected user. This is for critical server-wide announcements that everyone must see."
msgstr "Invia un messaggio di trasmissione urgente ad ogni utente connesso. Questo è per gli annunci critici su tutto il server che tutti devono vedere."

#: lib/retro_hex_chat_web/controllers/help_content/cmd_admin.html.heex:2
#, elixir-autogen, elixir-format
msgid "Server administration commands for managing users, channels, services, and settings. Only available to server administrators and operators."
msgstr "Comandi di amministrazione del server per la gestione di utenti, canali, servizi e impostazioni. Disponibile solo per amministratori e operatori del server."

#: lib/retro_hex_chat_web/controllers/help_content/cmd_clearmotd.html.heex:18
#: lib/retro_hex_chat_web/controllers/help_content/cmd_setmotd.html.heex:20
#, elixir-autogen, elixir-format
msgid "Server administrator only"
msgstr "Amministratore server solo"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_announce.html.heex:26
#, elixir-autogen, elixir-format
msgid "Server administrator only — regular users cannot send announcements"
msgstr "Solo l'amministratore del server: gli utenti regolari non possono inviare annunci"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_admin_debug.html.heex:2
#, elixir-autogen, elixir-format
msgid "Server debug tools for viewing runtime information about the BEAM VM. Requires server administrator role. Read-only, no side effects."
msgstr "Strumenti di debug server per la visualizzazione delle informazioni runtime sulla VM BEAM. Richiede un ruolo di amministratore del server. Solo per leggere, senza effetti collaterali."

#: lib/retro_hex_chat_web/controllers/help_content/cmd_wallops.html.heex:30
#, elixir-autogen, elixir-format
msgid "Server operator or administrator only"
msgstr "Solo operatore o amministratore del server"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_game.html.heex:28
#, elixir-autogen, elixir-format
msgid "Sessions expire after 5 minutes if the peer doesn't join"
msgstr "Le sessioni scadono dopo 5 minuti se il peer non si unisce"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_setwelcome.html.heex:2
#, elixir-autogen, elixir-format
msgid "Set a message shown once to each user when they join the current channel. Great for posting rules or helpful information for newcomers."
msgstr "Impostare un messaggio mostrato una volta per ogni utente quando si uniscono al canale corrente. Ottimo per le regole di pubblicazione o informazioni utili per i nuovi arrivati."

#: lib/retro_hex_chat_web/controllers/help_content/cmd_bio.html.heex:2
#, elixir-autogen, elixir-format
msgid "Set a short \"about me\" text that appears when others look you up with"
msgstr "Impostare un breve testo \"su di me\" che appare quando altri ti guardano con"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_autojoin.html.heex:2
#, elixir-autogen, elixir-format
msgid "Set channels to join automatically every time you connect, so you never have to manually rejoin your favorite rooms."
msgstr "Impostare i canali per unirsi automaticamente ogni volta che si collega, in modo da non dover tornare manualmente alle tue stanze preferite."

#: lib/retro_hex_chat_web/controllers/help_content/cmd_setmotd.html.heex:2
#, elixir-autogen, elixir-format
msgid "Set the server's Message of the Day — a welcome message shown to all users when they connect."
msgstr "Impostare il messaggio del server del giorno — un messaggio di benvenuto mostrato a tutti gli utenti quando si collegano."

#: lib/retro_hex_chat_web/controllers/help_content/cmd_perform.html.heex:2
#, elixir-autogen, elixir-format
msgid "Set up commands that automatically run every time you connect, like identifying with NickServ or joining channels."
msgstr "Impostare i comandi che vengono eseguiti automaticamente ogni volta che si collega, come l'identificazione con NickServ o i canali di adesione."

#: lib/retro_hex_chat_web/controllers/help_content/cmd_setmotd.html.heex:13
#, elixir-autogen, elixir-format
msgid "Sets or replaces the server MOTD. After setting it, all newly connecting users will see this message in the Status tab when they join. Existing connected users are not notified — only new connections see the MOTD. Any previous MOTD is replaced."
msgstr "Imposta o sostituisce il server MOTD. Dopo averlo impostato, tutti gli utenti di nuova connessione vedranno questo messaggio nella scheda Stato quando si uniscono. Gli utenti connessi esistenti non sono notificati — solo nuove connessioni vedono il MOTD. Ogni MOTD precedente viene sostituito."

#: lib/retro_hex_chat_web/controllers/help_content/cmd_whowas.html.heex:13
#, elixir-autogen, elixir-format
msgid "Shows information about a user who has disconnected within the configured retention period: their last seen time, which channels they were in, and their quit message (if they provided one). This is useful when you notice someone has left and want to know when and why. Lookups are case-insensitive. If no record exists, a \"no whowas information available\" message is shown."
msgstr "Mostra informazioni su un utente che si è disconnesso all'interno del periodo di conservazione configurato: il loro ultimo tempo visto, quali canali erano, e il loro messaggio di smettere (se ne hanno fornito uno). Questo è utile quando si nota qualcuno è andato e vuole sapere quando e perché. Le ricerche sono insensibili al caso. Se non esiste alcun record, viene visualizzato un messaggio \"nessun whowas information available\"."

