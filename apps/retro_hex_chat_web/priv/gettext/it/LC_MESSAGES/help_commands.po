msgid "Regular users should join"
msgstr "Gli utenti regolari dovrebbero aderire"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_unban.html.heex:2
#, elixir-autogen, elixir-format
msgid "Remove a ban from a user, allowing them to rejoin the channel."
msgstr "Rimuovere un divieto da un utente, permettendo loro di unirsi al canale."

#: lib/retro_hex_chat_web/controllers/help_content/cmd_unmute.html.heex:2
#, elixir-autogen, elixir-format
msgid "Remove a channel mute from a user, allowing them to send messages again."
msgstr "Rimuovere un canale muto da un utente, permettendo loro di inviare nuovamente messaggi."

#: lib/retro_hex_chat_web/controllers/help_content/cmd_kick.html.heex:2
#, elixir-autogen, elixir-format
msgid "Remove a user from the channel. Unlike"
msgstr "Rimuovere un utente dal canale. Diversamente"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_deop.html.heex:2
#, elixir-autogen, elixir-format
msgid "Remove operator status from a user in the current channel. This is a shorthand for"
msgstr "Rimuovere lo stato dell'operatore da un utente nel canale corrente. Questo è un cortometraggio"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_clearmotd.html.heex:2
#, elixir-autogen, elixir-format
msgid "Remove the server's Message of the Day so that new users connecting won't see any MOTD."
msgstr "Rimuovere il messaggio del server del giorno in modo che i nuovi utenti che si collegano non vedranno alcun MOTD."

#: lib/retro_hex_chat_web/controllers/help_content/cmd_clearwelcome.html.heex:2
#, elixir-autogen, elixir-format
msgid "Remove the welcome message from the current channel so that new users joining won't see one."
msgstr "Rimuovere il messaggio di benvenuto dal canale corrente in modo che i nuovi utenti che si uniscono non vedranno uno."

#: lib/retro_hex_chat_web/controllers/help_content/cmd_devoice.html.heex:2
#, elixir-autogen, elixir-format
msgid "Remove voice status from a user in the current channel. This is a shorthand for"
msgstr "Rimuovere lo stato della voce da un utente nel canale corrente. Questo è un cortometraggio"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_clear.html.heex:11
#, elixir-autogen, elixir-format
msgid "Removes all visible messages from whichever window you're currently viewing — a channel, a PM conversation, or the Status tab. This only affects your screen; other users' windows are not changed. The messages are gone permanently and cannot be recovered by scrolling up."
msgstr "Rimuove tutti i messaggi visibili da qualsiasi finestra che si sta attualmente visualizzando — un canale, una conversazione PM, o la scheda Stato. Questo colpisce solo lo schermo; le finestre degli altri utenti non sono cambiate. I messaggi sono andati in modo permanente e non possono essere recuperati scorrendo su."

#: lib/retro_hex_chat_web/controllers/help_content/cmd_unban.html.heex:10
#, elixir-autogen, elixir-format
msgid "Removes the ban entry for the specified user. Once unbanned, the user can rejoin the channel normally. For registered channels, the unban is persisted. You can also unban using"
msgstr "Rimuove la voce di divieto per l'utente specificato. Una volta non annunciato, l'utente può riunire il canale normalmente. Per i canali registrati, l'unban è persistito. Puoi anche usare unban"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_unignore.html.heex:13
#, elixir-autogen, elixir-format
msgid "Removes the user from your ignore list. Their messages, PMs, actions, and invites (whichever were being blocked) will be visible again immediately. To see who you're currently ignoring, run"
msgstr "Rimuove l'utente dall'elenco ignorato. I loro messaggi, PM, azioni e inviti (qualunque fossero bloccati) saranno immediatamente visibili. Per vedere chi stai ignorando, corri"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_timer.html.heex:45
#, elixir-autogen, elixir-format
msgid "Repeating: 10 to 86,400 seconds minimum interval"
msgstr "Ripetizione: da 10 a 86.400 secondi"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_knock.html.heex:2
#, elixir-autogen, elixir-format
msgid "Request to be let into an invite-only (+i) channel. Channel operators see your knock and can choose to invite you in."
msgstr "Richiesta di essere lasciato in un canale di invito solo (+i). Gli operatori del canale vedono il tuo bussare e possono scegliere di invitarti."

#: lib/retro_hex_chat_web/controllers/help_content/cmd_singleplayer.html.heex:11
#, elixir-autogen, elixir-format
msgid "Requirements"
msgstr "Requisiti"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_call.html.heex:26
#, elixir-autogen, elixir-format
msgid "Requires browser microphone permission"
msgstr "Richiede il permesso del microfono del browser"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_mode.html.heex:93
#, elixir-autogen, elixir-format
msgid "Requires channel operator (@) or owner (~) status to set most modes"
msgstr "Richiede lo stato dell'operatore del canale (@) o del proprietario (~) per impostare la maggior parte delle modalità"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_ban.html.heex:29
#: lib/retro_hex_chat_web/controllers/help_content/cmd_unban.html.heex:17
#, elixir-autogen, elixir-format
msgid "Requires channel operator or owner status"
msgstr "Richiede l'operatore del canale o lo stato del proprietario"

#: lib/retro_hex_chat_web/controllers/help_content/cmd_devoice.html.heex:18
#: lib/retro_hex_chat_web/controllers/help_content/cmd_kick.html.heex:32
#: lib/retro_hex_chat_web/controllers/help_content/cmd_mute.html.heex:34
