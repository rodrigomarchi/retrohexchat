#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_boxing.html.heex:50
#, elixir-autogen, elixir-format
msgid ""
"Boxers cannot pass through each other — body collision pushes the mover back"
msgstr ""
"I Boxer non possono passare l'uno attraverso l'altro — la collisione del "
"corpo spinge il movimento indietro"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_night.html.heex:61
#, elixir-autogen, elixir-format
msgid "Brake before fog"
msgstr "Freno prima della nebbia"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost.html.heex:117
#, elixir-autogen, elixir-format
