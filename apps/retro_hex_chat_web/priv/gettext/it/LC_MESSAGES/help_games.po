#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_pong.html.heex:35
#, elixir-autogen, elixir-format
msgid ""
"Ball angle depends on where it hits the paddle — center gives a shallow "
"bounce, edges give steep angles (up to 60 degrees)"
msgstr ""
"L'angolo della palla dipende da dove colpisce la pagaia — il centro dà un "
"rimbalzo superficiale, i bordi danno angoli ripidi (fino a 60 gradi)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis.html.heex:49
#, elixir-autogen, elixir-format
msgid "Ball must clear the net (simulated height arc)"
msgstr "La palla deve cancellare la rete (arco di altezza simulato)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_pong.html.heex:31
#, elixir-autogen, elixir-format
msgid "Ball speed increases with each paddle hit, up to 2.4x initial speed"
msgstr ""
"Velocità della palla aumenta con ogni colpo di pagaia, fino a 2.4x velocità "
"iniziale"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_boxing.html.heex:58
