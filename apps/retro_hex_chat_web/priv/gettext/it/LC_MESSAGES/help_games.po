"Bullets fire at a fixed 30-degree angle, aimed up or down based on your last"
" vertical input"
msgstr ""
"Bullets fuoco ad un angolo fisso di 30 gradi, rivolto su o giù in base al "
"vostro ultimo ingresso verticale"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw.html.heex:33
#, elixir-autogen, elixir-format
msgid "Bullets travel horizontally and are blocked by obstacles"
msgstr "I proiettili viaggiano in orizzontale e sono bloccati da ostacoli"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_stagecoach.html.heex:37
#, elixir-autogen, elixir-format
msgid "Bullets travel straight horizontally (no ricochet)"
msgstr "I proiettili viaggiano direttamente orizzontalmente (senza ricochet)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey.html.heex:32
#, elixir-autogen, elixir-format
