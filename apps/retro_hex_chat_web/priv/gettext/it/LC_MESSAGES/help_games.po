msgstr "Costruisci il tuo igloo raccogliendo 15 pezzi da blocchi di ghiaccio"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw.html.heex:40
#, elixir-autogen, elixir-format
msgid "Bullets are visible — dodge by moving vertically"
msgstr "I proiettili sono visibili — dodge spostandosi verticalmente"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_ricochet.html.heex:34
#, elixir-autogen, elixir-format
