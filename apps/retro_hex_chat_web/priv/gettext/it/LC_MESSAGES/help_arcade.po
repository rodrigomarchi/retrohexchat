#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_halflife_uplink.html.heex:70
#, elixir-autogen, elixir-format
msgid "Use the flashlight"
msgstr "Utilizzare la torcia"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_lure.html.heex:59
