#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_soltys.html.heex:86
#, elixir-autogen, elixir-format
msgid ""
"\"Soltys\" means \"Mayor\" (village head) in Polish. The game is a cult "
"classic in Poland, celebrated for its depiction of mid-1990s village life "
"and folk humor."
msgstr ""
"\"Soltys\" significa \"Mayor\" (capo del villaggio) in polacco. Il gioco è "
"un classico cult in Polonia, celebrato per la sua rappresentazione della "
"vita di villaggio di metà degli anni novanta e l'umorismo popolare."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm.html.heex:50
#, elixir-autogen, elixir-format
msgid ""
"(1992) — Revolution Software's debut. Medieval fantasy with innovative "
"Virtual Theatre AI system."
msgstr ""
"(1992) — Il debutto del software di rivoluzione. Fantasia medievale con "
"innovativo sistema Virtual Theatre AI."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm.html.heex:14
#, elixir-autogen, elixir-format
msgid ""
"(1994) — Cyberpunk masterpiece by Revolution Software. Full CD version with "
"voice acting."
msgstr ""
"(1994) — Il capolavoro cyberpunk di Revolution Software. Versione CD "
"completa con recitazione vocale."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm.html.heex:32
#, elixir-autogen, elixir-format
msgid ""
"(1994) — Dark cyberpunk top-down adventure by Creative Reality. Full CD "
"version with voice acting."
msgstr ""
"(1994) — Dark cyberpunk top-down avventura di Creative Reality. Versione CD "
"completa con recitazione vocale."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm.html.heex:41
#, elixir-autogen, elixir-format
