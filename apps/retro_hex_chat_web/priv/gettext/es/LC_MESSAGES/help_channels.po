#, elixir-autogen, elixir-format
msgid "Owner (+q)"
msgstr "Propietario (+q)"

#: lib/retro_hex_chat_web/controllers/help_content/mode_q.html.heex:9
#, elixir-autogen, elixir-format
msgid "Owner (~) > Operator (@) > Half-Operator (%) > Voice (+) > Regular"
msgstr "Propietario (~) не Operator (@) не Media-Operador (%) не Voz regular (+)"

