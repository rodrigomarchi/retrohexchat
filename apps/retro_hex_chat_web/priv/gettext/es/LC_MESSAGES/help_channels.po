msgstr "(Auto Operador) &rar; Operador (@) automáticamente al unirse"

#: lib/retro_hex_chat_web/controllers/help_content/channel_permissions.html.heex:129
#, elixir-autogen, elixir-format
msgid "(Auto Voice) &rarr; Voiced (+) automatically on join"
msgstr "(Voz Automática) &quot; La voz (+) automáticamente en unirse"

#: lib/retro_hex_chat_web/controllers/help_content/channel_permissions.html.heex:117
#, elixir-autogen, elixir-format
