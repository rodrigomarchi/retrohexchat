msgstr "(Super Operador) &rar; Operador (@) automáticamente al unirse"

#: lib/retro_hex_chat_web/controllers/help_content/channel_permissions.html.heex:147
#, elixir-autogen, elixir-format
msgid "(banned) — Banned users cannot join. Removed with"
msgstr "(banned) — Los usuarios prohibidos no pueden unirse. Retirada con"

#: lib/retro_hex_chat_web/controllers/help_content/channel_permissions.html.heex:152
#, elixir-autogen, elixir-format
msgid "(invite-only) — Only invited users or those with ban exceptions can join."
msgstr "(sólo invitado) — Sólo los usuarios invitados o aquellos con excepciones de prohibición pueden unirse."

#: lib/retro_hex_chat_web/controllers/help_content/channel_permissions.html.heex:159
#, elixir-autogen, elixir-format
msgid "(key) — Requires the correct password:"
msgstr "(key) — Requiere la contraseña correcta:"

#: lib/retro_hex_chat_web/controllers/help_content/channel_permissions.html.heex:162
#, elixir-autogen, elixir-format
msgid "(limit) — Channel cannot exceed the user limit."
msgstr "(limit) — El canal no puede exceder el límite de usuario."

#: lib/retro_hex_chat_web/controllers/help_content/channel_permissions.html.heex:184
#, elixir-autogen, elixir-format
msgid "(moderated) — Only Voiced, Half-Operator, Operator, and Owner can speak."
msgstr "(moderado) — Sólo Voz, Medio-Operador, Operador y Propietario puede hablar."

#: lib/retro_hex_chat_web/controllers/help_content/channel_permissions.html.heex:190
#, elixir-autogen, elixir-format
msgid "(no external) — Only channel members can send messages."
msgstr "(no externa) — Sólo los miembros del canal pueden enviar mensajes."

#: lib/retro_hex_chat_web/controllers/help_content/chanserv.html.heex:99
#, elixir-autogen, elixir-format
msgid "(no joins or messages)"
msgstr "(no se une o mensajes)"

#: lib/retro_hex_chat_web/controllers/help_content/channel_permissions.html.heex:168
#, elixir-autogen, elixir-format
msgid "(registered-only) — Only registered and identified users can join."
msgstr "(sólo registrado) - Sólo los usuarios registrados e identificados pueden unirse."

#: lib/retro_hex_chat_web/controllers/help_content/channel_permissions.html.heex:174
#, elixir-autogen, elixir-format
msgid "(throttle) — Limits the rate of joins (anti-flood)."
msgstr "(peligro) - Limita la tasa de afiliaciones (anti-flood)."

