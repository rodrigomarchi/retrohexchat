#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_lure.html.heex:74
#, elixir-autogen, elixir-format
msgid "— Some puzzles depend on NPC positions. Save often and be patient."
msgstr "— Certains puzzles dépendent des positions des PNC. Sauvez souvent et soyez patient."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_fotaq.html.heex:74
#, elixir-autogen, elixir-format
msgid "— Some puzzles have more than one solution. Experiment freely."
msgstr "— Certains puzzles ont plus d'une solution. Expérimentez librement."

