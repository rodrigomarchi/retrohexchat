msgstr "— Avancez pour tirer, puis évitez-le pendant que votre adversaire se recharge."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Move gunslinger (vertical; horizontal in No Man's Land)"
msgstr "— Déplacer les canons (verticals; horizontaux dans le no man's land)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_stagecoach.html.heex:11
