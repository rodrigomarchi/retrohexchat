#, elixir-autogen, elixir-format
msgid "— Jump to row below"
msgstr "— Aller à la ligne ci-dessous"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost.html.heex:17
#, elixir-autogen, elixir-format
msgid "— Jump to the row above (toward shore)"
msgstr "— Aller à la ligne au-dessus (vers la rive)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost.html.heex:23
#, elixir-autogen, elixir-format
msgid "— Jump to the row below (toward water)"
msgstr "— Sauter à la ligne ci-dessous (vers l'eau)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_night.html.heex:76
#, elixir-autogen, elixir-format
msgid "— Keep a mental tally. If you're ahead, play safe. If behind, take risks in the final minute."
msgstr "- Gardez un compte mental. Si vous êtes en avance, jouez en sécurité. Si derrière, prendre des risques dans la dernière minute."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_warlords.html.heex:25
#, elixir-autogen, elixir-format
msgid "— Launch fireball toward opponent"
msgstr "— Lancez la boule de feu vers l'adversaire"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey.html.heex:38
#, elixir-autogen, elixir-format
msgid "— Launches puck at 2× your movement speed in your facing direction"
msgstr "— Lance la rondelle à 2× votre vitesse de mouvement dans votre direction de face"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_stagecoach.html.heex:59
#, elixir-autogen, elixir-format
msgid "— Match your vertical position to stay in the gap the stagecoach leaves behind as it moves."
msgstr "— Correspondez à votre position verticale pour rester dans l'écart que l'entrainement laisse derrière elle."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing.html.heex:60
#, elixir-autogen, elixir-format
msgid "— More rocks, faster avalanche, medium gates"
msgstr "— Plus de roches, avalanche plus rapide, portes moyennes"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_boxing.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Move boxer (8 directions)"
msgstr "— Déplacer le boxeur (8 directions)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders.html.heex:11
