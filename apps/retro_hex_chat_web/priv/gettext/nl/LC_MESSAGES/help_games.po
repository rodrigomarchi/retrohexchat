#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw.html.heex:54
#, elixir-autogen, elixir-format
msgid "— Bullets fire at 30-degree angles and bounce once off ceiling/floor"
msgstr "De kogels schieten in een hoek van 30 graden en stuiteren eenmaal van het plafond."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_warlords.html.heex:19
#, elixir-autogen, elixir-format
msgid "— Catch fireball on shield contact"
msgstr "Vang vuurbal op schildcontact"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_night.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_sprint.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Change lane left"
msgstr "Verander van rijstrook links"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro.html.heex:17
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_night.html.heex:17
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_sprint.html.heex:17
#, elixir-autogen, elixir-format
msgid "— Change lane right"
msgstr "Verander van rijstrook rechts"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis.html.heex:64
#, elixir-autogen, elixir-format
msgid "— Classic: full set with tiebreak at 6-6"
msgstr "Classic: volledige set met tiebreak op 6-6"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_coop.html.heex:54
#, elixir-autogen, elixir-format
msgid "— Clearing aliens from the sides slows horizontal movement for the entire wave."
msgstr "Door buitenaardse wezens van de zijkanten te verwijderen wordt de horizontale beweging voor de hele golf vertraagd."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing_clean.html.heex:45
#, elixir-autogen, elixir-format
msgid "— Courses repeat. In best-of-3, the third round favors the player who learned the layout."
msgstr "Cursussen herhalen. In best-of-3, de derde ronde gunsten de speler die de lay-out geleerd."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid.html.heex:20
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_blitz.html.heex:20
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_pacifist.html.heex:20
#, elixir-autogen, elixir-format
msgid "— Decelerate"
msgstr "Vertragen"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_blitz.html.heex:57
#, elixir-autogen, elixir-format
msgid "— Decelerate in narrow sections. One wrong move at high speed means instant death on the banks."
msgstr "Vertragen in smalle secties. Een verkeerde beweging met hoge snelheid betekent onmiddellijke dood op de banken."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing.html.heex:66
#, elixir-autogen, elixir-format
msgid "— Dense ice patches, fast avalanche, narrow gates"
msgstr "Dichte ijsplekken, snelle lawine, smalle poorten"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_sprint.html.heex:72
#, elixir-autogen, elixir-format
msgid "— Don't waste time recovering from crashes. Stay focused from second one."
msgstr "Verspil geen tijd met herstellen van crashes. Blijf geconcentreerd vanaf de tweede."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid.html.heex:29
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_blitz.html.heex:29
#, elixir-autogen, elixir-format
msgid "— Drop mine"
msgstr "Laat de mijne vallen."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing_clean.html.heex:31
#, elixir-autogen, elixir-format
msgid "— Each gate saves 2 seconds. Over a full run, gates make the difference between winning and losing."
msgstr "Elke poort bespaart 2 seconden. Over een volledige run maken poorten het verschil tussen winnen en verliezen."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_coop.html.heex:47
#, elixir-autogen, elixir-format
msgid "— Each player takes a side. Overlapping coverage wastes shots and leaves gaps."
msgstr "Elke speler kiest een kant. Overlappende dekking afval shots en laat gaten."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis.html.heex:76
#, elixir-autogen, elixir-format
msgid "— Each point wins a game, first to 6"
msgstr "Elk punt wint een spel, eerst tot 6"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_coop.html.heex:68
#, elixir-autogen, elixir-format
msgid "— Earlier waves are easier. Play conservatively to have lives for waves 8-10."
msgstr "Eerdere golven zijn makkelijker. Speel conservatief om levens te hebben voor golven 8-10."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_peaceful.html.heex:62
#, elixir-autogen, elixir-format
msgid "— Enemies still escalate. In later rounds, focus on survival over speed."
msgstr "Vijanden escaleren nog steeds. In latere rondes, focus op overleven over snelheid."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_peaceful.html.heex:48
#, elixir-autogen, elixir-format
msgid "— Even though stealing is off, being on the same row as your opponent means fewer blocks for you."
msgstr "Hoewel stelen is uit, op dezelfde rij als je tegenstander betekent minder blokken voor je."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis_quick.html.heex:53
#, elixir-autogen, elixir-format
msgid "— Even when behind in a game, fighting to deuce gives you a chance. Never give up a game easily."
msgstr "Zelfs wanneer achter in een spel, vechten om deuce geeft je een kans. Geef nooit zomaar een spel op."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis_sudden.html.heex:40
#, elixir-autogen, elixir-format
msgid "— Every single rally decides a game. Stay focused for every point."
msgstr "Elke rally beslist over een spel. Blijf geconcentreerd voor elk punt."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_showdown.html.heex:76
#, elixir-autogen, elixir-format
msgid "— Fast pucks that hit the corners of the goal are nearly impossible to save."
msgstr "Snel pucks die de hoeken van het doel raken zijn bijna onmogelijk te redden."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw.html.heex:17
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_nml.html.heex:15
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_ricochet.html.heex:19
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_stagecoach.html.heex:17
#, elixir-autogen, elixir-format
msgid "— Fire (one bullet at a time)"
msgstr "Vuur (één kogel per keer)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_debris_field.html.heex:29
#: lib/retro_hex_chat_web/controllers/help_content/feature_gravity_well.html.heex:29
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders.html.heex:23
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_blitz.html.heex:23
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_coop.html.heex:23
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid.html.heex:26
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_blitz.html.heex:26
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_pacifist.html.heex:26
#: lib/retro_hex_chat_web/controllers/help_content/feature_pixel_tanks.html.heex:20
#: lib/retro_hex_chat_web/controllers/help_content/feature_star_duel.html.heex:29
#, elixir-autogen, elixir-format
msgid "— Fire missile"
msgstr "Vuurraket"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis.html.heex:70
#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_games.html.heex:127
#, elixir-autogen, elixir-format
msgid "— First to 3 games wins"
msgstr "Eerste tot 3 spellen wint"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost.html.heex:80
#, elixir-autogen, elixir-format
msgid "— Fly between rows, danger during jumps (from round 3)"
msgstr "Vlieg tussen rijen, gevaar tijdens sprongen (van ronde 3)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing_escape.html.heex:64
#, elixir-autogen, elixir-format
msgid "— Focus on the obstacles ahead, not the death wall behind you. Trust your speed and dodge forward."
msgstr "Focus op de obstakels voor je, niet de doodsmuur achter je. Vertrouw op je snelheid en ontwijk vooruit."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_night.html.heex:62
#, elixir-autogen, elixir-format
msgid "— Fog bursts reduce visibility to nearly zero. Slow down when fog hits and stay centered."
msgstr "Mistuitbarstingen verminderen het zicht tot bijna nul. Rustig aan als de mist toeslaat en in het midden blijft."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey.html.heex:50
#, elixir-autogen, elixir-format
msgid "— Free puck gradually slows down on the ice"
msgstr "Gratis puck vertraagt geleidelijk op het ijs"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro.html.heex:67
#, elixir-autogen, elixir-format
msgid "— Full Classic Duel: 3 days with weather cycle"
msgstr "Full Classic Duel: 3 dagen met weercyclus"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders.html.heex:62
#, elixir-autogen, elixir-format
msgid "— Full rules: alien drops, combos, 10 waves"
msgstr "Volledige regels: buitenaardse druppels, combo's, 10 golven"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid.html.heex:53
#, elixir-autogen, elixir-format
msgid "— Full rules: mines, fuel competition, 10 sections"
msgstr "Volledige regels: mijnen, brandstofconcurrentie, 10 secties"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_nml.html.heex:64
#, elixir-autogen, elixir-format
msgid "— Half-measures get you killed. Either push hard or stay back and react."
msgstr "Halve maatregelen worden je dood. Duw hard of blijf achteruit en reageer."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_coop.html.heex:61
#, elixir-autogen, elixir-format
msgid "— If one cannon goes down, the other faces the full wave alone. Keep each other alive."
msgstr "Als het ene kanon naar beneden gaat, kijkt de andere alleen naar de volle golf. Hou elkaar in leven."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey.html.heex:56
#, elixir-autogen, elixir-format
msgid "— If the puck stops for 5 seconds, a face-off is called"
msgstr "Als de puck 5 seconden stopt, wordt een face-off genoemd"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_blitz.html.heex:76
#, elixir-autogen, elixir-format
msgid "— If tied at the end, the next goal wins. Stay composed under pressure."
msgstr "Als verbonden aan het einde, wint het volgende doelpunt. Blijf samengesteld onder druk."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_blitz.html.heex:65
#, elixir-autogen, elixir-format
msgid "— In Blitz, volume of kills matters more than perfect accuracy. Keep firing."
msgstr "In Blitz is het volume van de moorden belangrijker dan perfecte nauwkeurigheid. Blijf schieten."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis_quick.html.heex:46
#, elixir-autogen, elixir-format
msgid "— In a short match, holding serve is critical. Aim for the corners on your service games."
msgstr "In een korte wedstrijd, houden dienen is cruciaal. Richt op de hoeken van je service games."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing.html.heex:39
#, elixir-autogen, elixir-format
msgid "— Infinite descent, ever-accelerating avalanche, last skier standing wins"
msgstr "Oneindige afdaling, steeds versnellende lawine, laatste skiër staande wint"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders.html.heex:74
#, elixir-autogen, elixir-format
msgid "— Instant drops, easier combos, 5 waves"
msgstr "Instant druppels, gemakkelijker combo's, 5 golven"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_blizzard.html.heex:17
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_peaceful.html.heex:17
#, elixir-autogen, elixir-format
msgid "— Jump to row above"
msgstr "Naar rij hierboven springen"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_blizzard.html.heex:23
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_peaceful.html.heex:23
#, elixir-autogen, elixir-format
msgid "— Jump to row below"
msgstr "Naar rij onder springen"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost.html.heex:17
#, elixir-autogen, elixir-format
msgid "— Jump to the row above (toward shore)"
msgstr "Spring naar de rij hierboven (naar de oever)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost.html.heex:23
#, elixir-autogen, elixir-format
msgid "— Jump to the row below (toward water)"
msgstr "Spring naar de rij hieronder (naar het water)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_night.html.heex:76
#, elixir-autogen, elixir-format
msgid "— Keep a mental tally. If you're ahead, play safe. If behind, take risks in the final minute."
msgstr "Hou een mentaal overzicht. Als je vooruit bent, wees voorzichtig. Als je achter loopt, neem dan risico's in de laatste minuut."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_warlords.html.heex:25
#, elixir-autogen, elixir-format
msgid "— Launch fireball toward opponent"
msgstr "Lanceer vuurbal richting tegenstander"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey.html.heex:38
#, elixir-autogen, elixir-format
msgid "— Launches puck at 2× your movement speed in your facing direction"
msgstr "Lanceert puck bij 2× uw bewegingssnelheid in uw richting"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_stagecoach.html.heex:59
#, elixir-autogen, elixir-format
msgid "— Match your vertical position to stay in the gap the stagecoach leaves behind as it moves."
msgstr "Match uw verticale positie te blijven in de kloof de postkoets laat achter als het beweegt."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing.html.heex:60
#, elixir-autogen, elixir-format
msgid "— More rocks, faster avalanche, medium gates"
msgstr "Meer rotsen, snellere lawine, middelgrote poorten"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_boxing.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Move boxer (8 directions)"
msgstr "Beweeg boxer (8 richtingen)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_blitz.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_coop.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Move cannon left"
msgstr "Kanon naar links verplaatsen"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders.html.heex:17
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_blitz.html.heex:17
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_coop.html.heex:17
#, elixir-autogen, elixir-format
msgid "— Move cannon right"
msgstr "Kanon naar rechts verplaatsen"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_nml.html.heex:50
#, elixir-autogen, elixir-format
msgid "— Move forward to draw a shot, then dodge it while your opponent reloads."
msgstr "Beweeg vooruit om een shot te trekken en ontwijk het terwijl je tegenstander herlaadt."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Move gunslinger (vertical; horizontal in No Man's Land)"
msgstr "Beweeg revolverheld (verticaal; horizontaal in niemandsland)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_stagecoach.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Move gunslinger vertically"
msgstr "Beweeg revolverheld verticaal"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_nml.html.heex:12
#, elixir-autogen, elixir-format
msgid "— Move gunslinger vertically and horizontally within your half"
msgstr "Beweeg revolverheld verticaal en horizontaal binnen uw helft"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_blitz.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_showdown.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Move in 8 directions"
msgstr "Beweeg in 8 richtingen"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_blizzard.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_peaceful.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Move left/right"
msgstr "Verplaatsen naar links/right"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Move left/right on blocks or shore"
msgstr "Beweeg links /right op blokken of wal"

#: lib/retro_hex_chat_web/controllers/help_content/feature_block_breakers.html.heex:13
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_pong.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Move paddle"
msgstr "Beweeg paddle"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis_quick.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis_sudden.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Move player"
msgstr "Beweeg speler"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_warlords.html.heex:13
#, elixir-autogen, elixir-format
msgid "— Move shield vertically"
msgstr "Schild verticaal verplaatsen"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_ricochet.html.heex:13
#, elixir-autogen, elixir-format
msgid "— Move vertically and set aim direction (last pressed determines angle)"
msgstr "Verticaal verplaatsen en richtrichting instellen (laatst ingedrukt bepaalt hoek)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost.html.heex:32
#, elixir-autogen, elixir-format
msgid "— Neutral. Step on it to claim it (+1 igloo piece)"
msgstr "Neutraal. Stap erop om het te claimen (+1 iglo stuk)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing.html.heex:48
#, elixir-autogen, elixir-format
msgid "— No avalanche, no items, pure time trial racing"
msgstr "Geen lawine, geen items, pure tijdrit race"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost.html.heex:110
#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_games.html.heex:203
#, elixir-autogen, elixir-format
msgid "— No block stealing, pure construction race"
msgstr "Geen blok stelen, pure bouw ras"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_sprint.html.heex:51
#, elixir-autogen, elixir-format
msgid "— No fuel means no reason to brake unless you're about to crash. Keep the pedal down."
msgstr "Geen brandstof betekent geen reden om te remmen tenzij je op het punt staat te crashen. Houd het pedaal naar beneden."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid.html.heex:59
#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_games.html.heex:163
#, elixir-autogen, elixir-format
msgid "— No mines, pure skill competition"
msgstr "Geen mijnen, pure vaardigheidswedstrijd"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw.html.heex:69
#, elixir-autogen, elixir-format
msgid "— No obstacle, but players can advance horizontally within their half"
msgstr "Geen obstakel, maar spelers kunnen horizontaal binnen hun helft"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey.html.heex:117
#, elixir-autogen, elixir-format
msgid "— No timer, first to 5 goals, puck speeds up with each goal"
msgstr "Geen timer, eerste tot 5 doelen, puck snelheden met elk doel"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_blizzard.html.heex:48
#, elixir-autogen, elixir-format
msgid "— Not all ice rows are equal. Focus on rows with predictable patterns first."
msgstr "Niet alle ijsrijen zijn gelijk. Focus eerst op rijen met voorspelbare patronen."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_stagecoach.html.heex:66
#, elixir-autogen, elixir-format
msgid "— One bullet at a time. A wasted shot on the stagecoach gives your opponent a free window to reposition."
msgstr "Eén kogel tegelijk. Een verspilde schot op de postkoets geeft je tegenstander een gratis venster om te herpositioneren."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost.html.heex:86
#, elixir-autogen, elixir-format
msgid "— Open/close on blocks. Open = dangerous, closed = safe (from round 4)"
msgstr "Open /close op blokken. Open = gevaarlijk, gesloten = veilig (vanaf ronde 4)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost.html.heex:68
#, elixir-autogen, elixir-format
msgid "— Patrols the shore. Dodge to reach your igloo!"
msgstr "Patrouilles de kust. Dodge om je iglo te bereiken!"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_peaceful.html.heex:55
#, elixir-autogen, elixir-format
msgid "— Perfect your jump timing between rows to minimize time between block collections."
msgstr "Perfect uw sprong timing tussen rijen om de tijd tussen blok collecties te minimaliseren."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey.html.heex:44
#, elixir-autogen, elixir-format
msgid "— Puck reflects off top/bottom walls"
msgstr "Puck reflecteert de bovenkant /bottom muren"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_boxing.html.heex:17
#, elixir-autogen, elixir-format
msgid "— Punch (alternates left/right arm automatically)"
msgstr "Punch (ter vervanging van links)/right arm automatisch)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost.html.heex:74
#, elixir-autogen, elixir-format
msgid "— Ride the ice blocks (from round 2)"
msgstr "Berijd de ijsblokken (van ronde 2)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis_sudden.html.heex:51
#, elixir-autogen, elixir-format
msgid "— Risky shots that go out cost you a whole game. Consistency beats flash in Sudden Death."
msgstr "Risky shots die uitgaan kostte je een heel spel. Consistentie is beter dan een plotselinge dood."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_night.html.heex:69
#, elixir-autogen, elixir-format
msgid "— Save your turbo boost for fog-free moments when you can actually see the road."
msgstr "Bespaar uw turbo boost voor mistvrije momenten wanneer u de weg daadwerkelijk kunt zien."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_blitz.html.heex:50
#, elixir-autogen, elixir-format
msgid "— Scarce fuel means every depot matters. Plan your path to hit fuel depots even if it means fewer enemy kills."
msgstr "Scarce brandstof betekent elke depot belangrijk. Plan je pad om brandstofdepots te raken, zelfs als het minder vijandelijke moorden betekent."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis.html.heex:17
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis_quick.html.heex:17
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis_sudden.html.heex:17
#, elixir-autogen, elixir-format
msgid "— Serve (during serving phase)"
msgstr "Serve (tijdens de dienstfase)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis_sudden.html.heex:58
#, elixir-autogen, elixir-format
msgid "— Server alternates after every point. Know when you're serving to maximize advantage."
msgstr "Server wisselt na elk punt. Weet wanneer je dient om het voordeel te maximaliseren."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders.html.heex:68
#, elixir-autogen, elixir-format
msgid "— Shared screen, no alien drops, fight together"
msgstr "Gedeeld scherm, geen buitenaardse druppels, samen vechten"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing_clean.html.heex:38
#, elixir-autogen, elixir-format
msgid "— Sharp turns slow you down. Plan your path 2-3 obstacles ahead for the smoothest line."
msgstr "Scherpe bochten vertragen je. Plan uw pad 2-3 obstakels vooruit voor de gladste lijn."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey.html.heex:17
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_blitz.html.heex:17
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_showdown.html.heex:17
#, elixir-autogen, elixir-format
msgid "— Shoot in your facing direction"
msgstr "Schiet in je gezicht richting"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_pacifist.html.heex:52
#, elixir-autogen, elixir-format
msgid "— Slow down for dense enemy clusters to maximize hits. Speed up in empty stretches to save fuel."
msgstr "Vertragen voor dichte vijandelijke clusters om hits te maximaliseren. Sneller in lege stukken om brandstof te besparen."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing.html.heex:54
#, elixir-autogen, elixir-format
msgid "— Sparse obstacles, slow avalanche, wide gates"
msgstr "Sparse obstakels, trage lawine, brede poorten"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing_escape.html.heex:50
#, elixir-autogen, elixir-format
msgid "— Speed boosts keep you ahead of the avalanche. Missing one could be fatal later."
msgstr "Speed boosts houden je voor op de lawine. Een vermiste kan later fataal zijn."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_showdown.html.heex:69
#, elixir-autogen, elixir-format
msgid "— Standard 60% success rate. Don't commit to a tackle unless you're sure you're close enough."
msgstr "Standaard 60% succespercentage. Doe niet aan een tackle tenzij je zeker weet dat je dichtbij genoeg bent."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_ricochet.html.heex:65
#, elixir-autogen, elixir-format
msgid "— Standing near the ceiling or floor gives your bullets a shorter bounce path, making them harder to dodge."
msgstr "Staande in de buurt van het plafond of vloer geeft uw kogels een kortere bounce pad, waardoor ze moeilijker te ontwijken."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_blitz.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_pacifist.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Steer jet laterally"
msgstr "Steerjet lateraal"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing_clean.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing_escape.html.heex:11
#, elixir-autogen, elixir-format
msgid "— Steer left/right"
msgstr "Stuur links/right"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost.html.heex:38
#, elixir-autogen, elixir-format
msgid "— Step on your own block to undo it (-1 piece)"
msgstr "Stap op je eigen blok om het ongedaan te maken (-1 stuk)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost.html.heex:45
#, elixir-autogen, elixir-format
msgid "— Step to steal it! You +1 piece, they -1 piece (2-piece swing!)"
msgstr "Stap om het te stelen! Je +1 stuk, ze -1 stuk (2-delige swing!)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_blizzard.html.heex:55
#, elixir-autogen, elixir-format
msgid "— Stepping on your opponent's blocks steals them. Use it offensively when you're ahead."
msgstr "Stappen op de blokken van je tegenstander steelt ze. Gebruik het beledigend als je vooruit bent."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey.html.heex:23
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_blitz.html.heex:23
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_showdown.html.heex:23
#, elixir-autogen, elixir-format
msgid "— Tackle opponent to steal puck"
msgstr "Aanvaller om puck te stelen"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_blitz.html.heex:69
#, elixir-autogen, elixir-format
msgid "— The 25% speed boost makes long-range shots more effective. Catch the opponent off guard."
msgstr "De 25% snelheidsverhoging maakt langeafstandsschoten effectiever. Vang de tegenstander op."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_blitz.html.heex:62
#, elixir-autogen, elixir-format
msgid "— The 80% success rate means tackling is almost always worth it. Chase the puck carrier relentlessly."
msgstr "De 80% succespercentage betekent aanpakken is bijna altijd de moeite waard. Chase de puck drager meedogenloos."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis_quick.html.heex:60
#, elixir-autogen, elixir-format
msgid "— The ball angle depends on where it hits your player. Position yourself to control shot direction."
msgstr "De bal hoek hangt af van waar het raakt uw speler. Plaats jezelf om schotrichting te controleren."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing_escape.html.heex:43
#, elixir-autogen, elixir-format
msgid "— The center of the course gives you the most options to dodge left or right as obstacles appear."
msgstr "Het centrum van de cursus geeft u de meeste opties om te ontwijken links of rechts als obstakels verschijnen."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_showdown.html.heex:55
#, elixir-autogen, elixir-format
msgid "— The first few goals are at normal puck speed. Build a lead before the puck becomes a missile."
msgstr "De eerste paar doelen zijn op normale puck snelheid. Bouw een spoor voordat de puck een raket wordt."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_stagecoach.html.heex:45
#, elixir-autogen, elixir-format
msgid "— The stagecoach bounces at a constant speed. Count the timing and fire during the gap windows."
msgstr "De postkoets stuitert constant. Tel de timing en het vuur tijdens de openingsramen."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_stagecoach.html.heex:52
#, elixir-autogen, elixir-format
msgid "— The stagecoach spends the least time at the top and bottom of its bounce, creating wider shooting windows."
msgstr "De postkoets brengt de minste tijd door aan de bovenkant en onderkant van zijn stuiter, waardoor bredere schietramen ontstaan."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing_clean.html.heex:52
#, elixir-autogen, elixir-format
msgid "— Tight gaps require micro-adjustments. Don't overcorrect and bounce between obstacles."
msgstr "Niet overcorrigeren en stuiteren tussen obstakels."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_pacifist.html.heex:59
#, elixir-autogen, elixir-format
msgid "— Touching the riverbank kills you instantly. Stay centered when the river narrows."
msgstr "Aanraken van de rivieroever doodt je direct. Blijf gecentreerd als de rivier smaller wordt."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey.html.heex:32
#, elixir-autogen, elixir-format
msgid "— Walk into the free puck to pick it up automatically"
msgstr "Loop in de gratis puck om het automatisch op te halen"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_sprint.html.heex:65
#, elixir-autogen, elixir-format
msgid "— Weave through tight gaps between AI cars. Each overtake counts — even risky ones."
msgstr "Weef door nauwe gaten tussen AI auto's. Elke inhaal telt zelfs risicovolle."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_showdown.html.heex:62
#, elixir-autogen, elixir-format
msgid "— When the puck is fast, stay between the puck and your goal. Reaction time shrinks."
msgstr "Als de puck snel is, blijf dan tussen de puck en je doel. Reactietijd krimpt."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_blizzard.html.heex:41
#, elixir-autogen, elixir-format
msgid "— With 60° on the clock, you have time. Don't rush jumps and fall into the water."
msgstr "Met 60° op de klok, heb je tijd. Niet te snel springen en in het water vallen."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_blitz.html.heex:55
#, elixir-autogen, elixir-format
msgid "— With 80% tackle success, holding the puck is dangerous. Shoot on sight."
msgstr "Met 80% tackle succes, het vasthouden van de puck is gevaarlijk. Schiet op zicht."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_blitz.html.heex:43
#, elixir-autogen, elixir-format
msgid "— With a 3-second cooldown, you can drop mines much more frequently. Use them to disrupt your opponent's rhythm."
msgstr "Met een 3-seconde afkoeling, kunt u mijnen veel vaker laten vallen. Gebruik ze om het ritme van je tegenstander te verstoren."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro_sprint.html.heex:58
#, elixir-autogen, elixir-format
msgid "— With clear visibility, use turbo when the road ahead is clear for maximum overtakes."
msgstr "Met duidelijk zicht, gebruik turbo wanneer de weg vooruit is duidelijk voor maximale inhalen."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_blitz.html.heex:44
#, elixir-autogen, elixir-format
msgid "— With lowered combo thresholds (2 kills for a drop), rapid-fire is your best weapon against the opponent."
msgstr "Met verlaagde combo drempels (2 doden voor een druppel), snelvuur is uw beste wapen tegen de tegenstander."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_nml.html.heex:57
#, elixir-autogen, elixir-format
msgid "— With no obstacles, vertical movement is your only defense. Never stand still."
msgstr "Zonder obstakels is verticale beweging uw enige verdediging. Sta nooit stil."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis_sudden.html.heex:44
#, elixir-autogen, elixir-format
msgid "— With one-point games, an ace or unreturnable serve is an instant game win."
msgstr "Met one-point games, een aas of unreturnable server is een instant game winnen."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis_quick.html.heex:39
#, elixir-autogen, elixir-format
msgid "— With only 3 games needed, losing even one game puts you at a serious disadvantage."
msgstr "Met slechts 3 games nodig, het verliezen van zelfs een spel brengt je in een ernstig nadeel."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_blitz.html.heex:64
#, elixir-autogen, elixir-format
msgid "— With only 5 sections, maximizing points per section is key. Prioritize high-value targets."
msgstr "Met slechts 5 secties, het maximaliseren van punten per sectie is belangrijk. Prioriteer doelen van hoge waarde."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_peaceful.html.heex:41
#, elixir-autogen, elixir-format
msgid "— Without block stealing, the fastest path through the ice rows wins. Plan your circuit."
msgstr "Zonder blok stelen wint het snelste pad door de ijsrijen. Plan je circuit."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid_pacifist.html.heex:45
#, elixir-autogen, elixir-format
msgid "— Without mines to worry about, you can fly more aggressively. But don't forget to refuel — fuel depots are your lifeline."
msgstr "Zonder mijnen om je zorgen over te maken, kunt u agressiever vliegen. Maar vergeet niet om bij te tanken brandstof depots zijn uw reddingslijn."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_ricochet.html.heex:72
#, elixir-autogen, elixir-format
msgid "— You can only fire one bullet at a time. Don't waste shots — wait for a clear angle."
msgstr "Je kunt maar één kogel tegelijk afvuren. Verspil geen schoten... wacht op een duidelijke hoek."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw_ricochet.html.heex:58
#, elixir-autogen, elixir-format
msgid "— Your last directional input sets your aim. Keep moving up and down to make your shots unpredictable."
msgstr "Je laatste ingang stelt je doel in. Blijf op en neer bewegen om je schoten onvoorspelbaar te maken."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_blitz.html.heex:44
#, elixir-autogen, elixir-format
msgid "— more aggressive, less risk"
msgstr "Meer agressief, minder risico"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_showdown.html.heex:32
#, elixir-autogen, elixir-format
msgid "— play until someone reaches 5 goals"
msgstr "Speel tot iemand 5 doelen bereikt"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_showdown.html.heex:38
#, elixir-autogen, elixir-format
msgid "— puck gets faster with each goal scored"
msgstr "Puck wordt sneller met elk doelpunt gescoord"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey.html.heex:68
#, elixir-autogen, elixir-format
msgid "— puck is freed at opponent's position"
msgstr "Puck is bevrijd op de positie van de tegenstander."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey.html.heex:74
#, elixir-autogen, elixir-format
msgid "— you are stunned for 300ms (can't move or act)"
msgstr "U bent verdoofd voor 300 meter (kan niet bewegen of acteren)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_single_session.html.heex:2
#, elixir-autogen, elixir-format
msgid ". Only one browser window or tab can be connected with the same nickname at a time."
msgstr ". Slechts één browservenster of tabblad kan met dezelfde bijnaam tegelijk worden verbonden."

#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_games.html.heex:8
#, elixir-autogen, elixir-format
msgid "/game <nickname>"
msgstr "/game <nickname>"

#: lib/retro_hex_chat_web/controllers/help_content/feature_star_duel.html.heex:69
#, elixir-autogen, elixir-format
msgid "2 seconds of invulnerability after each respawn"
msgstr "2 seconden van onkwetsbaarheid na elke respawn"

#: lib/retro_hex_chat_web/controllers/help_content/feature_block_breakers.html.heex:19
#, elixir-autogen, elixir-format
msgid "3 shared lives — if the ball exits top or bottom, both players lose a life"
msgstr "3 gedeelde levens als de bal verlaat top of bodem, beide spelers verliezen een leven"

#: lib/retro_hex_chat_web/controllers/help_content/feature_block_breakers.html.heex:25
#, elixir-autogen, elixir-format
msgid "50 blocks arranged in 5 rows of 10 with different point values"
msgstr "50 blokken gerangschikt in 5 rijen van 10 met verschillende puntwaarden"

#: lib/retro_hex_chat_web/controllers/help_content/feature_debris_field.html.heex:40
#, elixir-autogen, elixir-format
msgid "8 asteroids of varying sizes are scattered across the arena"
msgstr "8 asteroïden van verschillende grootte zijn verspreid over de arena"

#: lib/retro_hex_chat_web/controllers/help_content/feature_block_breakers.html.heex:13
#: lib/retro_hex_chat_web/controllers/help_content/feature_pixel_tanks.html.heex:13
#, elixir-autogen, elixir-format
msgid "A / D"
msgstr "A / D"

#: lib/retro_hex_chat_web/controllers/help_content/feature_gravity_well.html.heex:41
#, elixir-autogen, elixir-format
msgid "A central star exerts gravitational pull on all ships and missiles"
msgstr "Een centrale ster oefent zwaartekracht uit op alle schepen en raketten."

#: lib/retro_hex_chat_web/controllers/help_content/feature_pixel_tanks.html.heex:43
#, elixir-autogen, elixir-format
msgid "After each hit, both tanks respawn at starting positions with 2 seconds of invulnerability"
msgstr "Na elke slag worden beide tanks in startposities met 2 seconden van onkwetsbaarheid gerepaponeerd"

#: lib/retro_hex_chat_web/controllers/help_content/feature_debris_field.html.heex:58
#: lib/retro_hex_chat_web/controllers/help_content/feature_gravity_well.html.heex:60
#, elixir-autogen, elixir-format
msgid "All other rules are identical to Star Duel (first to 7, wraparound, hyperspace warp)"
msgstr "Alle andere regels zijn identiek aan Star Duel (eerste tot 7, wraparound, hyperruimte warp)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_games.html.heex:226
#, elixir-autogen, elixir-format
msgid "Architecture"
msgstr "Bouwkunde"

#: lib/retro_hex_chat_web/controllers/help_content/feature_block_breakers.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_pixel_tanks.html.heex:11
#, elixir-autogen, elixir-format
msgid "Arrow Left / Right"
msgstr "Pijl links / rechts"

#: lib/retro_hex_chat_web/controllers/help_content/feature_light_trails.html.heex:11
#, elixir-autogen, elixir-format
msgid "Arrow keys"
msgstr "Pijltjestoetsen"

#: lib/retro_hex_chat_web/controllers/help_content/feature_debris_field.html.heex:51
#, elixir-autogen, elixir-format
msgid "Asteroids are static — same layout for both players, randomly generated per match"
msgstr "Asteroïden zijn statisch dezelfde layout voor beide spelers, willekeurig gegenereerd per wedstrijd"

#: lib/retro_hex_chat_web/controllers/help_content/feature_single_session.html.heex:39
#, elixir-autogen, elixir-format
msgid "Auto-Reconnect"
msgstr "Automatisch opnieuw verbinden"

#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_games.html.heex:31
#, elixir-autogen, elixir-format
msgid "Available Games"
msgstr "Beschikbare spellen"

#: lib/retro_hex_chat_web/controllers/help_content/feature_block_breakers.html.heex:44
#, elixir-autogen, elixir-format
msgid "Ball bounces off left/right walls but NOT top/bottom — that's your job"
msgstr "De bal stuitert links /right muren maar NIET bovenaan/bottom Dat is jouw taak"

#: lib/retro_hex_chat_web/controllers/help_content/feature_block_breakers.html.heex:36
#, elixir-autogen, elixir-format
msgid "Ball speed resets after each life lost"
msgstr "Balsnelheid reset na elk verloren leven"

#: lib/retro_hex_chat_web/controllers/help_content/feature_block_breakers.html.heex:34
#, elixir-autogen, elixir-format
msgid "Ball speeds up with each paddle hit and every 5 blocks destroyed"
msgstr "Bal versnelt met elke peddel geraakt en elke 5 blokken vernietigd"

#: lib/retro_hex_chat_web/controllers/help_content/feature_block_breakers.html.heex:58
#, elixir-autogen, elixir-format
msgid "Based on Atari's Breakout (1976) — cooperative brick-breaking for two players."
msgstr "Gebaseerd op Atari's Breakout (1976)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_pixel_tanks.html.heex:55
#, elixir-autogen, elixir-format
msgid "Based on Atari's Combat (1977) — the quintessential tank battle game."
msgstr "Gebaseerd op Atari's Combat (1977) is het basketbal van de tank."

#: lib/retro_hex_chat_web/controllers/help_content/feature_light_trails.html.heex:50
#, elixir-autogen, elixir-format
msgid "Based on Atari's Surround (1977) and Tron's Light Cycles — the original trail game."
msgstr "Gebaseerd op Atari's Surround (1977) en Tron's Light Cycles, het originele parcoursspel."

#: lib/retro_hex_chat_web/controllers/help_content/feature_star_duel.html.heex:85
#, elixir-autogen, elixir-format
msgid "Based on Spacewar! (1962) — the grandfather of space combat games."
msgstr "Gebaseerd op de Spacewar! (1962) De grootvader van ruimtegevechten."

#: lib/retro_hex_chat_web/controllers/help_content/feature_light_trails.html.heex:26
#, elixir-autogen, elixir-format
msgid "Both players move one cell per tick on a 60x40 grid (10 ticks per second)"
msgstr "Beide spelers verplaatsen één cel per teek op een 60x40 raster (10 teken per seconde)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_games.html.heex:22
#, elixir-autogen, elixir-format
msgid "Browse and select from 35 available games across 15 families"
msgstr "Blader en selecteer 35 beschikbare spellen in 15 families"

#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_games.html.heex:20
#, elixir-autogen, elixir-format
msgid "Chat with your opponent"
msgstr "Chat met je tegenstander"

#: lib/retro_hex_chat_web/controllers/help_content/feature_debris_field.html.heex:42
#, elixir-autogen, elixir-format
msgid "Colliding with an asteroid is instant death (scores a point for your opponent)"
msgstr "Colliding met een asteroïde is instant death (scores een punt voor uw tegenstander)"

