#: lib/retro_hex_chat_web/controllers/help_content/feature_message_delete.html.heex:18
#, elixir-autogen, elixir-format
msgid ""
"You can only delete your own messages. The 5-minute time limit is enforced "
"server-side. Channel operators cannot delete other users' messages."
msgstr ""
"U kunt alleen uw eigen berichten verwijderen. De termijn van 5 minuten wordt"
" afgedwongen aan de serverzijde. Kanaaloperators kunnen de berichten van "
"andere gebruikers niet verwijderen."

#: lib/retro_hex_chat_web/controllers/help_content/feature_message_edit.html.heex:40
#, elixir-autogen, elixir-format
msgid ""
"You can only edit your own messages. The 5-minute time limit is enforced "
"server-side. Editing preserves any reply context (if the message was a "
"reply)."
msgstr ""
"U kunt alleen uw eigen berichten bewerken. De termijn van 5 minuten wordt "
"afgedwongen aan de serverzijde. Bewerken behoudt elk antwoord context (als "
"het bericht een antwoord was)."

