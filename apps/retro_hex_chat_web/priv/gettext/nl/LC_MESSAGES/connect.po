#, elixir-autogen, elixir-format
msgid "Sessions expire after 10 failed reconnection attempts."
msgstr "Sessies verlopen na 10 mislukte pogingen tot herverbinding."

#: lib/retro_hex_chat_web/live/v2/connect_live.ex:354
#, elixir-autogen, elixir-format
msgid ""
"The nickname %{nickname} is available! Choose a password to register it."
msgstr ""
"De bijnaam %{nickname} is beschikbaar! Kies een wachtwoord om het te "
"registreren."

#: lib/retro_hex_chat_web/live/v2/connect_live.ex:297
#, elixir-autogen, elixir-format
msgid ""
"The nickname %{nickname} is registered. Please enter your password to "
"continue."
msgstr ""
"De bijnaam %{nickname} is geregistreerd. Voer uw wachtwoord in om verder te "
"gaan."

