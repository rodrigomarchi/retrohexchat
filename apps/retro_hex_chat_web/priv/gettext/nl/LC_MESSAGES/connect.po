#: lib/retro_hex_chat_web/live/v2/connect_live.ex:414
#, elixir-autogen, elixir-format
msgid "Register & Connect"
msgstr "Registreren & verbinden"

#: lib/retro_hex_chat_web/live/v2/connect_live.ex:350
#, elixir-autogen, elixir-format
msgid "Registration"
msgstr "Registratie"

#: lib/retro_hex_chat_web/live/v2/connect_live.ex:391
#, elixir-autogen, elixir-format
msgid "Repeat your password..."
msgstr "Herhaal je wachtwoord..."

#: lib/retro_hex_chat_web/live/v2/connect_live.ex:61
#, elixir-autogen, elixir-format
