msgstr "Sessie beëindigd"

#: lib/retro_hex_chat_web/live/v2/connect_live.ex:59
#, elixir-autogen, elixir-format
msgid "Session expired"
msgstr "Sessie verlopen"

#: lib/retro_hex_chat_web/live/v2/connect_live.ex:263
#, elixir-autogen, elixir-format
msgid "Session expiry"
msgstr "Duur van de zitting"

