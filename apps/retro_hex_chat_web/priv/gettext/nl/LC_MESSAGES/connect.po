#, elixir-autogen, elixir-format
msgid "Password must be at least 5 characters"
msgstr "Wachtwoord moet minstens 5 tekens zijn"

#: lib/retro_hex_chat_web/live/v2/connect_live.ex:141
#, elixir-autogen, elixir-format
msgid "Passwords do not match"
