#, elixir-autogen, elixir-format
msgid "Must start with a letter"
msgstr "Moet beginnen met een brief"

#: lib/retro_hex_chat_web/live/v2/connect_live.ex:203
#, elixir-autogen, elixir-format
msgid "Nickname"
msgstr "Bijnaam"

#: lib/retro_hex_chat_web/live/v2/connect_live.ex:181
#, elixir-autogen, elixir-format
msgid "Nickname cannot be empty"
msgstr "Bijnaam kan niet leeg zijn"

#: lib/retro_hex_chat_web/live/v2/connect_live.ex:190
#, elixir-autogen, elixir-format
msgid "Nickname cannot contain spaces"
msgstr "Bijnaam kan spaties niet bevatten"

