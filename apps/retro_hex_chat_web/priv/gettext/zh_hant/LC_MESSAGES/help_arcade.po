msgid "— Examine"
msgstr "- 檢查"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_bass.html.heex:30
#, elixir-autogen, elixir-format
msgid "— Examine / open verb menu"
msgstr "檢查/打開動詞菜單"

