msgstr "- 開火"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_rekkr.html.heex:38
#, elixir-autogen, elixir-format
msgid "— Fire / swing weapon"
msgstr "- 火器/搖擺武器"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_chex_quest.html.heex:38
#, elixir-autogen, elixir-format
msgid "— Fire Zorcher"
msgstr "- 消防佐爾赫"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_quake.html.heex:58
