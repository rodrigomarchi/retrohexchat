msgstr "/mode +s — Make channel secret /mode -s — Remove secret mode"

#: lib/retro_hex_chat_web/controllers/help_content/mode_t.html.heex:8
#, elixir-autogen, elixir-format
msgid "/mode +t — Enable topic lock /mode -t — Disable topic lock"
msgstr "/mode +t — Enable topic lock /mode -t — Disable topic lock"

#: lib/retro_hex_chat_web/controllers/help_content/mode_v.html.heex:8
#, elixir-autogen, elixir-format
