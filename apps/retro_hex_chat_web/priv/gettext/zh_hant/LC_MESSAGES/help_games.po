msgid "— Move boxer (8 directions)"
msgstr "——移動拳擊手(8個方向)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders.html.heex:11
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders_blitz.html.heex:11
