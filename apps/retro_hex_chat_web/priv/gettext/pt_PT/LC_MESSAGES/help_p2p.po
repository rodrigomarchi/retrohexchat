#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_sessions.html.heex:2
#, elixir-autogen, elixir-format
msgid ""
"P2P sessions allow direct communication between two registered users for "
"chat, file transfer, and audio/video calls."
msgstr ""
"As sessões de P2P permitem comunicação direta entre dois usuários "
"registrados para chat, transferência de arquivos e chamadas de áudio/video."

#: lib/retro_hex_chat_web/controllers/help_content/feature_file_transfer.html.heex:36
#, elixir-autogen, elixir-format
msgid "Pause and Resume"
msgstr "Pausa e continuação"

#: lib/retro_hex_chat_web/controllers/help_content/feature_video_call.html.heex:2
#, elixir-autogen, elixir-format
msgid ""
"Peer-to-peer video calls with full-screen remote video and a local video "
"thumbnail."
msgstr "Chamadas de vídeo com ecrã completo e uma miniatura de vídeo local."

#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_sessions.html.heex:70
#, elixir-autogen, elixir-format
msgid ""
"Pending sessions (waiting for the peer) expire in 5 minutes. The lobby "
"expires due to inactivity after 15 minutes. The WebRTC connection has a "
"30-second timeout."
msgstr ""
"Sessões pendentes (esperando pelo par) expiram em 5 minutos. O lobby expira "
"devido à inatividade após 15 minutos. A ligação WebRTC tem um intervalo de "
"30 segundos."

