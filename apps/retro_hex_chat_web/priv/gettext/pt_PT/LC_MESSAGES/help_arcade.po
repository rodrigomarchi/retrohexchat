#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_librequake.html.heex:91
#, elixir-autogen, elixir-format
msgid ""
"Combined with the GPL-licensed Quake engine source code (released by id "
"Software in 1999), LibreQuake creates a 100% free and open source game."
msgstr ""
