#: lib/retro_hex_chat_web/controllers/help_content/mode_k.html.heex:2
#, elixir-autogen, elixir-format
msgid "Sets a password (key) that users must provide to join the channel."
msgstr "Define uma senha (chave) que os usuários devem fornecer para entrar no canal."

#: lib/retro_hex_chat_web/controllers/help_content/mode_c.html.heex:2
#, elixir-autogen, elixir-format
msgid "Strips all formatting codes from messages, including bold, italic, underline, color codes, and reverse. Messages and /me actions are processed server-side before delivery."
msgstr "Tira todos os códigos de formatação de mensagens, incluindo negrito, itálico, sublinhado, códigos de cores e inverso. As mensagens e as ações /me são processadas no servidor antes da entrega."

