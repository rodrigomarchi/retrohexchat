#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_freedoom1.html.heex:76
#, elixir-autogen, elixir-format
msgid "WAD compatible"
msgstr "WAD 호환"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_doom.html.heex:79
#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_halflife.html.heex:31
#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_quake.html.heex:39
#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_quake2.html.heex:30
