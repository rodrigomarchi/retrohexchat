#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid.html.heex:44
#, elixir-autogen, elixir-format
msgid "3 lives per player — highest score when all sections clear or both out of lives wins"
msgstr "3 کھلاڑی فی کھلاڑی — سب سے زیادہ اسکور اس وقت جیتا جب تمام حصے واضح ہوں یا دونوں زندگیوں میں جیت جائیں۔"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders.html.heex:56
