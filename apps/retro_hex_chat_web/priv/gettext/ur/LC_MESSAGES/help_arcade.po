#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_lure.html.heex:24
#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_soltys.html.heex:24
#, elixir-autogen, elixir-format
msgid "— Walk / interact with object"
msgstr "— چیز کیساتھ ساتھ چلنا / بات‌چیت کرنا"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_doom.html.heex:113
#, elixir-autogen, elixir-format
msgid "— Walls with different textures often hide secret rooms with weapons and ammo. Press Use on everything."
msgstr "— مختلف بازوؤں کے ساتھ دیواروں میں اکثر ہتھیاروں اور ایمو کے ساتھ خفیہ کمرے چھپ جاتے ہیں ۔ پریس ہر چیز پر استعمال کریں۔"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_halflife_uplink.html.heex:55
#, elixir-autogen, elixir-format
msgid "— Weapon category"
msgstr "— رنگ‌برنگی دُنیا"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_doom.html.heex:86
#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_quake.html.heex:45
#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_quake2.html.heex:39
#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_wolfenstein.html.heex:41
#, elixir-autogen, elixir-format
msgid "— Weapon select"
msgstr "— انتخاب"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_halflife_uplink.html.heex:64
#, elixir-autogen, elixir-format
msgid "— Weapons have alt-fire modes. The shotgun's double-barrel blast is devastating up close."
msgstr "— ہتھیاروں میں فائرنگ کا طریقہ کار ہے۔ گولگن کا ڈبل بابر دھماکا قریب واقع ہے۔"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_hacx.html.heex:63
#, elixir-autogen, elixir-format
msgid "— Weapons look and behave differently from classic DOOM. Learn their quirks."
msgstr "سپاہی کلاسیکی دُنیا سے فرق نظر آتے ہیں ۔ اُن کی مہارت سیکھیں ۔"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_freedoom2.html.heex:77
#, elixir-autogen, elixir-format
msgid "— Works with community DOOM II mods — decades of free content at your fingertips."
msgstr "— کمیونٹی ڈومم دوم — اپنی انگلیوں پر کئی دہوں سے آزاد مواد — کے ساتھ کام کرتے ہیں ۔"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_quake2.html.heex:23
#, elixir-autogen, elixir-format
msgid "— Yamagi Quake II compiled to WebAssembly via Emscripten. Features WebGL 2 rendering, software rendering fallback, and in-browser save games."
msgstr "— یاماسکرن کے ذریعے یام‌اِن‌فِک دوم نے ویب‌سائٹ پر جمع کِیا ۔ اخذ کردہ ویبGL 2 کرونا، سافٹ وئیر کاری گرڈ بیک اور ان-بارکر کھیلوں کو محفوظ کرتا ہے۔"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_wolfenstein_3d.html.heex:58
#, elixir-autogen, elixir-format
msgid "— You can hear guards through doors. Plan your approach before opening."
msgstr "— آپ دروازوں کے ذریعے گارڈوں کو سنا سکتے ہیں ۔ شروع ہونے سے پہلے اپنا جائزہ لیں ۔"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_dreamweb.html.heex:60
#, elixir-autogen, elixir-format
msgid "— You can only carry a limited number of items. Choose wisely what to take."
msgstr "— آپ صرف تھوڑی بہت چیزیں لے سکتے ہیں ۔ سمجھ‌داری سے فیصلہ کریں ۔"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_quake2_shareware.html.heex:63
#, elixir-autogen, elixir-format
msgid "— You'll revisit areas with new keys and equipment. Remember the layout."
msgstr "— آپ نئی کلیدوں اور اوزاروں کے ساتھ علاقوں میں تقسیم کریں گے. خالی یاد رکھیں."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_lure.html.heex:67
#, elixir-autogen, elixir-format
msgid "— Your companion Ratpouch can perform unique actions. Tell him to do things."
msgstr "— آپ کا ساتھی رٹپووچ منفرد کام انجام دے سکتا ہے ۔ اسے کچھ کرنے کے لئے کہو."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_quake2.html.heex:52
#, elixir-autogen, elixir-format
msgid "— Your starting Blaster has infinite ammo but low damage. Switch to better weapons as soon as you find them."
msgstr "— آپ کا شروع شروع میں بلاگنگو بے انتہا مگر کم نقصان ہوا ہے ۔ ان کی تلاش کے فوراً بعد بہتر ہتھیاروں پر سوئچ."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_halflife.html.heex:24
#, elixir-autogen, elixir-format
msgid "— an open-source reimplementation of the GoldSource engine, compiled to WebAssembly via Emscripten (GPL-2.0). Features WebGL2 rendering and Web Audio support."
msgstr "— ایک کھلے ماخذ کی ری میکیشن آف دی گولڈ کرافٹ انجن، جس نے ایسکریپٹن (ایم ایل-2.0) کے ذریعے ویب سیریز کو جمع کیا۔ ویبGL2 ترجمہ اور ویب آڈیو معاونت۔"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm.html.heex:68
#, elixir-autogen, elixir-format
msgid "— the legendary multi-engine adventure game interpreter with an official Emscripten backend, compiled to WebAssembly (GPL-3.0). Game data is loaded on-demand via HTTP filesystem."
msgstr "— ایک سرکاری Escreten کمرشل کے ساتھ مل کر ویب سیریز کو جمع کیا گیا گیم ڈاٹ کو ایچ ٹی پی فائل سسٹم کے ذریعے-ڈیمنڈ پر لاد دیا گیا ہے۔"
