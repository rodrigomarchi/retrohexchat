#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_soltys.html.heex:86
#, elixir-autogen, elixir-format
msgid "\"Soltys\" means \"Mayor\" (village head) in Polish. The game is a cult classic in Poland, celebrated for its depiction of mid-1990s village life and folk humor."
msgstr "پولینڈ فہرست پولینڈ کے شہر انگریزی ویکیپیڈیا کے مشارکین. \"Soltys\". میاور (village) (انگریزی: Mayor (village)) کا مطلب ہے۔ یہ کھیل پولینڈ میں ایک مذہبی کلاسیک ہے، جو 1990ء کی دہائی کے وسط میں دیہی زندگی اور قوم پرستانہ زندگی کی تصویر کشی کی وجہ سے منایا جاتا تھا۔"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm.html.heex:50
#, elixir-autogen, elixir-format
msgid "(1992) — Revolution Software's debut. Medieval fantasy with innovative Virtual Theatre AI system."
msgstr "(1992ء) — انقلاب سافٹ ویئر کے ڈیبٹ۔ مریخی فن جس میں نویاتی تھیٹر اے آئی نظام ہے۔"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm.html.heex:14
#, elixir-autogen, elixir-format
msgid "(1994) — Cyberpunk masterpiece by Revolution Software. Full CD version with voice acting."
msgstr "( 1994ء ) — انقلاب کے سافٹ ویئر کی طرف سے خیبر پختونخوا کی حکومت ۔ آواز کے ساتھ مکمل سی ڈی ورژن."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm.html.heex:32
#, elixir-autogen, elixir-format
msgid "(1994) — Dark cyberpunk top-down adventure by Creative Reality. Full CD version with voice acting."
msgstr "(1994ء) — ڈارک خیبر پختونخوا کی جانب سے تخلیقی حقیقت۔ آواز کے ساتھ مکمل سی ڈی ورژن."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm.html.heex:41
#, elixir-autogen, elixir-format
msgid "(1995) — Comic Indiana Jones-style adventure in the Amazon. Full CD version with voice acting."
msgstr "(195ء) — کومک انڈین جونس-ستیل مہم جو ایمیزون میں۔ آواز کے ساتھ مکمل سی ڈی ورژن."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm.html.heex:59
#, elixir-autogen, elixir-format
msgid "(1995) — Surreal Polish puzzle adventure by LK Avalon. Rescue your grandfather from underground pirates."
msgstr "(1995ء) — سورۂ پولینڈ کی ایجادات LK Avalon۔ آپ کے دادا کو نیچے کی پٹیوں سے بچا."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm.html.heex:23
#, elixir-autogen, elixir-format
msgid "(1996) — Hilarious Spanish point & click parody of Dracula. Full version with MP3 voice acting."
msgstr "(1996ء) — مختلف ہسپانوی پوائنٹ & کلکتہ آف ڈراکولا۔ ایم پی3 آواز کے ساتھ مکمل ورژن۔"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade.html.heex:122
#, elixir-autogen, elixir-format
msgid "(ECWolf compiled to WebAssembly via Emscripten). DOOM games are powered by"
msgstr "(ECWolf نے Escripten کے ذریعے ویب سائٹ پر جمع کیا۔ DodoM کھیلوں میں طاقت ہوتی ہے۔"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade.html.heex:117
#, elixir-autogen, elixir-format
msgid "(GoldSource reimplementation compiled to WebAssembly). Wolfenstein 3D is powered by"
msgstr "( ویب سیریز کے لئے جمع کی گئی. وولفنستائن 3D کی طاقت رکھتا ہے۔"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade.html.heex:127
#, elixir-autogen, elixir-format
msgid "(PrBoom+ compiled to WebAssembly). Quake games are powered by"
msgstr "(PrBom+ جمع کیا گیا ہے کھیلوں کے کھیلوں میں طاقت ہوتی ہے۔"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade.html.heex:129
#, elixir-autogen, elixir-format
msgid "(QuakeSpasm compiled to WebAssembly). Quake II is powered by"
msgstr "(کوئکیسپاسم نے ویب سائٹ پر جمع کیا۔ ایس ایم دوم کی طاقت سے کام لیا گیا ہے۔"

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade.html.heex:131
#, elixir-autogen, elixir-format
msgid "(Yamagi Quake II compiled to WebAssembly). All support keyboard, mouse, and gamepad input."
msgstr "(یا مجسّمہ دوم نے ویب‌وی‌ویس کو جمع کِیا ۔ ) تمام کی بورڈ، ماکس اور کھیلوں کی دیکھ بھال."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade.html.heex:16
#, elixir-autogen, elixir-format
msgid ") to play."
msgstr ") کھیلنے کے لئے."

