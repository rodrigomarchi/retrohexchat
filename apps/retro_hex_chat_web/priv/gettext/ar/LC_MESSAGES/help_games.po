#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid.html.heex:44
#, elixir-autogen, elixir-format
msgid ""
"3 lives per player — highest score when all sections clear or both out of "
"lives wins"
msgstr "3 أرواح لكل لاعب - أعلى درجة عندما تُوضّح جميع الأقسام أو يفوز كلاهما"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders.html.heex:56
