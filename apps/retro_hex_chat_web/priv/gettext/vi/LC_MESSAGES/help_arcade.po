#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_freedm.html.heex:83
#, elixir-autogen, elixir-format
msgid "— Great for learning weapon behavior and movement techniques before tackling Phase 1 or Phase 2."
msgstr "- Tốt cho việc học hành vi vũ khí và kỹ thuật vận động trước khi giải quyết giai đoạn 1 hay giai đoạn 2."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_halflife_uplink.html.heex:77
#, elixir-autogen, elixir-format
msgid "— Headcrabs are weak to melee. Save bullets for tougher enemies."
msgstr "- Người Ả Rập yếu đuối lắm. Tiết kiệm đạn cho kẻ thù cứng rắn hơn."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_drascula.html.heex:64
#, elixir-autogen, elixir-format
msgid "— Heavy on pop culture references, horror movie parodies, and Spanish comedy."
msgstr "- Rất quan trọng về văn hóa nhạc pop, phim kinh dị và hài kịch Tây Ban Nha."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_chex_quest.html.heex:64
#, elixir-autogen, elixir-format
msgid "— Hidden areas contain extra Zorcher energy. Check suspicious walls."
msgstr "- Những khu vực ẩn chứa thêm năng lượng. Kiểm tra những bức tường đáng ngờ."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_halflife.html.heex:61
#, elixir-autogen, elixir-format
msgid "— Hold crouch while jumping to reach higher ledges. Essential for navigation in Uplink."
msgstr "- Giữ cúi xuống khi nhảy lên cao. Cần thiết để định vị ở Uplink."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_halflife_uplink.html.heex:81
#, elixir-autogen, elixir-format
msgid "— Hold crouch while jumping to reach higher ledges. Essential for navigation."
msgstr "- Giữ cúi xuống khi nhảy lên cao. Cần thiết để định vị."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_fotaq.html.heex:78
#, elixir-autogen, elixir-format
msgid "— If you enjoy Monkey Island or Day of the Tentacle, you'll love this."
msgstr "- Nếu các người thích Đảo Khỉ hay Ngày Lễ xúc tu, các người sẽ thích cái này."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm.html.heex:134
