#, elixir-autogen, elixir-format
msgid "— Underwater sections require careful air monitoring. Know your escape route."
msgstr "- Những khu vực dưới nước đòi hỏi phải cẩn thận kiểm tra không khí. Biết đường thoát rồi."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_doom.html.heex:84
