#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_drascula.html.heex:71
#, elixir-autogen, elixir-format
msgid "— Item descriptions are often funny and sometimes contain puzzle hints."
msgstr "- Những lời miêu tả trong đó thường buồn cười và đôi khi chứa những gợi ý giải đố."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_fotaq.html.heex:53
#, elixir-autogen, elixir-format
msgid "— Joe's quips are hilarious, and dialogue often contains puzzle hints."
msgstr "- Những mạch máu của Joe rất hài hước, và những cuộc đối thoại thường chứa những gợi ý câu đố."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_bass.html.heex:72
#, elixir-autogen, elixir-format
