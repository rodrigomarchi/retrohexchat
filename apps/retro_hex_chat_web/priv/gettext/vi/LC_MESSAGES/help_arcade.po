#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_doom_shareware.html.heex:63
#, elixir-autogen, elixir-format
msgid "— Movement speed doubles, essential for dodging projectiles."
msgstr "- Tốc độ tăng gấp đôi, cần thiết để né đạn."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_doom_shareware.html.heex:85
#, elixir-autogen, elixir-format
msgid "— Moving forward + strafe simultaneously makes you ~40% faster than running straight."
msgstr "- Di chuyển về phía trước + strafe đồng thời làm cho bạn -40% nhanh hơn chạy thẳng."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_halflife.html.heex:75
#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_halflife_uplink.html.heex:88
#, elixir-autogen, elixir-format
msgid "— NPCs give hints about what's ahead. Pay attention to their dialogue."
msgstr "- NPC gợi ý về những gì phía trước. Chú ý đến cuộc đối thoại của họ."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_bass.html.heex:65
#, elixir-autogen, elixir-format
msgid "— NPCs often have new dialogue after events change. Talk to them multiple times."
msgstr "- NPC thường có cuộc đối thoại mới sau khi sự kiện thay đổi. Nói chuyện với họ nhiều lần."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm.html.heex:141
#, elixir-autogen, elixir-format
msgid "— NPCs sometimes have new dialogue after story events. Exhaust all conversation options."
msgstr "- Người NPC đôi khi có những cuộc đối thoại mới sau những sự kiện kể chuyện. Mở rộng tất cả các lựa chọn giao tiếp."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_scummvm_drascula.html.heex:78
#, elixir-autogen, elixir-format
msgid "— New items and interactions appear after story events change."
msgstr "— Những điều mới và sự tương tác xuất hiện sau khi câu chuyện thay đổi."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_freedm.html.heex:76
#, elixir-autogen, elixir-format
msgid "— No monsters by design — these are PvP arenas. In solo play, treat them as weapon testing grounds."
msgstr "- Không có quái vật nào được thiết kế — đây là những đấu trường PvP. Trong một trận đấu, hãy xem chúng như là khu vực thử vũ khí."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_chex_quest.html.heex:71
#, elixir-autogen, elixir-format
msgid "— Only 5 levels, but packed with nostalgia and secrets to find."
msgstr "- Chỉ có 5 tầng, nhưng có đầy sự hoài nghi và bí mật."

#: lib/retro_hex_chat_web/controllers/help_content/feature_arcade_wolfenstein.html.heex:38
