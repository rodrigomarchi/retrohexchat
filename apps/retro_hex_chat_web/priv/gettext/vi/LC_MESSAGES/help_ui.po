#: lib/retro_hex_chat_web/controllers/help_content/keyboard_shortcuts.html.heex:10
#, elixir-autogen, elixir-format
msgid ""
"Enter — Send message / select autocomplete item Shift+Enter — Insert newline"
" in input Up — Edit last message (when input is empty) / command history Up "
"/ Down — Command history / navigate autocomplete dropdown Ctrl+Up — Browse "
"history (saves draft) Ctrl+Down — Browse history forward (restores draft) "
"Ctrl+R — Reverse search history Tab — Select autocomplete item / cycle nick "
"completion Escape — Cancel edit mode / dismiss autocomplete / tooltip / — "
"Open command autocomplete (at start of input) @ — Open nick autocomplete (at"
" word boundary) # — Open channel autocomplete (at word boundary)"
msgstr ""
"Hãy nhập — Gửi thông điệp / chọn mục hoàn tất tự động Shift+Enter — chèn "
"dòng mới vào đầu vào — Sửa đổi thông điệp cuối cùng (khi nhập rỗng) / xuống "
"— lịch sử lệnh / xuống — lịch sử điều khiển / di chuyển tự động thả xuống "
"Ctrl+Up — Duyệt lịch sử (bản nháp) Ctrl+ Down — Mở dịch vụ duyệt (các dòng) "
"Ctrl+R — Dòng lệnh tìm kiếm ngược — Chọn mục tự động hoàn tất /   ngắt kết "
"thúc chu kỳ hoàn chỉnh — Hủy bỏ chế độ tự động sửa đổi / bỏ tự động sửa đổi "
"/ công cụ) — Lệnh Mở (tự động khởi động khởi động) — Mở (tự động khởi động "
"khởi động) — Mở dịch vụ mở từ — Mở dịch vụ tự động — Mở ra — mở giới hạn tự "
"động) — Mở dịch vụ tự động — mở kênh (t thị trường tự động) — mở dịch vụ tự "
"động)"

