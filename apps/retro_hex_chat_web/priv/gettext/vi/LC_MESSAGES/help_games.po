msgstr "Không có sự di chuyển ngược — hãy lập kế hoạch cẩn thận"

#: lib/retro_hex_chat_web/controllers/help_content/feature_pixel_tanks.html.heex:29
#, elixir-autogen, elixir-format
msgid "One missile per player at a time — you can't fire again until it expires or hits"
msgstr "Một tên lửa cho mỗi người một lúc - bạn không thể bắn một lần nữa cho đến khi nó hết hạn hoặc trúng"

#: lib/retro_hex_chat_web/controllers/help_content/feature_gravity_well.html.heex:69
#, elixir-autogen, elixir-format
msgid "Orbit, don't fight"
msgstr "Đừng đánh"

#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_games.html.heex:2
#, elixir-autogen, elixir-format
msgid "P2P Games lets you play retro arcade games directly with another user. Games run in real-time over WebRTC DataChannel — no server relay, minimal latency. 15 base games with 20 additional mode variants across action, sports, racing, and co-op genres."
msgstr "Trò chơi P2P cho phép bạn chơi trò chơi điện tử ngược trực tiếp với một người dùng khác. Trò chơi chạy trong thời gian thực trên WebTC DataCCCChanel — không có máy chủ chuyển tiếp, độ trễ tối thiểu. 15 trận đấu cơ bản với 20 biến thể khác nhau qua hành động, thể thao, đua xe, và các thể loại tương tác."

#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_games.html.heex:244
#, elixir-autogen, elixir-format
msgid "P2P Sessions"
msgstr "Phiên chạy P2P"

#: lib/retro_hex_chat_web/controllers/help_content/feature_block_breakers.html.heex:38
#, elixir-autogen, elixir-format
msgid "Paddle hit angle affects ball direction — edges create steeper bounces (up to 60 degrees)"
msgstr "Góc đập mạnh ảnh hưởng đến hướng của bóng — cạnh tạo ra những cú nhảy dốc (lên đến 60 độ)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_games.html.heex:236
#, elixir-autogen, elixir-format
msgid "Pending sessions expire in 5 minutes. The lobby expires after 15 minutes of inactivity (with a warning at 10 minutes)."
msgstr "Thời gian chờ hết hạn trong 5 phút. Hành lang sẽ hết hạn sau 15 phút ngừng hoạt động (với một lời cảnh báo vào lúc 10 phút)."

#: lib/retro_hex_chat_web/controllers/help_content/feature_p2p_games.html.heex:50
#, elixir-autogen, elixir-format
msgid "Pixel Tanks"
msgstr "Xe tăng điểm ảnh"

#: lib/retro_hex_chat_web/controllers/help_content/feature_light_trails.html.heex:2
#, elixir-autogen, elixir-format
msgid "Race across a neon grid leaving a glowing trail behind you. Hit any trail or the wall and you're out. Trap your opponent to win. Both players move continuously at a fixed pace — there's no stopping, only choosing where to turn next. First to 3 round wins takes the match."
msgstr "Chạy qua mạng lưới neon để lại dấu vết sáng ngời phía sau. Đi theo bất cứ đường mòn nào hoặc bức tường thì anh sẽ bị loại. Đặt bẫy đối thủ để chiến thắng. Cả hai người chơi di chuyển liên tục ở một tốc độ cố định - không có dừng lại, chỉ chọn nơi để quay tiếp theo. 3 hiệp đầu sẽ thắng."

#: lib/retro_hex_chat_web/controllers/help_content/feature_single_session.html.heex:2
#, elixir-autogen, elixir-format
msgid "RetroHexChat enforces a"
msgstr "Retro HexChat thi hành một"

