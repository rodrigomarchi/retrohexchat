#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing_clean.html.heex:21
#, elixir-autogen, elixir-format
msgid "No speed boosts or ice patches — obstacle avoidance only"
msgstr "Không có sự gia tăng tốc độ hay vá băng — chỉ tránh được chướng ngại vật"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey_showdown.html.heex:32
#, elixir-autogen, elixir-format
