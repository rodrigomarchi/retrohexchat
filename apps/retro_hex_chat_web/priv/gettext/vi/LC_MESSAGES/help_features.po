#, elixir-autogen, elixir-format
msgid "- Only appears in private message conversations (not channels)"
msgstr "- Chỉ xuất hiện trong các cuộc trò chuyện tin nhắn riêng (không phải các kênh)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_timers.html.heex:46
#, elixir-autogen, elixir-format
msgid "- Repeat: minimum 10 seconds, maximum 86,400 seconds."
msgstr "- Nhắc lại: tối thiểu 10 giây, tối đa 86,400 giây."

#: lib/retro_hex_chat_web/controllers/help_content/feature_notices.html.heex:10
#, elixir-autogen, elixir-format
