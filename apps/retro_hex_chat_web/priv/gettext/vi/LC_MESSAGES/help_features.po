msgstr "- Ánh xạ không ảnh hưởng đến thông báo thị giác ( Chớp song song, đèn flash)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_timers.html.heex:43
#, elixir-autogen, elixir-format
msgid "- One-shot: minimum 1 second, maximum 86,400 seconds (24 hours)."
msgstr "- Một phát: tối thiểu 1 giây, tối đa 86,400 giây (24 giờ)."

