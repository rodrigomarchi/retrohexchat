#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_raid.html.heex:44
#, elixir-autogen, elixir-format
msgid ""
"3 lives per player — highest score when all sections clear or both out of "
"lives wins"
msgstr ""
"Oyuncu başına 3 hayat - tüm bölümler açık veya her iki yaşamdan çıktığında "
"en yüksek puan"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_invaders.html.heex:56
#, elixir-autogen, elixir-format
msgid "3 lives per player — lose a life when hit by an alien bomb"
msgstr ""
"Oyuncu başına 3 hayat - yabancı bir bomba tarafından vurulduğunda bir hayat "
"kaybetmek"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey.html.heex:93
