#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_pong.html.heex:35
#, elixir-autogen, elixir-format
msgid ""
"Ball angle depends on where it hits the paddle — center gives a shallow "
"bounce, edges give steep angles (up to 60 degrees)"
msgstr ""
"Ball açısı, paddle'a vurduğu yere bağlıdır - merkez sığ bir sıçrama verir, "
"kenarlar dik açılar verir (60 dereceye kadar)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_tennis.html.heex:49
#, elixir-autogen, elixir-format
msgid "Ball must clear the net (simulated height arc)"
msgstr "Ball net olmalıdır (simated yükseklik yay)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_pong.html.heex:31
#, elixir-autogen, elixir-format
msgid "Ball speed increases with each paddle hit, up to 2.4x initial speed"
msgstr "Ball speed her paddle hit ile artar, 2.4x ilk hıza kadar"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_boxing.html.heex:58
#, elixir-autogen, elixir-format
msgid "Based on Activision's Boxing (1980) for the Atari 2600."
msgstr "Activision'un Boxing'ine göre Atari 2600."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_hockey.html.heex:121
#, elixir-autogen, elixir-format
msgid "Based on Activision's Ice Hockey (1981) for the Atari 2600."
msgstr "Activision'un Buz Hokeyi (2014) for the Atari 2600."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_pong.html.heex:49
#, elixir-autogen, elixir-format
msgid ""
"Based on Atari's Pong (1972) — the game that started the video game "
"industry."
msgstr "Atari'nin Pong.'a dayanarak - video oyunu endüstrisine başlayan oyun."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_warlords.html.heex:69
#, elixir-autogen, elixir-format
msgid ""
"Based on Atari's Warlords (1980) — castle defense meets Breakout in a head-"
"to-head duel."
msgstr ""
"Atari'nin Warlords (1980)'a dayanarak - kale savunması bir kafa önünde "
"toplanıyor."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw.html.heex:76
#, elixir-autogen, elixir-format
msgid "Based on Outlaw (1978) by David Crane for the Atari 2600."
msgstr "David Nicholson 2600 için Outlaw'a dayanarak."

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_enduro.html.heex:62
#, elixir-autogen, elixir-format
msgid "Best of 3 days — highest total score wins"
msgstr "En iyi 3 gün - en yüksek toplam puan kazanır"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing.html.heex:20
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_skiing_clean.html.heex:19
#, elixir-autogen, elixir-format
msgid "Best of 3 rounds with increasing difficulty"
msgstr "En iyi 3 tur, artan zorlukla"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_boxing.html.heex:41
#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_outlaw.html.heex:26
