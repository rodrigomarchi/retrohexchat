msgstr "En iyi 3 tur - ilk olarak 2 tur kazanır"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost.html.heex:63
#, elixir-autogen, elixir-format
msgid "Best of 5 rounds (first to 3 wins)"
msgstr "En iyi 5 tur (ilk 3 galibiyet)"

#: lib/retro_hex_chat_web/controllers/help_content/feature_hex_frost_peaceful.html.heex:31
#, elixir-autogen, elixir-format
msgid "Best of 5 rounds — same as Arctic Race"
