    {dgettext("help_arcade", "DOOM: Knee-Deep in the Dead")}
  </.help_link>
  ·
  <.help_link topic="feature-arcade-quake-shareware">
    {dgettext("help_arcade", "Quake: Dimension of the Doomed")}
  </.help_link>
</p>
