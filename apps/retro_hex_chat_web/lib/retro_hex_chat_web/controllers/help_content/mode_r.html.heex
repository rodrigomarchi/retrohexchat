<p>
  {gettext(
    "When set, only users who have identified with NickServ can join the channel. Users already in the channel when +R is set are not affected."
  )}
</p>
<.help_h4 icon={:icon_terminal}>{gettext("Usage")}</.help_h4>
<pre>{gettext("/mode +R — Enable registered-only mode /mode -R — Disable registered-only mode")}</pre>
<.help_h4 icon={:icon_link}>{gettext("See Also")}</.help_h4>
<p><.help_link topic="feature-nickserv">{gettext("NickServ")}</.help_link></p>
