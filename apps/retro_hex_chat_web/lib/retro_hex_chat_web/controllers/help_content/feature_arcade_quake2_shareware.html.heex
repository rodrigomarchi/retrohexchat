    {dgettext("help_arcade", "Quake: Dimension of the Doomed")}
  </.help_link>
  ·
  <.help_link topic="feature-arcade-doom-shareware">
    {dgettext("help_arcade", "DOOM: Knee-Deep in the Dead")}
  </.help_link>
  ·
  <.help_link topic="feature-arcade-wolfenstein-3d">
    {dgettext("help_arcade", "Wolfenstein 3D")}
  </.help_link>
</p>
