  </.help_link>
  {dgettext("help_commands", "— Send an action message")}<br />
  <.help_link topic="cmd-notice">
    {dgettext("help_commands", "/notice")}
  </.help_link>
  {dgettext("help_commands", "— Send a notice")}
</p>
