<p>
  {dgettext(
    "help_commands",
    "RetroHexChat supports the following slash commands. Type them in the chat input and press Enter."
  )}
</p>
<.help_h4 icon={:icon_connect}>{dgettext("help_commands", "Connection & Navigation")}</.help_h4>
<p>
  <.help_link topic="cmd-join">{dgettext("help_commands", "/join")}</.help_link>
  {dgettext("help_commands", "— Join a channel")}<br />
  <.help_link topic="cmd-part">
    {dgettext("help_commands", "/part")}
  </.help_link>
  {dgettext("help_commands", "— Leave a channel")}<br />
  <.help_link topic="cmd-quit">
    {dgettext("help_commands", "/quit")}
  </.help_link>
  {dgettext("help_commands", "— Disconnect from chat")}<br />
  <.help_link topic="cmd-list">
    {dgettext("help_commands", "/list")}
  </.help_link>
  {dgettext("help_commands", "— List available channels")}
</p>
