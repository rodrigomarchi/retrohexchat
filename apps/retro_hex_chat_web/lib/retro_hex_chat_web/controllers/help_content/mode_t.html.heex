<p>
  {dgettext(
    "help_channels",
    "When topic lock is set, only channel operators can change the topic."
  )}
</p>
<.help_h4 icon={:icon_terminal}>{dgettext("help_channels", "Usage")}</.help_h4>
<pre>{dgettext("help_channels", "/mode +t — Enable topic lock /mode -t — Disable topic lock")}</pre>
<.help_h4 icon={:icon_link}>{dgettext("help_channels", "See Also")}</.help_h4>
<p><.help_link topic="cmd-topic">{dgettext("help_channels", "/topic Command")}</.help_link></p>
