<p>{gettext("When topic lock is set, only channel operators can change the topic.")}</p>
<.help_h4 icon={:icon_terminal}>{gettext("Usage")}</.help_h4>
<pre>{gettext("/mode +t — Enable topic lock /mode -t — Disable topic lock")}</pre>
<.help_h4 icon={:icon_link}>{gettext("See Also")}</.help_h4>
<p><.help_link topic="cmd-topic">{gettext("/topic Command")}</.help_link></p>
