      </li>
    </ul>
  </li>
  <li>
    <.help_link topic="feature-hex-skiing">{dgettext("help_games", "Hex Skiing")}</.help_link>
    {dgettext("help_games", "— Alpine descent through obstacles, outrun the avalanche")}
    <ul>
      <li>
        <.help_link topic="feature-hex-skiing-escape">
          {dgettext("help_games", "Escape")}
        </.help_link>
        {dgettext("help_games", "— Infinite descent, ever-accelerating avalanche")}
      </li>
      <li>
        <.help_link topic="feature-hex-skiing-clean">
          {dgettext("help_games", "Clean Run")}
        </.help_link>
        {dgettext("help_games", "— No avalanche, pure time trial")}
      </li>
    </ul>
