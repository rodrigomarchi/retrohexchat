</ul>
<.help_h4 icon={:icon_webrtc}>{dgettext("help_games", "Architecture")}</.help_h4>
<p>
  {dgettext("help_games", "The session creator acts as")} <strong>host</strong>
  {dgettext(
    "help_games",
    "and runs the game loop at ~60fps. The peer sends keyboard inputs via DataChannel and receives game state snapshots. This keeps both players in sync with minimal bandwidth."
  )}
</p>
<.help_h4 icon={:icon_clock}>{dgettext("help_games", "Timeouts")}</.help_h4>
<p>
  {dgettext(
    "help_games",
    "Pending sessions expire in 5 minutes. The lobby expires after 15 minutes of inactivity (with a warning at 10 minutes)."
  )}
</p>
<.help_h4 icon={:icon_link}>{dgettext("help_games", "See Also")}</.help_h4>
<p>
  <.help_link topic="cmd-game">{dgettext("help_games", "/game")}</.help_link>
  · <.help_link topic="feature-p2p-sessions">{dgettext("help_games", "P2P Sessions")}</.help_link>
  · <.help_link topic="feature-arcade">{dgettext("help_games", "Solo Arcade")}</.help_link>
</p>
