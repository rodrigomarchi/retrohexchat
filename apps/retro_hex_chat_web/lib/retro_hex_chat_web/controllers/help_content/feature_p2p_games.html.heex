          {dgettext("help_games", "No Man's Land")}
        </.help_link>
        {dgettext("help_games", "— Open field, full horizontal movement")}
      </li>
    </ul>
  </li>
  <li>
    <.help_link topic="feature-hex-hockey">{dgettext("help_games", "Hex Hockey")}</.help_link>
    {dgettext("help_games", "— Ice hockey with AI goalies, 3 periods")}
    <ul>
      <li>
        <.help_link topic="feature-hex-hockey-blitz">
          {dgettext("help_games", "Blitz")}
        </.help_link>
        {dgettext("help_games", "— 1 period, faster puck, 80% tackle success")}
      </li>
      <li>
        <.help_link topic="feature-hex-hockey-showdown">
          {dgettext("help_games", "Showdown")}
        </.help_link>
        {dgettext("help_games", "— No timer, first to 5 goals, escalating puck speed")}
      </li>
