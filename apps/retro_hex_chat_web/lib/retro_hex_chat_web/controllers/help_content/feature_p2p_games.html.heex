<p>
  {dgettext(
    "help_games",
    "P2P Games lets you play retro arcade games directly with another user. Games run in real-time over WebRTC DataChannel — no server relay, minimal latency. 15 base games with 20 additional mode variants across action, sports, racing, and co-op genres."
  )}
</p>
<.help_h4 icon={:icon_send}>{dgettext("help_games", "Starting a Game")}</.help_h4>
<pre>{dgettext("help_games", "/game <nickname>")}</pre>
<p>
  {dgettext(
    "help_games",
    "This creates a game session and sends an invite via PM. The target user clicks the link to join the game lobby."
  )}
</p>
<.help_h4 icon={:icon_community}>{dgettext("help_games", "Game Lobby")}</.help_h4>
<p>
  {dgettext("help_games", "The lobby is where both players meet before starting a game. You can:")}
</p>
<ul>
  <li>{dgettext("help_games", "Chat with your opponent")}</li>
  <li>
    {dgettext("help_games", "Browse and select from 35 available games across 15 families")}
  </li>
  <li>{dgettext("help_games", "Wait for your opponent to accept or decline")}</li>
</ul>
<p>
  {dgettext("help_games", "Game selection requires")}
  <strong>{dgettext("help_games", "bilateral consent")}</strong>
  {dgettext("help_games", "— one player picks a game, the other must accept before it starts.")}
</p>
<.help_h4 icon={:icon_game_generic}>{dgettext("help_games", "Available Games")}</.help_h4>
<ul>
  <li>
    <.help_link topic="feature-hex-pong">{dgettext("help_games", "Hex Pong")}</.help_link>
    {dgettext("help_games", "— Cyberpunk Pong, first to 11 (win by 2)")}
  </li>
  <li>
    <.help_link topic="feature-light-trails">{dgettext("help_games", "Light Trails")}</.help_link>
    {dgettext("help_games", "— Neon grid trail race, trap your opponent")}
  </li>
  <li>
    <.help_link topic="feature-hex-warlords">{dgettext("help_games", "Hex Warlords")}</.help_link>
    {dgettext("help_games", "— Versus Breakout castle battle, last king standing")}
  </li>
  <li>
    <.help_link topic="feature-hex-boxing">{dgettext("help_games", "Hex Boxing")}</.help_link>
    {dgettext("help_games", "— Top-down boxing, distance-based scoring, first to KO")}
  </li>
  <li>
    <.help_link topic="feature-pixel-tanks">{dgettext("help_games", "Pixel Tanks")}</.help_link>
    {dgettext("help_games", "— Tank combat in destructible mazes, best of 3 rounds")}
  </li>
  <li>
    <.help_link topic="feature-star-duel">{dgettext("help_games", "Star Duel")}</.help_link>
    {dgettext("help_games", "— Newtonian space combat with wraparound arena")}
    <ul>
      <li>
        <.help_link topic="feature-gravity-well">
          {dgettext("help_games", "Gravity Well")}
        </.help_link>
        {dgettext("help_games", "— Central star pulls ships into orbital trajectories")}
      </li>
      <li>
        <.help_link topic="feature-debris-field">
          {dgettext("help_games", "Debris Field")}
        </.help_link>
        {dgettext("help_games", "— 8 asteroids block missiles and kill ships")}
      </li>
    </ul>
  </li>
  <li>
    <.help_link topic="feature-block-breakers">
      {dgettext("help_games", "Block Breakers")}
    </.help_link>
    {dgettext("help_games", "— Cooperative Breakout with two paddles")}
  </li>
  <li>
    <.help_link topic="feature-hex-outlaw">{dgettext("help_games", "Hex Outlaw")}</.help_link>
    {dgettext("help_games", "— Western duel across a cactus obstacle")}
    <ul>
      <li>
