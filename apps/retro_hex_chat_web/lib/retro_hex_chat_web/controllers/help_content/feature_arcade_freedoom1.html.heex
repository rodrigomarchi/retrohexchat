  ·
  <.help_link topic="feature-arcade-chex-quest">
    {dgettext("help_arcade", "Chex Quest")}
  </.help_link>
  · <.help_link topic="feature-arcade-hacx">{dgettext("help_arcade", "HacX")}</.help_link>
  · <.help_link topic="feature-arcade-rekkr">{dgettext("help_arcade", "REKKR")}</.help_link>
</p>
