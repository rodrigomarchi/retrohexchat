  </.help_link>
  ·
  <.help_link topic="feature-arcade-doom-shareware">
    {dgettext("help_arcade", "DOOM: Knee-Deep in the Dead")}
  </.help_link>
  ·
  <.help_link topic="feature-arcade-quake2-shareware">
    {dgettext("help_arcade", "Quake II: The Invasion")}
  </.help_link>
</p>
