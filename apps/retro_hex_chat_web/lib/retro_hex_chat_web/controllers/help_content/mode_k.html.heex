<p>
  {dgettext("help_channels", "Sets a password (key) that users must provide to join the channel.")}
</p>
<.help_h4 icon={:icon_terminal}>{dgettext("help_channels", "Usage")}</.help_h4>
<pre>{dgettext("help_channels", "/mode +k secretpass — Set channel key /mode -k — Remove channel key /join #channel secretpass — Join with key")}</pre>
