        <a href="/" class="landing-taskbar__btn landing-taskbar__btn--primary">Conectar</a>
      </div>
    </div>
  </nav>
</header>

<main id="main-content">
  <%!-- ══════════════ SEÇÃO 1: HERO ══════════════ --%>
  <section id="hero" class="landing-section" aria-labelledby="hero-heading">
    <div class="window landing-window landing-window--reveal">
      <div class="title-bar">
        <div class="title-bar-text">Retro Hex Chat &mdash; Bem-vindo</div>
        <div class="title-bar-controls">
          <button aria-label="Minimize" disabled></button>
          <button aria-label="Maximize" disabled></button>
          <button aria-label="Close" disabled></button>
        </div>
      </div>
      <div class="window-body">
        <h1 id="hero-heading" class="landing-hero__title">
          <img
            src="/images/landing/wordmark.svg"
            alt="Retro Hex Chat"
            class="landing-hero__wordmark"
          />
        </h1>

        <p class="landing-hero__subtitle">
          Chat federado. Como nos velhos tempos.<br /> Mas com a tecnologia de hoje.
        </p>

        <p class="landing-hero__description">
          Rode seu próprio servidor. Conecte com outros.<br />
          Sem empresa no meio. Sem algoritmos. Sem permissão.<br />
          <strong>Seus dados. Suas regras. Sua comunidade.</strong>
        </p>

        <div class="landing-hero__ctas">
          <a href="/" class="landing-hero__cta landing-hero__cta--primary">
            &#9654; Conectar
          </a>
        </div>

        <p class="landing-hero__proof">
          Projeto open source &bull; Feito com Elixir &amp; Phoenix
        </p>
      </div>
      <div class="status-bar">
        <p class="status-bar-field">Pronto</p>
        <p class="status-bar-field">v0.1.0</p>
      </div>
    </div>

    <div class="window landing-window landing-window--reveal">
      <div class="title-bar">
        <div class="title-bar-text">C:\Desktop</div>
        <div class="title-bar-controls">
          <button aria-label="Minimize" disabled></button>
          <button aria-label="Maximize" disabled></button>
          <button aria-label="Close" disabled></button>
        </div>
      </div>
      <div class="window-body">
        <div class="landing-desktop-icons">
          <button class="landing-desktop-icon" data-target="#features" type="button">
            <span class="landing-desktop-icon__img">&#x1F4C1;</span>
            <span class="landing-desktop-icon__label">Meus Chats</span>
          </button>
          <button class="landing-desktop-icon" data-target="#rede" type="button">
            <span class="landing-desktop-icon__img">&#x1F310;</span>
            <span class="landing-desktop-icon__label">Rede</span>
