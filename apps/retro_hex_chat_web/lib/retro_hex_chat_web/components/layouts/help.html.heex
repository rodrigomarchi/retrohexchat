<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <%!-- SEO Meta --%>
    <title>{assigns[:page_title] || "Help - RetroHexChat"}</title>
    <meta
      name="description"
      content={assigns[:page_description] || "RetroHexChat help documentation."}
    />
    <meta name="robots" content="index, follow" />
    <link
      rel="canonical"
      href={"https://retrohexchat.com#{assigns[:current_url] || "/chat/help"}"}
    />

    <%!-- Open Graph --%>
    <meta property="og:type" content="article" />
    <meta property="og:title" content={assigns[:page_title] || "Help - RetroHexChat"} />
    <meta
      property="og:description"
      content={assigns[:page_description] || "RetroHexChat help documentation."}
    />
    <meta
      property="og:url"
      content={"https://retrohexchat.com#{assigns[:current_url] || "/chat/help"}"}
    />
    <meta property="og:site_name" content="RetroHexChat" />

    <%!-- JSON-LD Structured Data --%>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://retrohexchat.com"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Help",
            "item": "https://retrohexchat.com/chat/help"
          }
        ]
      }
    </script>

    <%!-- Favicon --%>
    <link rel="icon" type="image/svg+xml" href={~p"/images/favicon.svg"} />
    <link rel="icon" type="image/x-icon" href={~p"/favicon.ico"} />

    <%!-- Fonts --%>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <%!-- CSS (same app.css — reuse 98.css and tokens) --%>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
  </head>
  <body class="help-page-body">
    {@inner_content}
  </body>
</html>
