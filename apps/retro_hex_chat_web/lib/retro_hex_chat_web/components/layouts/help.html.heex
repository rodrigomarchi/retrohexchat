<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <%!-- SEO Meta --%>
    <title>{assigns[:page_title] || "Help - RetroHexChat"}</title>
    <meta
      name="description"
      content={assigns[:page_description] || "RetroHexChat help documentation."}
    />
    <meta name="robots" content="index, follow" />
    <link
      rel="canonical"
      href={"https://retrohexchat.com#{assigns[:current_url] || "/chat/help"}"}
    />

    <%!-- Open Graph --%>
    <meta property="og:type" content="article" />
    <meta property="og:title" content={assigns[:page_title] || "Help - RetroHexChat"} />
    <meta
      property="og:description"
      content={assigns[:page_description] || "RetroHexChat help documentation."}
    />
    <meta
      property="og:url"
      content={"https://retrohexchat.com#{assigns[:current_url] || "/chat/help"}"}
    />
    <meta property="og:site_name" content="RetroHexChat" />

    <%!-- JSON-LD Structured Data --%>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://retrohexchat.com"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Help",
            "item": "https://retrohexchat.com/chat/help"
          }
        ]
      }
    </script>

    <%!-- Favicon --%>
    <link rel="icon" type="image/svg+xml" href={~p"/images/favicon.svg"} />
    <link rel="icon" type="image/x-icon" href={~p"/favicon.ico"} />

    <%!-- Fonts --%>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <%!-- CSS (same app.css — reuse retro design system and tokens) --%>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
  </head>
  <body>
    <div class="app-container">
      <div class="app-header">
        <img src="/images/header-logo.svg" alt="RetroHexChat" class="app-header-wordmark" />
        <div class="app-header-panels">
          <%!-- Toolbar: all buttons disabled (preview mode) --%>
          <div class="toolbar toolbar--preview" role="toolbar">
            <span class="toolbar-btn toolbar-btn--disabled" title="Connect">
              <.icon_btn_connect_disabled />
            </span>
            <span class="toolbar-btn toolbar-btn--disabled" title="View">
              <.icon_group_view class="toolbar-group-icon toolbar-icon--disabled" />
            </span>
            <span class="toolbar-btn toolbar-btn--disabled" title="Tools">
              <.icon_group_tools class="toolbar-group-icon toolbar-icon--disabled" />
            </span>
            <span class="toolbar-btn toolbar-btn--disabled" title="Notifications">
              <.icon_group_notifications class="toolbar-group-icon toolbar-icon--disabled" />
            </span>
            <span class="toolbar-btn toolbar-btn--disabled" title="Help">
              <.icon_group_help class="toolbar-group-icon toolbar-icon--disabled" />
            </span>
          </div>
          <%!-- Status bar: all fields disabled --%>
          <div class="status-bar">
            <p class="status-bar-field status-bar-section--left">
              <.icon_status_user class="status-bar-icon status-bar-icon--disabled" />
              <span class="status-bar-nick status-bar-text--disabled">Guest</span>
              <span class="status-bar-separator">|</span>
              <.icon_tab_channel class="status-bar-icon status-bar-icon--disabled" />
              <span class="status-bar-channel status-bar-text--disabled">No channel</span>
              <span class="status-bar-text--disabled">(0)</span>
              <span class="status-bar-separator">|</span>
              <span class="status-bar-connection--disconnected">● Off</span>
              <span class="status-bar-separator">|</span>
              <.icon_status_signal class="status-bar-icon status-bar-icon--disabled" />
              <span class="status-bar-text--disabled">Lag: —</span>
              <span class="status-bar-separator">|</span>
              <.icon_clock class="status-bar-icon status-bar-icon--disabled" />
              <span>--:--</span>
              <span class="status-bar-separator">|</span>
              <span class="status-bar-text--disabled">
                <.icon_dialog_sound class="status-bar-icon status-bar-icon--disabled" />
              </span>
            </p>
          </div>
        </div>
      </div>
      {@inner_content}
    </div>
  </body>
</html>
