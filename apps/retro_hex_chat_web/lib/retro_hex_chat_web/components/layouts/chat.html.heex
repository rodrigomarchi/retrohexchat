<!DOCTYPE html>
<html lang={RetroHexChatWeb.I18n.html_lang()} dir={RetroHexChatWeb.I18n.html_dir()}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta
      name="plausible-env"
      content={Application.get_env(:retro_hex_chat_web, :plausible_env, "prod")}
    />
    <.live_title default="RetroHexChat">
      {assigns[:page_title]}
    </.live_title>
    <meta name="robots" content={RetroHexChatWeb.SEO.noindex_content()} />
    <link rel="icon" type="image/svg+xml" href={~p"/images/favicon.svg"} />
    <link rel="icon" type="image/x-icon" href={~p"/favicon.ico"} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/retrohex.css"} />
    <script phx-track-static type="module" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body class="bg-desktop font-system text-text">
    {@inner_content}
  </body>
</html>
