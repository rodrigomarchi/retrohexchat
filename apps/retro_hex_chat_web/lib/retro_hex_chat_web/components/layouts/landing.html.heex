<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <%!-- SEO (dynamic per page) --%>
    <title>
      {assigns[:page_title] ||
        "Retro Hex Chat — Your server. Your conversations. Nobody in between."}
    </title>
    <meta
      name="description"
      content={
        assigns[:page_description] ||
          "Run your own chat server. Your data stays with you. Voice and video calls go directly between users via P2P. Open source, self-hosted, and free as in freedom."
      }
    />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={"https://retrohexchat.com#{@conn.request_path}"} />

    <%!-- Open Graph --%>
    <meta property="og:type" content="website" />
    <meta
      property="og:title"
      content={assigns[:page_title] || "Retro Hex Chat — Self-hosted chat with P2P calls"}
    />
    <meta
      property="og:description"
      content={
        assigns[:page_description] ||
          "Your data. Your rules. Your community. Real-time chat on your own server with direct P2P voice and video calls."
      }
    />
    <meta property="og:url" content={"https://retrohexchat.com#{@conn.request_path}"} />
    <meta property="og:site_name" content="Retro Hex Chat" />
    <meta property="og:locale" content="en_US" />

    <%!-- Twitter Card --%>
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content={assigns[:page_title] || "Retro Hex Chat — Self-hosted P2P chat"}
    />
    <meta
      name="twitter:description"
      content={
        assigns[:page_description] ||
          "Run your own server. Talk directly with your friends. Open source and self-hosted."
      }
    />

    <%!-- JSON-LD Structured Data --%>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Retro Hex Chat",
        "applicationCategory": "CommunicationApplication",
        "operatingSystem": "Web",
        "description": "Self-hosted chat software with P2P voice and video calls, inspired by the IRC of the 2000s. Open source, licensed under MIT.",
        "license": "https://opensource.org/licenses/MIT",
        "url": "https://retrohexchat.com",
        "author": {
          "@type": "Person",
          "name": "Rodrigo Marchi"
        },
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        }
      }
    </script>

    <%!-- Fonts (same as chat app) --%>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <%!-- Favicon --%>
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <%!-- Landing-specific CSS (no app.css, no LiveView) --%>
    <link rel="stylesheet" href="/assets/css/landing.css" />

    <%!-- Landing-specific JS (no app.js, no LiveView, no WebSocket) --%>
    <script defer src="/assets/js/landing.js">
    </script>
  </head>
  <body class="landing-body">
    <a href="#main-content" class="landing-skip-link">Skip to content</a>

    <%!-- ══════════════ HEADER (fixed nav) ══════════════ --%>
    <header class="landing-header" role="banner">
      <RetroHexChatWeb.Components.AppHeader.app_header logo_href="/" logo_variant={:full}>
        <:panels>
          <nav class="landing-nav" aria-label="Main navigation">
            <button
              class="landing-nav__hamburger"
              type="button"
              aria-label="Open navigation menu"
              aria-expanded="false"
              aria-controls="landing-nav-menu"
            >
              &#9776;
            </button>

            <div id="landing-nav-menu" class="landing-nav__links" role="menubar">
              <a
                href="/about"
                class={"landing-nav__link #{if assigns[:active_page] == :about, do: "landing-nav__link--active"}"}
                role="menuitem"
              >
                <.icon_warning class="licon licon-12" /> About
              </a>
              <a
                href="/how-it-works"
                class={"landing-nav__link #{if assigns[:active_page] == :how_it_works, do: "landing-nav__link--active"}"}
                role="menuitem"
              >
                <.icon_server class="licon licon-12" /> How It Works
              </a>
              <a
                href="/features"
                class={"landing-nav__link #{if assigns[:active_page] == :features, do: "landing-nav__link--active"}"}
                role="menuitem"
              >
                <.icon_chat class="licon licon-12" /> Features
              </a>
              <a
                href="/privacy"
                class={"landing-nav__link #{if assigns[:active_page] == :privacy, do: "landing-nav__link--active"}"}
                role="menuitem"
              >
                <.icon_lock class="licon licon-12" /> Privacy
              </a>
              <a
                href="/install"
                class={"landing-nav__link #{if assigns[:active_page] == :install, do: "landing-nav__link--active"}"}
                role="menuitem"
              >
                <.icon_terminal class="licon licon-12" /> Install
              </a>
              <a
                href="/community"
                class={"landing-nav__link #{if assigns[:active_page] == :community, do: "landing-nav__link--active"}"}
                role="menuitem"
              >
                <.icon_code class="licon licon-12" /> Community
              </a>
              <a
                href="/faq"
                class={"landing-nav__link #{if assigns[:active_page] == :faq, do: "landing-nav__link--active"}"}
                role="menuitem"
              >
                <.icon_question class="licon licon-12" /> FAQ
              </a>
              <a href="/chat/help" class="landing-nav__link" role="menuitem">
                <.icon_notepad class="licon licon-12" /> Docs
              </a>
              <div class="landing-nav__actions">
                <a href="/connect" class="landing-nav__btn landing-nav__btn--primary">
                  <.icon_connect class="licon licon-12" /> Connect
                </a>
              </div>
            </div>
          </nav>
        </:panels>
      </RetroHexChatWeb.Components.AppHeader.app_header>
    </header>

    <main id="main-content">
      {@inner_content}
    </main>

    <%!-- ══════════════ FOOTER ══════════════ --%>
    <footer class="landing-footer" role="contentinfo">
      <div class="window landing-window">
        <div class="title-bar">
          <div class="title-bar-text">About</div>
          <div class="title-bar-controls">
            <button aria-label="Minimize" disabled></button>
            <button aria-label="Maximize" disabled></button>
            <button aria-label="Close" disabled></button>
          </div>
        </div>
        <div class="window-body">
          <p>
            Retro Hex Chat is free software, licensed under MIT.<br />
            Built with Elixir, Phoenix, and LiveView.<br />
            Inspired by the IRC of the 2000s and the freedom it represented.
          </p>

          <div class="landing-footer__columns">
            <div class="landing-footer__col">
              <h3><.icon_code class="licon licon-12" /> Project</h3>
              <ul>
                <li>
                  <a
                    href="https://github.com/rodrigomarchi/retro_hex_chat"
                    target="_blank"
                    rel="noopener"
                  >
                    GitHub
                  </a>
                </li>
                <li>
                  <a
                    href="https://github.com/rodrigomarchi/retro_hex_chat/blob/main/CONTRIBUTING.md"
                    target="_blank"
                    rel="noopener"
                  >
                    Contribute
                  </a>
                </li>
                <li>
                  <a
                    href="https://github.com/rodrigomarchi/retro_hex_chat/blob/main/LICENSE"
                    target="_blank"
                    rel="noopener"
                  >
                    License (MIT)
                  </a>
                </li>
                <li>
                  <a href="/chat/help">Documentation</a>
                </li>
              </ul>
            </div>
            <div class="landing-footer__col">
              <h3><.icon_community class="licon licon-12" /> Community</h3>
              <ul>
                <li><a href="/connect" target="_blank" rel="noopener">#general</a></li>
                <li><a href="/connect" target="_blank" rel="noopener">#dev</a></li>
                <li><a href="/connect" target="_blank" rel="noopener">#help</a></li>
              </ul>
            </div>
            <div class="landing-footer__col">
              <h3><.icon_legal class="licon licon-12" /> Legal</h3>
              <ul>
                <li>
                  <a
                    href="https://github.com/rodrigomarchi/retro_hex_chat/blob/main/LICENSE"
                    target="_blank"
                    rel="noopener"
                  >
                    MIT License
                  </a>
                </li>
                <li>
                  <a
                    href="https://github.com/rodrigomarchi/retro_hex_chat/blob/main/SECURITY.md"
                    target="_blank"
                    rel="noopener"
                  >
                    Security
                  </a>
                </li>
              </ul>
            </div>
            <div class="landing-footer__col">
              <h3><.icon_heart class="licon licon-12" /> Support</h3>
              <ul>
                <li>
                  <a
                    href="https://github.com/sponsors/rodrigomarchi"
                    target="_blank"
                    rel="noopener"
                  >
                    GitHub Sponsors
                  </a>
                </li>
              </ul>
            </div>
          </div>

          <p class="landing-footer__quote">
            &ldquo;Your data. Your rules. Nobody in between.&rdquo;
          </p>

          <div class="landing-footer__meta">
            <span>v0.1.0</span>
            <span>Made by humans</span>
            <span>2025&ndash;2026</span>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
