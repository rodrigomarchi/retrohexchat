<!DOCTYPE html>
<html lang={RetroHexChatWeb.I18n.html_lang()} dir={RetroHexChatWeb.I18n.html_dir()}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta
      name="plausible-env"
      content={Application.get_env(:retro_hex_chat_web, :plausible_env, "prod")}
    />

    <%!-- SEO Meta --%>
    <.live_title default="Help — RetroHexChat">
      {assigns[:page_title]}
    </.live_title>
    <meta
      name="description"
      content={
        assigns[:page_description] ||
          "RetroHexChat help documentation. Learn about IRC commands, channel modes, features, and keyboard shortcuts."
      }
    />
    <meta name="robots" content="index, follow" />
    <link
      rel="canonical"
      href={"https://retrohexchat.com#{assigns[:canonical_url] || "/chat/help"}"}
    />

    <%!-- Open Graph --%>
    <meta property="og:type" content="article" />
    <meta
      property="og:title"
      content={assigns[:page_title] || "Help — RetroHexChat"}
    />
    <meta
      property="og:description"
      content={
        assigns[:page_description] ||
          "RetroHexChat help documentation."
      }
    />
    <meta
      property="og:url"
      content={"https://retrohexchat.com#{assigns[:canonical_url] || "/chat/help"}"}
    />
    <meta property="og:site_name" content="RetroHexChat" />

    <%!-- JSON-LD Structured Data --%>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://retrohexchat.com"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Help",
            "item": "https://retrohexchat.com/chat/help"
          }
        ]
      }
    </script>

    <%!-- Fonts --%>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <%!-- Favicon --%>
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <%!-- RetroHex CSS (Tailwind) + RetroHex Content JS (LiveSocket) --%>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/retrohex.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/retrohex_content.js"}>
    </script>
  </head>
  <body class="bg-desktop font-system text-text">
    {@inner_content}
  </body>
</html>
