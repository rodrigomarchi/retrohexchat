<.showcase_layout active_page={@active_page}>
  <h2 class="text-lg font-bold mb-3">{dgettext("showcase", "Fieldset")}</h2>

  <.showcase_card
    title={dgettext("showcase", "Basic Fieldset")}
    description="A Win98 groupbox with etched groove border and legend."
  >
    <.retro_fieldset legend={dgettext("showcase", "Personal Information")}>
      <.field_row>
        <.label class="text-sm w-24">{dgettext("showcase", "Name:")}</.label>
        <.input type="text" value="Troll" class="flex-1" />
      </.field_row>
      <.field_row>
        <.label class="text-sm w-24">{dgettext("showcase", "Email:")}</.label>
        <.input type="text" value="troll@retro.chat" class="flex-1" />
      </.field_row>
    </.retro_fieldset>
    <.code_example>
      &lt;.retro_fieldset legend="Personal Information"&gt;
      &lt;.field_row&gt;
      &lt;.label class="text-sm w-24"&gt;Name:&lt;/.label&gt;
      &lt;.input type="text" value="Troll" /&gt;
      &lt;/.field_row&gt;
      &lt;/.retro_fieldset&gt;
    </.code_example>
  </.showcase_card>

  <.showcase_card
    title={dgettext("showcase", "Event Sounds")}
    description="Replicating the platform's Sounds dialog fieldset."
  >
    <.retro_fieldset legend={dgettext("showcase", "Event Sounds")}>
      <div class="shadow-retro-field bg-white">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-300">
              <th class="text-left px-2 py-1 font-bold">{dgettext("showcase", "Event")}</th>
              <th class="text-left px-2 py-1 font-bold">{dgettext("showcase", "Sound")}</th>
              <th class="text-left px-2 py-1 font-bold">{dgettext("showcase", "Flash")}</th>
            </tr>
          </thead>
          <tbody>
            <tr :for={
              {event, sound} <- [
                {"Channel Message", "Ding Low"},
                {"Private Message", "Chime High"},
                {"Highlight/Mention", "Alert"},
                {"User Joined", "Click"},
                {"User Left", "Click"},
                {"Connected", "Chime Short"},
                {"Disconnected", "Chime Low"}
              ]
            }>
              <td class="px-2 py-1">{event}</td>
              <td class="px-2 py-1">
                <.select
                  :let={builder}
                  id={"fieldset-sound-#{event}"}
                  name={"sound_#{event}"}
                  value={sound}
                  label={sound}
                >
                  <.select_trigger builder={builder} class="h-7 text-sm w-28" />
                  <.select_content builder={builder}>
                    <.select_group>
                      <.select_item builder={builder} value={sound} label={sound}>
                        {sound}
                      </.select_item>
                    </.select_group>
                  </.select_content>
                </.select>
              </td>
              <td class="px-2 py-1">
                <.button variant="outline" size="sm">
                  <:icon><Icons.icon_btn_play /></:icon>
                  {dgettext("showcase", "Play")}
                </.button>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </.retro_fieldset>
  </.showcase_card>

  <.showcase_card
    title={dgettext("showcase", "Without Legend")}
    description="Fieldset without a legend text."
  >
    <.retro_fieldset>
      <.field_row>
        <.checkbox value={true} />
        <.label class="text-sm">{dgettext("showcase", "Enable notifications")}</.label>
      </.field_row>
      <.field_row>
        <.checkbox value={false} />
        <.label class="text-sm">{dgettext("showcase", "Play sounds")}</.label>
      </.field_row>
      <.field_row>
        <.checkbox value={true} />
        <.label class="text-sm">{dgettext("showcase", "Flash taskbar")}</.label>
      </.field_row>
    </.retro_fieldset>
    <.code_example>
      &lt;.retro_fieldset&gt;
      &lt;.field_row&gt;
      &lt;.checkbox value=&#123;true&#125; /&gt;
      &lt;.label&gt;Enable notifications&lt;/.label&gt;
      &lt;/.field_row&gt;
      &lt;/.retro_fieldset&gt;
    </.code_example>
  </.showcase_card>

  <.showcase_card
    title={dgettext("showcase", "Stacked Layout")}
    description="Field rows in vertical (stacked) layout."
  >
    <.retro_fieldset legend={dgettext("showcase", "Connection Settings")}>
      <.field_row stacked>
        <.label class="text-sm font-bold">{dgettext("showcase", "Server Address:")}</.label>
        <.input type="text" value="irc.retro.chat" class="w-full" />
      </.field_row>
      <.field_row stacked>
        <.label class="text-sm font-bold">{dgettext("showcase", "Port:")}</.label>
        <.input type="text" value="6667" class="w-32" />
      </.field_row>
    </.retro_fieldset>
    <.code_example>
      &lt;.field_row stacked&gt;
      &lt;.label&gt;Server Address:&lt;/.label&gt;
      &lt;.input type="text" value="irc.retro.chat" /&gt;
      &lt;/.field_row&gt;
    </.code_example>
  </.showcase_card>
</.showcase_layout>
